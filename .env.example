# WillowSoft Environment Configuration Example
# Copy this file to .env and configure values for your environment.

# Canonical Website URL
SITE_URL=https://willowsoft.co

# --- Supabase ---
# Project: https://app.supabase.com/project/chemyzlmjqvnoxeqxfku/settings/api
SUPABASE_URL=https://chemyzlmjqvnoxeqxfku.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Server-side only — NEVER expose to the browser. Used for content saves & bot logging.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin user is created in Supabase Auth (email/password); no app-level password here.
# Bootstrap the first admin in the Supabase dashboard (Authentication → Users) or via SQL.

# Environment Mode (development | production)
NODE_ENV=development

# WillowSoft Environment Configuration Example
# Copy this file to .env and configure values for your environment.

# Server Port
PORT=4173

# Canonical Website URL
SITE_URL=https://willowsoft.co

# Admin Panel Credentials
ADMIN_USER=admin
# WARNING: Always set a strong, unique password in production!
ADMIN_PASSWORD=willow-admin-2026

# Environment Mode (development | production)
# In production mode, ADMIN_PASSWORD is strictly required to be changed.
NODE_ENV=development

# Analytics Settings
MAX_STORED_EVENTS=5000

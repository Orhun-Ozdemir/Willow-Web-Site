---
interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{images && images.length > 1 && (
  <div class="product-gallery">
    <div class="product-gallery-main">
      <img data-gallery-main src={`/${images[0]}`.replace("//", "/")} alt={title} />
    </div>
    <div class="product-gallery-thumbs">
      {images.map((src, idx) => (
        <button
          type="button"
          class={`product-gallery-thumb${idx === 0 ? " active" : ""}`}
          data-src={`/${src}`.replace("//", "/")}
          aria-label={`${title} image ${idx + 1} of ${images.length}`}
          aria-pressed={idx === 0 ? "true" : "false"}
        >
          <img src={`/${src}`.replace("//", "/")} alt="" loading="lazy" decoding="async" />
        </button>
      ))}
    </div>
  </div>
)}

<script>
  function setupGallery() {
    const galleries = document.querySelectorAll('.product-gallery');
    galleries.forEach(gallery => {
      const mainImg = gallery.querySelector('[data-gallery-main]') as HTMLImageElement;
      const thumbs = gallery.querySelectorAll('.product-gallery-thumb');
      
      thumbs.forEach(thumb => {
        thumb.addEventListener('click', () => {
          thumbs.forEach(t => t.classList.remove('active'));
          thumbs.forEach(t => t.setAttribute('aria-pressed', 'false'));
          thumb.classList.add('active');
          thumb.setAttribute('aria-pressed', 'true');
          const src = (thumb as HTMLButtonElement).dataset.src;
          if (src && mainImg) {
            mainImg.src = src;
          }
        });
      });
    });
  }

  // Run on load and after View Transitions if any
  setupGallery();
  document.addEventListener('astro:after-swap', setupGallery);
</script>

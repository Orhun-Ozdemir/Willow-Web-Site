---
import type { Locale } from "@/lib/cms";
import { locales } from "@/lib/cms";

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

const labels: Record<string, string> = { en: "EN", tr: "TR", de: "DE", fr: "FR", es: "ES", it: "IT", ar: "AR", ja: "JA" };
const navLabels = {
  home: { en: "Home", tr: "Ana Sayfa", de: "Startseite", fr: "Accueil", es: "Inicio", it: "Home", ar: "الرئيسية", ja: "ホーム" },
  solutions: { en: "Solutions", tr: "Çözümler", de: "Lösungen", fr: "Solutions", es: "Soluciones", it: "Soluzioni", ar: "الحلول", ja: "ソリューション" },
  services: { en: "Services", tr: "Hizmetler", de: "Leistungen", fr: "Services", es: "Servicios", it: "Servizi", ar: "الخدمات", ja: "サービス" },
  products: { en: "Products", tr: "Ürünler", de: "Produkte", fr: "Produits", es: "Productos", it: "Prodotti", ar: "المنتجات", ja: "製品" },
  news: { en: "News", tr: "Haberler", de: "Neuigkeiten", fr: "Actualités", es: "Noticias", it: "Notizie", ar: "الأخبار", ja: "ニュース" },
  company: { en: "Company", tr: "Şirket", de: "Unternehmen", fr: "Entreprise", es: "Empresa", it: "Azienda", ar: "الشركة", ja: "会社情報" },
  contact: { en: "Contact", tr: "İletişim", de: "Kontakt", fr: "Contact", es: "Contacto", it: "Contatti", ar: "اتصل بنا", ja: "お問い合わせ" },
  language: { en: "Language", tr: "Dil", de: "Sprache", fr: "Langue", es: "Idioma", it: "Lingua", ar: "اللغة", ja: "言語" },
  openMenu: { en: "Open menu", tr: "Menüyü aç", de: "Menü öffnen", fr: "Ouvrir le menu", es: "Abrir menú", it: "Apri menu", ar: "افتح القائمة", ja: "メニューを開く" },
  mainNavigation: { en: "Main navigation", tr: "Ana gezinme", de: "Hauptnavigation", fr: "Navigation principale", es: "Navegación principal", it: "Navigazione principale", ar: "التنقل الرئيسي", ja: "メインナビゲーション" },
};
const ctaLabels: Record<string, string> = {
  en: "Start Project",
  tr: "Projeyi Başlat",
  de: "Projekt starten",
  fr: "Démarrer le projet",
  es: "Iniciar proyecto",
  it: "Avvia progetto",
  ar: "بدء المشروع",
  ja: "プロジェクト相談",
};

const getLabel = (key: keyof typeof navLabels) => navLabels[key][locale] || navLabels[key].en;
const links = [
  { name: getLabel("home"), href: `/${locale}`, accent: "nav-accent-cyan" },
  { name: getLabel("solutions"), href: `/${locale}/solutions`, accent: "nav-accent-green" },
  { name: getLabel("services"), href: `/${locale}/services`, accent: "nav-accent-cyan" },
  { name: getLabel("products"), href: `/${locale}/products`, accent: "nav-accent-cyan" },
  { name: getLabel("news"), href: `/${locale}/news`, accent: "nav-accent-amber" },
  { name: getLabel("company"), href: `/${locale}/company`, accent: "nav-accent-warm" },
  { name: getLabel("contact"), href: `/${locale}/contact`, accent: "nav-accent-green" },
];

function isActive(href: string) {
  if (href === `/${locale}`) return currentPath === href || currentPath === `/${locale}/`;
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <nav class="nav" aria-label={getLabel("mainNavigation")}>
    <a href={`/${locale}`} class="brand">
      <span class="brand-mark" aria-hidden="true">
        <img src={`${import.meta.env.BASE_URL}assets/willow-mark-transparent.png`} alt="" decoding="async" />
      </span>
      <span>
        <strong>WILLOWSOFT</strong>
        <span>Smart Embedded Connectivity</span>
      </span>
    </a>

    <div class="nav-links" id="nav-links">
      {links.map((link) => (
        <a
          href={link.href}
          class={link.accent}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.name}
        </a>
      ))}
      <a href={`/${locale}/start-project`} class="mobile-cta">{ctaLabels[locale] || ctaLabels.en}</a>
    </div>

    <div class="nav-actions">
      <label class="language-switcher" data-language-switcher>
        <span class="sr-only">{getLabel("language")}</span>
        <select aria-label={getLabel("language")} id="locale-select">
          {locales.map((loc) => (
            <option value={loc} selected={loc === locale}>{labels[loc]}</option>
          ))}
        </select>
      </label>

      <a href={`/${locale}/start-project`} class="btn btn-primary btn-small">{ctaLabels[locale] || ctaLabels.en}</a>
      <button class="menu-toggle" aria-expanded="false" aria-label={getLabel("openMenu")} id="menu-toggle">☰</button>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const navLinks = document.getElementById("nav-links");
  toggle?.addEventListener("click", () => {
    const open = navLinks?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
  });

  const select = document.getElementById("locale-select") as HTMLSelectElement | null;
  select?.addEventListener("change", (e) => {
    const nextLocale = (e.target as HTMLSelectElement).value;
    const parts = window.location.pathname.split("/").filter(Boolean);
    const locales = ["en", "tr", "de", "fr", "es", "it", "ar", "ja"];
    if (locales.includes(parts[0])) parts[0] = nextLocale;
    else parts.unshift(nextLocale);
    window.location.href = "/" + parts.join("/") + window.location.search + window.location.hash;
  });
</script>

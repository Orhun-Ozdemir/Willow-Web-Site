---
import { localizeItem, resolveLocale, type Locale } from "@/lib/cms";

interface Props {
  item: any;
  locale: Locale;
  index: number;
  variant?: "default" | "compact";
}

const { item, index, variant = "default" } = Astro.props;
const locale = resolveLocale(Astro.props.locale, Astro.url.pathname);
const n = localizeItem(item, locale);
const delay = index % 3 ? ` delay-${index % 3}` : "";
const basePath = import.meta.env.BASE_URL || "/";
const date = n.date
  ? new Date(`${n.date}T00:00:00`).toLocaleDateString(locale, { year: "numeric", month: "short", day: "numeric" })
  : "";
const timestamp = n.date ? new Date(`${n.date}T00:00:00`).getTime() || 0 : 0;
const rawCategory = n.category || "News";
const categoryKey = String(rawCategory).trim().toLowerCase();
const categoryLabels: Record<string, Record<string, string>> = {
  proof: { en: "Field signal", tr: "Saha sinyali", de: "Feldsignal", fr: "Signal terrain", es: "Señal de campo", it: "Segnale sul campo", ar: "إشارة ميدانية", ja: "現場シグナル" },
  tracking: { en: "Field update", tr: "Saha güncellemesi", de: "Feld-Update", fr: "Mise à jour terrain", es: "Actualización de campo", it: "Aggiornamento sul campo", ar: "تحديث ميداني", ja: "現場アップデート" },
  "field-update": { en: "Field update", tr: "Saha güncellemesi", de: "Feld-Update", fr: "Mise à jour terrain", es: "Actualización de campo", it: "Aggiornamento sul campo", ar: "تحديث ميداني", ja: "現場アップデート" },
  "export": { en: "Export", tr: "İhracat", de: "Export", fr: "Export", es: "Exportación", it: "Export", ar: "تصدير", ja: "輸出" },
  event: { en: "Event", tr: "Etkinlik", de: "Event", fr: "Événement", es: "Evento", it: "Evento", ar: "فعالية", ja: "イベント" },
  company: { en: "Company", tr: "Şirket", de: "Unternehmen", fr: "Entreprise", es: "Empresa", it: "Azienda", ar: "الشركة", ja: "会社" },
  workshop: { en: "Workshop", tr: "Atölye", de: "Workshop", fr: "Atelier", es: "Workshop", it: "Workshop", ar: "ورشة عمل", ja: "ワークショップ" },
  update: { en: "Update", tr: "Güncelleme", de: "Update", fr: "Mise à jour", es: "Actualización", it: "Aggiornamento", ar: "تحديث", ja: "更新" },
};
const category = categoryLabels[categoryKey]?.[locale] || categoryLabels[categoryKey]?.en || rawCategory;
const slug = encodeURIComponent(n.slug || n.id || "");
const rawGalleryImage = Array.isArray(n.images) ? n.images.find((src: any) => typeof src === "string" && src.trim()) : "";
const rawImage = typeof n.image === "string" && n.image.trim() ? n.image : rawGalleryImage || "";
const imageSrc = rawImage
  ? rawImage.startsWith("http") || rawImage.startsWith("data:")
    ? rawImage
    : `${basePath}${rawImage.replace(/^\/+/, "")}`.replace(/([^:]\/)\/+/g, "$1")
  : "";
const searchable = [n.title, rawCategory, category, n.excerpt].filter(Boolean).join(" ").toLowerCase();
const readLabel: Record<string, string> = {
  en: "Read Update",
  tr: "Haberi Oku",
  de: "Update lesen",
  fr: "Lire la mise à jour",
  es: "Leer actualización",
  it: "Leggi l'aggiornamento",
  ar: "اقرأ التحديث",
  ja: "更新を見る",
};
const featuredLabel: Record<string, string> = {
  en: "Featured update",
  tr: "Öne çıkan haber",
  de: "Ausgewähltes Update",
  fr: "Actualité à la une",
  es: "Actualización destacada",
  it: "Aggiornamento in evidenza",
  ar: "تحديث مميز",
  ja: "注目の更新",
};
const dateLabel: Record<string, string> = {
  en: "Date",
  tr: "Tarih",
  de: "Datum",
  fr: "Date",
  es: "Fecha",
  it: "Data",
  ar: "التاريخ",
  ja: "日付",
};
---

<article
  class={`card news-card news-card-${variant} reveal${delay}`}
  data-news-card
  data-news-search={searchable}
  data-news-category={categoryKey}
  data-news-date={timestamp}
  data-news-title={String(n.title || "").toLowerCase()}
>
  <figure class={!imageSrc ? "is-empty" : ""}>
    {imageSrc ? (
      <img
        src={imageSrc}
        alt={n.title}
        loading="lazy"
        decoding="async"
        onerror="this.closest('figure').classList.add('is-empty'); this.remove();"
      />
    ) : (
      <span class="news-card-placeholder">WillowSoft</span>
    )}
  </figure>
  <div class="product-body">
    <div class="news-card-meta">
      <span class="news-badge">{category}</span>
    </div>
    {n.featured && <span class="news-featured-pill">{featuredLabel[locale] || featuredLabel.en}</span>}
    <h3>{n.title}</h3>
    <p>{n.excerpt}</p>
    <p class="news-card-action">
      <a href={`/${locale}/news/${slug}`} class="btn btn-ghost btn-small">
        {readLabel[locale] || readLabel.en}
      </a>
    </p>
    <div class="news-card-footer">
      <span>{dateLabel[locale] || dateLabel.en}</span>
      {date ? <time datetime={n.date}>{date}</time> : <strong>-</strong>}
    </div>
  </div>
</article>

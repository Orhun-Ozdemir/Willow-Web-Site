---
import type { Locale } from "@/lib/cms";
import { ANALYTICS_CONSENT_COOKIE, ANALYTICS_CONSENT_VERSION } from "@/lib/analytics";

interface Props { locale: Locale }

const { locale } = Astro.props;
const choice = Astro.cookies.get(ANALYTICS_CONSENT_COOKIE)?.value || "";
const hasChoice = choice === `granted:${ANALYTICS_CONSENT_VERSION}` || choice === `denied:${ANALYTICS_CONSENT_VERSION}`;

const copy: Record<Locale, { title: string; body: string; accept: string; reject: string; preferences: string; privacy: string }> = {
  en: { title: "Your privacy, your choice", body: "We respect your privacy. This site uses cookies for analytics and marketing. Please choose whether to allow non-essential cookies or customize your settings.", accept: "Allow", reject: "Decline", preferences: "Cookie preferences", privacy: "Privacy notice" },
  tr: { title: "Gizliliğiniz, sizin tercihiniz", body: "Gizliliğinize saygı duyuyoruz. Bu site analiz ve pazarlama amacıyla çerezler kullanır. Zorunlu olmayan çerezlere izin verebilir veya tercihlerinizi özelleştirebilirsiniz.", accept: "İzin ver", reject: "Reddet", preferences: "Çerez tercihleri", privacy: "Gizlilik bildirimi" },
  de: { title: "Ihre Privatsphäre, Ihre Wahl", body: "Wir respektieren Ihre Privatsphäre. Diese Website verwendet Cookies für Analyse und Marketing. Entscheiden Sie, ob Sie nicht notwendige Cookies zulassen oder Ihre Einstellungen anpassen möchten.", accept: "Analyse zulassen", reject: "Nur notwendige", preferences: "Cookie-Einstellungen", privacy: "Datenschutzhinweis" },
  fr: { title: "Votre vie privée, votre choix", body: "Nous respectons votre vie privée. Ce site utilise des cookies à des fins d’analyse et de marketing. Choisissez d’autoriser les cookies non essentiels ou de personnaliser vos préférences.", accept: "Autoriser l’analyse", reject: "Nécessaires uniquement", preferences: "Préférences cookies", privacy: "Avis de confidentialité" },
  es: { title: "Tu privacidad, tu elección", body: "Respetamos tu privacidad. Este sitio utiliza cookies para análisis y marketing. Elige si deseas permitir las cookies no esenciales o personalizar tus preferencias.", accept: "Permitir analítica", reject: "Solo necesarias", preferences: "Preferencias de cookies", privacy: "Aviso de privacidad" },
  it: { title: "La tua privacy, la tua scelta", body: "Rispettiamo la tua privacy. Questo sito utilizza cookie per analisi e marketing. Scegli se consentire i cookie non essenziali o personalizzare le tue preferenze.", accept: "Consenti analisi", reject: "Solo necessari", preferences: "Preferenze cookie", privacy: "Informativa privacy" },
  ar: { title: "خصوصيتك، اختيارك", body: "نحن نحترم خصوصيتك. يستخدم هذا الموقع ملفات تعريف الارتباط للتحليلات والتسويق. اختر السماح بالملفات غير الضرورية أو تخصيص تفضيلاتك.", accept: "السماح بالتحليلات", reject: "الضرورية فقط", preferences: "تفضيلات ملفات الارتباط", privacy: "إشعار الخصوصية" },
  ja: { title: "プライバシーはあなたの選択です", body: "お客様のプライバシーを尊重します。本サイトは分析とマーケティングにCookieを使用します。必須ではないCookieを許可するか、設定を変更してください。", accept: "分析を許可", reject: "必須のみ", preferences: "Cookie設定", privacy: "プライバシー通知" },
};

const text = copy[locale] || copy.en;
const settingsCopy: Record<Locale, { customize: string; save: string; necessary: string; necessaryDesc: string; analytics: string; analyticsDesc: string; always: string }> = {
  en: { customize: "Customize", save: "Save preferences", necessary: "Necessary", necessaryDesc: "Security, language and consent preferences.", analytics: "Analytics & marketing", analyticsDesc: "Anonymous visits, product interest and live chat.", always: "Always active" },
  tr: { customize: "Özelleştir", save: "Tercihleri kaydet", necessary: "Zorunlu", necessaryDesc: "Güvenlik, dil ve izin tercihleri.", analytics: "Analiz ve pazarlama", analyticsDesc: "Anonim ziyaretler, ürün ilgisi ve canlı destek.", always: "Her zaman aktif" },
  de: { customize: "Anpassen", save: "Auswahl speichern", necessary: "Notwendig", necessaryDesc: "Sicherheit, Sprache und Einwilligung.", analytics: "Analyse & Marketing", analyticsDesc: "Anonyme Besuche, Produktinteresse und Live-Chat.", always: "Immer aktiv" },
  fr: { customize: "Personnaliser", save: "Enregistrer", necessary: "Nécessaires", necessaryDesc: "Sécurité, langue et préférences de consentement.", analytics: "Analyse et marketing", analyticsDesc: "Visites anonymes, intérêt produit et chat en direct.", always: "Toujours actifs" },
  es: { customize: "Personalizar", save: "Guardar preferencias", necessary: "Necesarias", necessaryDesc: "Seguridad, idioma y preferencias de consentimiento.", analytics: "Analítica y marketing", analyticsDesc: "Visitas anónimas, interés en productos y chat en vivo.", always: "Siempre activas" },
  it: { customize: "Personalizza", save: "Salva preferenze", necessary: "Necessari", necessaryDesc: "Sicurezza, lingua e preferenze di consenso.", analytics: "Analisi e marketing", analyticsDesc: "Visite anonime, interesse prodotti e live chat.", always: "Sempre attivi" },
  ar: { customize: "تخصيص", save: "حفظ التفضيلات", necessary: "ضرورية", necessaryDesc: "الأمان واللغة وتفضيلات الموافقة.", analytics: "التحليلات والتسويق", analyticsDesc: "زيارات مجهولة واهتمام المنتجات والدردشة المباشرة.", always: "نشطة دائماً" },
  ja: { customize: "カスタマイズ", save: "設定を保存", necessary: "必須", necessaryDesc: "セキュリティ、言語、同意設定。", analytics: "分析とマーケティング", analyticsDesc: "匿名訪問、製品関心、ライブチャット。", always: "常に有効" },
};
const settingsText = settingsCopy[locale] || settingsCopy.en;
---

<aside id="willow-consent" class:list={["willow-consent", { "is-hidden": hasChoice }]} aria-labelledby="willow-consent-title" aria-live="polite">
  <div class="willow-consent-mark" aria-hidden="true">
    <span class="willow-cookie-icon"><i></i><i></i><i></i></span>
  </div>
  <div class="willow-consent-copy">
    <strong id="willow-consent-title">{text.title}</strong>
    <p>{text.body}</p>
    <a href={`/${locale}/privacy`}>{text.privacy}</a>
  </div>
  <div class="willow-consent-actions">
    <button type="button" class="willow-consent-accept" data-consent-choice="true">{text.accept}</button>
    <button type="button" class="willow-consent-reject" data-consent-choice="false">{text.reject}</button>
  </div>
  <div class="willow-consent-settings" data-consent-settings hidden>
    <div class="willow-consent-setting-row">
      <div>
        <strong>{settingsText.necessary}</strong>
        <span>{settingsText.necessaryDesc}</span>
      </div>
      <em>{settingsText.always}</em>
    </div>
    <label class="willow-consent-setting-row" for="willow-analytics-toggle">
      <div>
        <strong>{settingsText.analytics}</strong>
        <span>{settingsText.analyticsDesc}</span>
      </div>
      <input id="willow-analytics-toggle" type="checkbox" data-analytics-toggle />
      <i aria-hidden="true"></i>
    </label>
    <button type="button" class="willow-consent-save" data-consent-save>{settingsText.save}</button>
  </div>
</aside>

<script is:inline define:vars={{ consentVersion: ANALYTICS_CONSENT_VERSION }}>
  (function () {
    var banner = document.getElementById("willow-consent");
    if (!banner || banner.dataset.bound === "1") return;
    banner.dataset.bound = "1";
    var settingsPanel = banner.querySelector("[data-consent-settings]");
    var analyticsToggle = banner.querySelector("[data-analytics-toggle]");
    var customizeButton = banner.querySelector("[data-consent-customize]");
    var saveButton = banner.querySelector("[data-consent-save]");

    function clearAnalyticsStorage() {
      try {
        localStorage.removeItem("willow_analytics_attribution");
        sessionStorage.removeItem("willow_analytics_started_forms");
      } catch {}
    }

    async function saveChoice(granted) {
      banner.classList.add("is-saving");
      try {
        var response = await fetch("/api/analytics/consent", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ granted: granted }),
        });
        if (!response.ok) throw new Error("Consent could not be saved");
        if (!granted) clearAnalyticsStorage();
        banner.classList.add("is-hidden");
        banner.classList.remove("is-customizing");
        if (settingsPanel) settingsPanel.hidden = true;
        window.dispatchEvent(new CustomEvent("willow:analytics-consent", { detail: { granted: granted, version: consentVersion } }));
      } catch {
        banner.classList.remove("is-hidden");
      } finally {
        banner.classList.remove("is-saving");
      }
    }

    banner.querySelectorAll("[data-consent-choice]").forEach(function (button) {
      button.addEventListener("click", function () {
        saveChoice(button.getAttribute("data-consent-choice") === "true");
      });
    });

    function openPreferences(showDetails) {
      banner.classList.remove("is-hidden");
      if (analyticsToggle) analyticsToggle.checked = document.cookie.indexOf("willow_analytics_consent=granted%3A1") !== -1 || document.cookie.indexOf("willow_analytics_consent=granted:1") !== -1;
      if (settingsPanel) settingsPanel.hidden = !showDetails;
      banner.classList.toggle("is-customizing", !!showDetails);
      var focusTarget = showDetails ? analyticsToggle : banner.querySelector(".willow-consent-accept");
      if (focusTarget) focusTarget.focus();
    }

    if (customizeButton) customizeButton.addEventListener("click", function () { openPreferences(true); });
    if (saveButton) saveButton.addEventListener("click", function () { saveChoice(!!(analyticsToggle && analyticsToggle.checked)); });
    document.querySelectorAll("[data-cookie-settings]").forEach(function (button) {
      button.addEventListener("click", function () { openPreferences(true); });
    });
  })();
</script>

<script is:inline define:vars={{ consentVersion: ANALYTICS_CONSENT_VERSION }}>
  (function () {
    if (window.__willowAnalyticsLoaded) return;
    window.__willowAnalyticsLoaded = true;

    var activeStartedAt = document.visibilityState === "visible" ? Date.now() : 0;
    var unsentActiveMs = 0;
    var maxScroll = 0;
    var sentScroll = {};
    var pageViewSent = false;
    var attributionKey = "willow_analytics_attribution";

    function readConsent() {
      var match = document.cookie.match(/(?:^|;\s*)willow_analytics_consent=([^;]+)/);
      return match ? decodeURIComponent(match[1]) : "";
    }

    function isGranted() {
      return readConsent() === "granted:" + consentVersion;
    }

    function locale() {
      return document.documentElement.lang || "en";
    }

    function getAttribution() {
      if (!isGranted()) return {};
      var now = Date.now();
      var current = {};
      try {
        current = JSON.parse(localStorage.getItem(attributionKey) || "{}");
      } catch {}
      if (!current.createdAt || now - current.createdAt > 90 * 86400000) current = {};

      var params = new URLSearchParams(location.search);
      var hasCampaign = ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content"].some(function (key) { return params.has(key); });
      if (!current.createdAt || hasCampaign) {
        current = {
          createdAt: now,
          landingPage: location.pathname,
          utmSource: (params.get("utm_source") || "").slice(0, 160),
          utmMedium: (params.get("utm_medium") || "").slice(0, 160),
          utmCampaign: (params.get("utm_campaign") || "").slice(0, 200),
          utmTerm: (params.get("utm_term") || "").slice(0, 200),
          utmContent: (params.get("utm_content") || "").slice(0, 200),
        };
        try { localStorage.setItem(attributionKey, JSON.stringify(current)); } catch {}
      }
      return current;
    }

    function payload(eventType, options) {
      options = options || {};
      return {
        eventType: eventType,
        path: location.pathname + location.search,
        title: document.title,
        locale: locale(),
        referrer: document.referrer,
        language: navigator.language || "",
        timezone: (Intl.DateTimeFormat().resolvedOptions().timeZone || ""),
        viewport: { width: window.innerWidth || 0, height: window.innerHeight || 0 },
        durationMs: options.durationMs || 0,
        metadata: options.metadata || null,
        attribution: getAttribution(),
      };
    }

    function track(eventType, options) {
      if (!isGranted()) return false;
      var body = JSON.stringify(payload(eventType, options));
      if (options && options.beacon && navigator.sendBeacon) {
        return navigator.sendBeacon("/api/events", new Blob([body], { type: "application/json" }));
      }
      fetch("/api/events", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        keepalive: true,
        body: body,
      }).catch(function () {});
      return true;
    }

    window.willowTrack = track;

    function sendPageView() {
      if (pageViewSent || !isGranted()) return;
      pageViewSent = true;
      activeStartedAt = document.visibilityState === "visible" ? Date.now() : 0;
      unsentActiveMs = 0;
      track("page_view");
      var productMatch = location.pathname.match(/\/(?:en|tr|de|fr|es|it|ar|ja)\/products\/([^/?#]+)/);
      if (productMatch) track("product_view", { metadata: { productSlug: decodeURIComponent(productMatch[1]) } });
    }

    function captureActiveTime() {
      if (!activeStartedAt) return;
      unsentActiveMs += Math.max(0, Date.now() - activeStartedAt);
      activeStartedAt = 0;
    }

    function sendEngagement() {
      captureActiveTime();
      if (!pageViewSent || !isGranted() || unsentActiveMs <= 0) return;
      var durationMs = unsentActiveMs;
      unsentActiveMs = 0;
      track("page_engagement", {
        beacon: true,
        durationMs: durationMs,
        metadata: { scrollDepth: maxScroll },
      });
    }

    function elementLabel(element) {
      return String(element.getAttribute("aria-label") || element.textContent || "").replace(/\s+/g, " ").trim().slice(0, 120);
    }

    document.addEventListener("click", function (event) {
      if (!isGranted()) return;
      var target = event.target instanceof Element ? event.target.closest("a,button,[data-analytics-event]") : null;
      if (!target || target.closest("#willow-consent") || target.closest("[data-cookie-settings]")) return;
      var custom = target.getAttribute("data-analytics-event");
      var href = target instanceof HTMLAnchorElement ? target.href : "";
      var rawHref = target instanceof HTMLAnchorElement ? (target.getAttribute("href") || "") : "";
      var eventType = custom || "cta_click";

      if (rawHref.startsWith("mailto:")) eventType = "email_click";
      else if (rawHref.startsWith("tel:")) eventType = "phone_click";
      else if (/wa\.me|whatsapp/i.test(href)) eventType = "whatsapp_click";
      else if (target.hasAttribute("download") || /\.(pdf|docx?|xlsx?|zip)(?:$|\?)/i.test(href)) eventType = "document_download";
      else if (/\/(?:en|tr|de|fr|es|it|ar|ja)\/products\/[^/]+/.test(new URL(href || location.href, location.href).pathname)) eventType = "product_card_click";
      else if (href && new URL(href, location.href).origin !== location.origin) eventType = "outbound_click";
      else if (target.closest("nav,header")) eventType = "nav_click";

      track(eventType, { metadata: {
        label: elementLabel(target),
        section: target.closest("section")?.id || target.closest("section")?.getAttribute("data-section") || "",
        href: rawHref.slice(0, 300),
      } });
    }, { passive: true });

    document.addEventListener("change", function (event) {
      var target = event.target;
      if (target instanceof HTMLSelectElement && target.id === "locale-select") {
        track("language_switch", { metadata: { label: target.value } });
      }
    });

    document.addEventListener("focusin", function (event) {
      if (!isGranted()) return;
      var form = event.target instanceof Element ? event.target.closest("form") : null;
      if (!form || form.dataset.analyticsStarted === "1") return;
      form.dataset.analyticsStarted = "1";
      var isProject = form.id === "start-project-form";
      track(isProject ? "start_project_form_start" : "contact_form_start", { metadata: { formId: form.id || "form" } });
    });

    window.addEventListener("scroll", function () {
      var total = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
      maxScroll = Math.max(maxScroll, Math.min(100, Math.round((window.scrollY / total) * 100)));
      [25, 50, 75, 90].forEach(function (milestone) {
        if (maxScroll >= milestone && !sentScroll[milestone]) {
          sentScroll[milestone] = true;
          track("scroll_depth", { metadata: { scrollDepth: milestone } });
        }
      });
    }, { passive: true });

    window.addEventListener("pagehide", sendEngagement);
    document.addEventListener("visibilitychange", function () {
      if (document.visibilityState === "hidden") sendEngagement();
      else if (isGranted() && !activeStartedAt) activeStartedAt = Date.now();
    });
    window.addEventListener("willow:analytics-consent", function (event) {
      if (event.detail && event.detail.granted) sendPageView();
      else {
        pageViewSent = false;
        activeStartedAt = 0;
        unsentActiveMs = 0;
      }
    });

    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", sendPageView, { once: true });
    else sendPageView();
  })();
</script>

<style>
  .willow-consent {
    position: fixed;
    z-index: 10050;
    right: 50%;
    bottom: 16px;
    left: auto;
    width: min(780px, calc(100vw - 32px));
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr) auto;
    align-items: center;
    gap: 14px;
    padding: 13px 16px;
    color: #f4f5f7;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 16px;
    background: rgba(45, 49, 70, 0.97);
    box-shadow: 0 18px 50px rgba(14, 17, 29, 0.28);
    backdrop-filter: blur(20px) saturate(120%);
    transform: translateX(50%);
    animation: willow-consent-enter 360ms cubic-bezier(0.16, 1, 0.3, 1) both;
    transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;
  }
  .willow-consent.is-hidden { opacity: 0; visibility: hidden; transform: translate(50%, 14px); pointer-events: none; }
  .willow-consent.is-customizing { width: min(820px, calc(100vw - 32px)); }
  .willow-consent.is-saving { opacity: 0.72; pointer-events: none; }
  .willow-consent-mark { width: 36px; height: 36px; display: grid; place-items: center; border-radius: 50%; background: rgba(19, 23, 42, 0.3); border: 1px solid rgba(255, 255, 255, 0.06); }
  .willow-cookie-icon { position: relative; width: 18px; height: 18px; display: block; border-radius: 50%; background: #f1f0eb; box-shadow: inset -2px -2px 0 rgba(0, 0, 0, 0.08); }
  .willow-cookie-icon::after { content: ""; position: absolute; right: -2px; top: -2px; width: 9px; height: 9px; border-radius: 50%; background: #252a42; box-shadow: -3px 7px 0 -1px #252a42; }
  .willow-cookie-icon i { position: absolute; width: 3px; height: 3px; border-radius: 50%; background: #363c59; }
  .willow-cookie-icon i:nth-child(1) { left: 5px; top: 5px; }
  .willow-cookie-icon i:nth-child(2) { left: 11px; top: 11px; }
  .willow-cookie-icon i:nth-child(3) { left: 5px; top: 14px; }
  .willow-consent-copy > strong { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  .willow-consent-copy p { max-width: 480px; margin: 0; color: #f4f3ef; font-size: 12.5px; font-weight: 500; line-height: 1.42; letter-spacing: -0.01em; }
  .willow-consent-copy a { display: inline-block; margin-top: 2px; color: rgba(244, 243, 239, 0.62); font-size: 9px; font-weight: 700; text-decoration: none; }
  .willow-consent-copy a:hover { text-decoration: underline; }
  .willow-consent-actions { display: flex; gap: 10px; }
  .willow-consent-actions button { min-width: 94px; min-height: 40px; padding: 0 16px; border: 1px solid rgba(255, 255, 255, 0.22); border-radius: 13px; cursor: pointer; color: #f4f3ef; background: transparent; font: inherit; font-size: 12px; font-weight: 600; white-space: nowrap; transition: color 160ms ease, background 160ms ease, border-color 160ms ease; }
  .willow-consent-actions button:hover { color: #252a42; background: #f1f0eb; border-color: #f1f0eb; }
  .willow-consent-settings { grid-column: 1 / -1; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto; align-items: center; gap: 20px; padding-top: 10px; border-top: 1px solid rgba(255, 255, 255, 0.1); }
  .willow-consent-settings[hidden] { display: none; }
  .willow-consent-setting-row { position: relative; display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 9px 2px; color: #f1f2f4; }
  .willow-consent-setting-row + .willow-consent-setting-row { border-top: 0; }
  .willow-consent-setting-row div { min-width: 0; }
  .willow-consent-setting-row strong { display: block; font-size: 11px; }
  .willow-consent-setting-row span { display: block; margin-top: 2px; color: rgba(241, 242, 244, 0.56); font-size: 9.5px; }
  .willow-consent-setting-row em { color: #cfd2d8; font-size: 9px; font-style: normal; font-weight: 900; white-space: nowrap; }
  .willow-consent-setting-row input { position: absolute; opacity: 0; pointer-events: none; }
  .willow-consent-setting-row > i { position: relative; width: 34px; height: 19px; flex: 0 0 auto; border-radius: 999px; background: #696d75; cursor: pointer; transition: background 160ms ease; }
  .willow-consent-setting-row > i::after { content: ""; position: absolute; top: 3px; left: 3px; width: 13px; height: 13px; border-radius: 50%; background: white; box-shadow: 0 1px 4px rgba(0,0,0,.18); transition: transform 160ms ease; }
  .willow-consent-setting-row input:checked + i { background: #aeb5c7; }
  .willow-consent-setting-row input:checked + i::after { transform: translateX(15px); }
  .willow-consent-setting-row input:focus-visible + i { outline: 2px solid #4c65b8; outline-offset: 2px; }
  .willow-consent-save { min-width: 142px; min-height: 34px; margin: 0; padding: 0 14px; border: 0; border-radius: 8px; color: #25272c; background: #f3f4f6; font: inherit; font-size: 10px; font-weight: 900; cursor: pointer; }
  :global(.footer-cookie-settings) { padding: 0; border: 0; color: inherit; background: transparent; font: inherit; text-align: start; cursor: pointer; }
  :global(.footer-cookie-settings:hover) { color: white; }
  @keyframes willow-consent-enter {
    from { opacity: 0; transform: translate(50%, 24px); }
    to { opacity: 1; transform: translate(50%, 0); }
  }
  :global(body:has(.willow-consent:not(.is-hidden)) .whatsapp-float) { bottom: 7.2rem; }
  :global(body:has(.willow-consent.is-customizing:not(.is-hidden)) .whatsapp-float) { bottom: 12rem; }
  @media (max-width: 720px) {
    .willow-consent { right: 12px; bottom: 12px; left: 12px; width: auto; grid-template-columns: 34px minmax(0, 1fr); gap: 11px; padding: 16px; border-radius: 18px; transform: none; }
    .willow-consent.is-hidden { transform: translateY(14px); }
    .willow-consent.is-customizing { width: auto; }
    .willow-consent-mark { width: 34px; height: 34px; }
    .willow-cookie-icon { transform: scale(.86); }
    .willow-consent-actions { grid-column: 1 / -1; }
    .willow-consent-copy p { font-size: 12px; }

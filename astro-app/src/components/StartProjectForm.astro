  { value: "Idea / early planning", label: { en: "Idea / early planning", tr: "Fikir / erken planlama", de: "Idee / frühe Planung", fr: "Idée / planification initiale", es: "Idea / planificación inicial", it: "Idea / pianificazione iniziale", ar: "فكرة / تخطيط مبكر", ja: "アイデア段階 / 初期計画" } },
  { value: "Prototype exists", label: { en: "Prototype exists", tr: "Prototip mevcut", de: "Prototyp vorhanden", fr: "Prototype existant", es: "Prototipo existente", it: "Prototipo esistente", ar: "يوجد نموذج أولي", ja: "プロトタイプあり" } },
  { value: "Hardware exists, software needed", label: { en: "Hardware exists, software needed", tr: "Donanım var, yazılım gerekiyor", de: "Hardware vorhanden, Software benötigt", fr: "Matériel existant, logiciel à développer", es: "Hardware existente, falta software", it: "Hardware esistente, serve software", ar: "الأجهزة موجودة، البرمجيات مطلوبة", ja: "ハードあり・ソフトウェアが必要" } },
  { value: "Software exists, hardware needed", label: { en: "Software exists, hardware needed", tr: "Yazılım var, donanım gerekiyor", de: "Software vorhanden, Hardware benötigt", fr: "Logiciel existant, matériel à développer", es: "Software existente, falta hardware", it: "Software esistente, serve hardware", ar: "البرمجيات موجودة، الأجهزة مطلوبة", ja: "ソフトあり・ハードウェアが必要" } },
  { value: "Existing system needs rebuild", label: { en: "Existing system needs rebuild", tr: "Mevcut sistem yeniden kurulmalı", de: "Bestehendes System muss neu aufgebaut werden", fr: "Système existant à reconstruire", es: "El sistema actual debe reconstruirse", it: "Sistema esistente da ricostruire", ar: "النظام الحالي يحتاج إعادة بناء", ja: "既存システムの再構築が必要" } },
  { value: "Ready for production support", label: { en: "Ready for production support", tr: "Üretim desteğine hazır", de: "Bereit für Produktionsunterstützung", fr: "Prêt pour le support en production", es: "Listo para soporte de producción", it: "Pronto per il supporto in produzione", ar: "جاهز لدعم الإنتاج", ja: "量産サポートの準備完了" } },
];

const layerOptions = [
  { value: "hardware", label: { en: "Hardware", tr: "Donanım", de: "Hardware", fr: "Matériel", es: "Hardware", it: "Hardware", ar: "الأجهزة", ja: "ハードウェア" } },
  { value: "firmware", label: { en: "Firmware", tr: "Firmware", de: "Firmware", fr: "Firmware", es: "Firmware", it: "Firmware", ar: "البرنامج الثابت", ja: "ファームウェア" } },
  { value: "backend", label: { en: "Backend API", tr: "Backend API", de: "Backend-API", fr: "API backend", es: "API backend", it: "API backend", ar: "واجهة برمجة الخلفية", ja: "バックエンド API" } },
  { value: "postgresql", label: { en: "PostgreSQL", tr: "PostgreSQL", de: "PostgreSQL", fr: "PostgreSQL", es: "PostgreSQL", it: "PostgreSQL", ar: "PostgreSQL", ja: "PostgreSQL" } },
  { value: "web-admin", label: { en: "Web/Admin", tr: "Web / yönetim paneli", de: "Web/Admin", fr: "Web/Admin", es: "Web/Admin", it: "Web/Admin", ar: "ويب / إدارة", ja: "Web/管理画面" } },
  { value: "mobile", label: { en: "Mobile", tr: "Mobil", de: "Mobil", fr: "Mobile", es: "Móvil", it: "Mobile", ar: "جوال", ja: "モバイル" } },
  { value: "website", label: { en: "Website", tr: "Web sitesi", de: "Website", fr: "Site web", es: "Sitio web", it: "Sito web", ar: "موقع ويب", ja: "Webサイト" } },
  { value: "vr", label: { en: "VR / Simulation", tr: "VR / simülasyon", de: "VR / Simulation", fr: "VR / simulation", es: "VR / simulación", it: "VR / simulazione", ar: "VR / محاكاة", ja: "VR / シミュレーション" } },
];

const timelineOptions = [
  { value: "Exploring options", label: { en: "Exploring options", tr: "Seçenekleri araştırıyoruz", de: "Optionen prüfen", fr: "Exploration des options", es: "Explorando opciones", it: "Valutazione opzioni", ar: "استكشاف الخيارات", ja: "選択肢を検討中" } },
  { value: "0-3 months", label: { en: "0-3 months", tr: "0-3 ay", de: "0-3 Monate", fr: "0-3 mois", es: "0-3 meses", it: "0-3 mesi", ar: "0-3 أشهر", ja: "0〜3か月" } },
  { value: "3-6 months", label: { en: "3-6 months", tr: "3-6 ay", de: "3-6 Monate", fr: "3-6 mois", es: "3-6 meses", it: "3-6 mesi", ar: "3-6 أشهر", ja: "3〜6か月" } },
  { value: "6+ months", label: { en: "6+ months", tr: "6+ ay", de: "6+ Monate", fr: "6+ mois", es: "6+ meses", it: "6+ mesi", ar: "أكثر من 6 أشهر", ja: "6か月以上" } },
  { value: "Urgent rescue project", label: { en: "Urgent rescue project", tr: "Acil kurtarma projesi", de: "Dringendes Rettungsprojekt", fr: "Projet de secours urgent", es: "Proyecto de rescate urgente", it: "Progetto di salvataggio urgente", ar: "مشروع إنقاذ عاجل", ja: "緊急対応プロジェクト" } },
];

const budgetOptions = [
  { value: "Not sure yet", label: { en: "Not sure yet", tr: "Henüz emin değilim", de: "Noch unsicher", fr: "Pas encore sûr", es: "Aún no estoy seguro", it: "Non ancora sicuro", ar: "غير متأكد بعد", ja: "まだ未定" } },
  { value: "Under $10k", label: { en: "Under $10k", tr: "$10k altı", de: "Unter 10.000 $", fr: "Moins de 10 000 $", es: "Menos de 10.000 $", it: "Sotto 10.000 $", ar: "أقل من 10 آلاف دولار", ja: "1万ドル未満" } },
  { value: "$10k - $25k", label: { en: "$10k - $25k", tr: "$10k - $25k", de: "10.000 - 25.000 $", fr: "10 000 - 25 000 $", es: "10.000 - 25.000 $", it: "10.000 - 25.000 $", ar: "10-25 ألف دولار", ja: "1万〜2.5万ドル" } },
  { value: "$25k - $75k", label: { en: "$25k - $75k", tr: "$25k - $75k", de: "25.000 - 75.000 $", fr: "25 000 - 75 000 $", es: "25.000 - 75.000 $", it: "25.000 - 75.000 $", ar: "25-75 ألف دولار", ja: "2.5万〜7.5万ドル" } },
  { value: "$75k+", label: { en: "$75k+", tr: "$75k+", de: "75.000 $+", fr: "75 000 $+", es: "75.000 $+", it: "75.000 $+", ar: "أكثر من 75 ألف دولار", ja: "7.5万ドル以上" } },
];

const getLabel = (key: keyof typeof labels) => {
  return labels[key][locale] || labels[key]["en"];
};
---

<div class="start-project-form-container">
  <form id="start-project-form" class="project-brief-form">
    <div class="form-header">
      <span>{getLabel("formHeader")}</span>
      <strong>{getLabel("formSteps")}</strong>
    </div>
    
    <fieldset class="brief-form-group">
      <legend><span>1</span>{getLabel("step1")}</legend>
      <div class="field span-2">
        <label for="lpMessage">{getLabel("message")}</label>
        <textarea
          id="lpMessage"
          name="message"
          placeholder={loc(messagePlaceholder)}
          required
        ></textarea>
      </div>
      <div class="field">
        <label for="lpType">{getLabel("projectType")}</label>
        <select id="lpType" name="projectType">
          {projectTypeOptions.map((opt) => (
            <option value={opt.value}>{optLabel(opt)}</option>
          ))}
        </select>
      </div>
      <div class="field">
        <label for="lpStatus">{getLabel("currentStatus")}</label>
        <select id="lpStatus" name="currentStatus">
          {statusOptions.map((opt) => (
            <option value={opt.value}>{optLabel(opt)}</option>
          ))}
        </select>
      </div>
    </fieldset>

    <fieldset class="brief-form-group">
      <legend><span>2</span>{getLabel("step2")}</legend>
      <div class="field span-2">
        <label>{getLabel("layersQuestion")}</label>
        <div class="option-grid">
          {layerOptions.map((layer) => (
            <label>
              <input
                type="checkbox"
                name="layers"
                value={layer.value}
              />{" "}
              {optLabel(layer)}
            </label>
          ))}
        </div>
      </div>
    </fieldset>

    <fieldset class="brief-form-group">
      <legend><span>3</span>{getLabel("step3")}</legend>
      <div class="field">
        <label for="lpTimeline">{getLabel("timeline")}</label>
        <select id="lpTimeline" name="timeline">
          {timelineOptions.map((opt) => (
            <option value={opt.value}>{optLabel(opt)}</option>
          ))}
        </select>
      </div>
      <div class="field">
        <label for="lpBudget">{getLabel("budgetRange")}</label>
        <select id="lpBudget" name="budgetRange">
          {budgetOptions.map((opt) => (
            <option value={opt.value}>{optLabel(opt)}</option>
          ))}
        </select>
      </div>
    </fieldset>

    <fieldset class="brief-form-group">
      <legend><span>4</span>{getLabel("step4")}</legend>
      <div class="field">
        <label for="lpName">{getLabel("name")}</label>
        <input id="lpName" name="name" autocomplete="name" required />
      </div>
      <div class="field">
        <label for="lpEmail">{getLabel("email")}</label>
        <input id="lpEmail" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="field span-2">
        <label for="lpCompany">{getLabel("company")}</label>
        <input id="lpCompany" name="company" autocomplete="organization" />
      </div>
    </fieldset>

    {/* Honeypot — hidden from humans, bots auto-fill it. Submissions with this set are silently dropped server-side. */}
    <div aria-hidden="true" style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;">
      <label for="lpWebsite">Website</label>
      <input id="lpWebsite" name="website" type="text" tabindex="-1" autocomplete="off" />
    </div>
    <p id="error-message" style="color: #ef4444; font-size: 0.875rem; display: none; margin-bottom: 12px;">{getLabel("errorMsg")}</p>
    <button class="btn btn-primary project-submit" type="submit" id="submit-btn">{getLabel("submit")}</button>
  </form>

  <div id="success-message" class="form card" style="text-align: center; padding: 40px 20px; display: none; flex-direction: column; align-items: center; justify-content: center; gap: 16px;">
    <div class="success-icon" style="width: 56px; height: 56px; border-radius: 50%; background: rgba(16, 185, 129, 0.1); display: grid; place-items: center; color: #10b981; font-size: 1.8rem; font-weight: bold;">✓</div>
    <h3 style="font-size: 1.5rem; margin: 0;">{successTitles[locale] || successTitles.en}</h3>
    <p style="color: var(--muted); font-size: 0.96rem; margin: 0; line-height: 1.5; max-width: 320px;">{successTexts[locale] || successTexts.en}</p>
    <button type="button" class="btn btn-secondary btn-small" id="reset-btn" style="margin-top: 10px;">
      {successButtons[locale] || successButtons.en}
    </button>
  </div>
</div>

<script define:vars={{ locale, sendingLabel: getLabel("sending"), submitLabel: getLabel("submit") }}>
  function setupStartProjectForm() {
    const form = document.getElementById('start-project-form');
    const successMsg = document.getElementById('success-message');
    const errorMsg = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');
    const resetBtn = document.getElementById('reset-btn');

    if (!form || !successMsg || !errorMsg || !submitBtn || !resetBtn) return;

    // Prefill product query param if any
    const urlParams = new URLSearchParams(window.location.search);
    const productSlug = urlParams.get('product');
    if (productSlug) {
      const messageField = form.querySelector('#lpMessage');
      if (messageField) {
        const prefillText = {
          en: `Hello, I'd like to plan a project incorporating the ${productSlug} device into our operational system.`,
          tr: `Merhaba, ${productSlug} cihazını operasyonel sistemimize dahil eden bir proje planlamak istiyorum.`,
          de: `Hallo, ich möchte ein Projekt planen, das das Gerät ${productSlug} in unser Betriebssystem integriert.`,
          fr: `Bonjour, je souhaite planifier un projet intégrant le produit ${productSlug} dans notre système opérationnel.`,
          es: `Hola, me gustaría planificar un proyecto que incorpore el dispositivo ${productSlug} en nuestro sistema operativo.`,
          it: `Ciao, vorrei pianificare un progetto che integri il dispositivo ${productSlug} nel nostro sistema operativo.`,
          ar: `مرحباً، أود التخطيط لمشروع يتضمن دمج جهاز ${productSlug} في نظامنا التشغيلي.`,
          ja: `こんにちは。${productSlug} デバイスを当社のシステムに導入するプロジェクトについて相談させてください。`
        };
        messageField.value = prefillText[locale] || prefillText['en'];
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = sendingLabel;
      errorMsg.style.display = 'none';

      // Never use form.name — HTMLFormElement.name is the form's name attribute, not the input.
      const field = (n) => {
        const el = form.elements.namedItem(n);
        return el && typeof el.value === 'string' ? el.value : '';
      };

      const checkedLayers = [];
      const checkboxes = form.querySelectorAll('input[name="layers"]:checked');
      checkboxes.forEach(cb => checkedLayers.push(cb.value));

      const formData = {
        message: field('message'),
        projectType: field('projectType'),
        currentStatus: field('currentStatus'),
        layers: checkedLayers,
        timeline: field('timeline'),
        budgetRange: field('budgetRange'),
        name: field('name'),
        email: field('email'),
        company: field('company'),
        website: field('website'), // honeypot
      };

      try {
        const res = await fetch('/api/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ...formData,
            sourcePage: window.location.pathname,
            locale: locale,
          }),
        });

        if (res.ok) {
          form.style.display = 'none';
          successMsg.style.display = 'flex';
          form.reset();
        } else {
          // Server rejected the submission (validation / rate limit / error):
          // surface the real error instead of pretending it succeeded.
          errorMsg.style.display = 'block';
        }
      } catch (err) {
        // Network failure only — queue offline so the visitor's brief isn't lost.
        try {
          const localLeads = JSON.parse(window.localStorage.getItem('willowsoft-leads-offline') || '[]');
          localLeads.unshift({
            id: `offline-${Date.now()}`,
            status: 'new',
            createdAt: new Date().toISOString(),
            sourcePage: window.location.pathname,
            locale: locale,
            ...formData,
          });
          window.localStorage.setItem('willowsoft-leads-offline', JSON.stringify(localLeads));

          form.style.display = 'none';
          successMsg.style.display = 'flex';
          form.reset();
        } catch {
          errorMsg.style.display = 'block';
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    });

    resetBtn.addEventListener('click', () => {
      successMsg.style.display = 'none';
      form.style.display = 'block';
    });
  }

  setupStartProjectForm();
  document.addEventListener('astro:after-swap', setupStartProjectForm);
</script>

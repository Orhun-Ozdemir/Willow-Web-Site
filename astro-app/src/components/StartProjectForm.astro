  errorMsg: { en: "Something went wrong. Please try again.", tr: "Bir şeyler yanlış gitti. Lütfen tekrar deneyin.", de: "Etwas ist schief gelaufen. Bitte versuchen Sie es erneut.", fr: "Une erreur s'est produite. Veuillez réessayer.", es: "Algo salió mal. Por favor intente de nuevo.", it: "Qualcosa è andato storto. Riprova.", ar: "حدث خطأ ما. يرجى المحاولة مرة أخرى.", ja: "エラーが発生しました。もう一度お試しください。" }
};

type LocRecord = Record<string, string>;
const loc = (map: LocRecord) => map[locale] || map.en;
const optLabel = (item: { label: LocRecord }) => item.label[locale] || item.label.en;

const messagePlaceholder: LocRecord = {
  en: "Describe your product idea, operational goal, current blocker, or field deployment problem...",
  tr: "Ürün fikrinizi, operasyonel hedefinizi, mevcut engelinizi veya saha kurulum sorununuzu anlatın...",
  de: "Beschreiben Sie Ihre Produktidee, Ihr Betriebsziel, aktuelle Hürden oder Probleme beim Feldeinsatz...",
  fr: "Décrivez votre idée de produit, votre objectif opérationnel, votre blocage actuel ou un problème de déploiement terrain...",
  es: "Describa su idea de producto, objetivo operativo, bloqueo actual o problema de despliegue en campo...",
  it: "Descrivi l'idea di prodotto, l'obiettivo operativo, il blocco attuale o un problema di installazione sul campo...",
  ar: "صف فكرة منتجك أو هدفك التشغيلي أو العائق الحالي أو مشكلة النشر الميداني...",

---
import type { Locale } from "@/lib/cms";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const successTitles: Record<string, string> = {
  en: "Submission Received!",
  tr: "Talebiniz Alındı!",
  ar: "تم استلام طلبك!",
  de: "Anfrage Erhalten!",
  fr: "Demande Reçue!",

  { value: "Custom IoT Hardware", label: { en: "Custom IoT Hardware", tr: "Özel IoT donanımı", de: "Individuelle IoT-Hardware", fr: "Matériel IoT sur mesure", es: "Hardware IoT a medida", it: "Hardware IoT personalizzato", ar: "أجهزة IoT مخصصة", ja: "カスタム IoT ハードウェア" } },
  { value: "Firmware / Connectivity", label: { en: "Firmware / Connectivity", tr: "Firmware / bağlantı katmanı", de: "Firmware / Konnektivität", fr: "Firmware / connectivité", es: "Firmware / conectividad", it: "Firmware / connettività", ar: "البرنامج الثابت / الاتصال", ja: "ファームウェア / 接続" } },
  { value: "Backend / PostgreSQL / Admin Panel", label: { en: "Backend / PostgreSQL / Admin Panel", tr: "Backend / PostgreSQL / yönetim paneli", de: "Backend / PostgreSQL / Admin-Panel", fr: "Backend / PostgreSQL / panneau admin", es: "Backend / PostgreSQL / panel admin", it: "Backend / PostgreSQL / pannello admin", ar: "الخلفية / PostgreSQL / لوحة الإدارة", ja: "バックエンド / PostgreSQL / 管理画面" } },
  { value: "Mobile App / Web Platform", label: { en: "Mobile App / Web Platform", tr: "Mobil uygulama / web platformu", de: "Mobile App / Web-Plattform", fr: "Application mobile / plateforme web", es: "App móvil / plataforma web", it: "App mobile / piattaforma web", ar: "تطبيق جوال / منصة ويب", ja: "モバイルアプリ / Webプラットフォーム" } },
  { value: "Website Development", label: { en: "Website Development", tr: "Kurumsal web sitesi", de: "Website-Entwicklung", fr: "Développement de site web", es: "Desarrollo web", it: "Sviluppo sito web", ar: "تطوير موقع ويب", ja: "Webサイト開発" } },
  { value: "VR / Simulation", label: { en: "VR / Simulation", tr: "VR / simülasyon", de: "VR / Simulation", fr: "VR / simulation", es: "VR / simulación", it: "VR / simulazione", ar: "الواقع الافتراضي / المحاكاة", ja: "VR / シミュレーション" } },

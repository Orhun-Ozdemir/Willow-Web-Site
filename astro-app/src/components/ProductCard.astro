---
import { localizeItem, resolveAsset, resolveLocale, type Locale } from "@/lib/cms";
import { DEFAULT_PRODUCT_CATEGORIES, productCategoryLabel, type ProductCategory } from "@/lib/product-categories";

interface Props {
  product: any;
  locale: Locale;
  index: number;
  variant?: "default" | "catalog";
  categories?: ProductCategory[];
}

const { product, index, variant = "default", categories = DEFAULT_PRODUCT_CATEGORIES } = Astro.props;
const locale = resolveLocale(Astro.props.locale, Astro.url.pathname);
const p = localizeItem(product, locale);
const delay = index % 4 ? ` delay-${index % 4}` : "";
const localizeChip = (chip: string) => {
  if (locale !== "tr") return chip;
  return chip
    .replace(/\b10 years\b/gi, "10 yıla kadar")
    .replace(/\b5 years\b/gi, "5 yıla kadar");
};
const chips = (p.chips || []).slice(0, 3).map(localizeChip);

const cutoutImage =
  resolveAsset(p.cardImage) ||
  resolveAsset(p.image) ||
  resolveAsset(`assets/product-cutouts/${p.id}.png`);
const originalImage = resolveAsset(p.image) || resolveAsset(p.cardImage) || cutoutImage;
const detailsLabel: Record<string, string> = {
  en: "View Details",
  tr: "Detayları Gör",
  de: "Details ansehen",
  fr: "Voir les détails",
  es: "Ver detalles",
  it: "Vedi dettagli",
  ar: "عرض التفاصيل",
  ja: "詳細を見る",
};
// Category is a stable technical key and must never be replaced by a localized value.
const displayCategory = String(product.category || "environment");
const categoryLabel = productCategoryLabel(categories, displayCategory, locale);
---

<article class={`card product-card${variant === "catalog" ? " product-card-premium" : ""} reveal${delay}`} data-category={displayCategory} data-product={p.id}>
  <figure>
    {variant === "catalog" && <span class="product-card-category">{categoryLabel}</span>}
    <img src={cutoutImage} alt={p.title} loading="lazy" decoding="async" onerror="this.onerror=null; this.src='/assets/willow-mark-transparent.png'; this.style.opacity='0.15';" />
    {variant === "catalog" && <span class="product-card-index" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>}
  </figure>
  <div class="product-body">
    <h3>{p.title}</h3>
    <p class="product-description">{p.shortDescription}</p>
    <div class="chip-row">
      {chips.map((chip: string) => (
        <span class="chip">{chip}</span>
      ))}
    </div>
    <div class="product-actions">
      <a href={`/${locale}/products/${encodeURIComponent(p.slug || p.id)}`} class="btn btn-ghost btn-small">
        <span>{detailsLabel[locale] || detailsLabel.en}</span>
        {variant === "catalog" && <span class="product-action-arrow" aria-hidden="true">↗</span>}
      </a>
    </div>
  </div>
</article>

---
import { localizeItem, resolveLocale, type Locale } from "@/lib/cms";

interface Props {
  product: any;
  locale: Locale;
  index: number;
}

const { product, index } = Astro.props;
const locale = resolveLocale(Astro.props.locale, Astro.url.pathname);
const p = localizeItem(product, locale);
const delay = index % 4 ? ` delay-${index % 4}` : "";
const chips = (p.chips || []).slice(0, 3);
const base = import.meta.env.BASE_URL?.replace(/\/$/, "") || "";

function resolveImgUrl(url: string | undefined): string | undefined {
  if (!url) return undefined;
  // Full URL (https://...) — keep as-is
  if (/^https?:\/\//i.test(url)) return url;
  // Already has leading slash — keep as-is
  if (url.startsWith("/")) return url;
  // Relative path (e.g. "assets/...") — prepend base
  return `${base}/${url}`;
}

const cutoutImage =
  resolveImgUrl(p.cardImage) ||
  resolveImgUrl(p.image) ||
  `${base}/assets/product-cutouts/${p.id}.png`;
const originalImage = resolveImgUrl(p.image) || resolveImgUrl(p.cardImage) || cutoutImage;
const detailsLabel: Record<string, string> = {
  en: "View Details",
  tr: "Detayları Gör",
  de: "Details ansehen",
  fr: "Voir les détails",
  es: "Ver detalles",
  it: "Vedi dettagli",
  ar: "عرض التفاصيل",
  ja: "詳細を見る",
};
---

<article class={`card product-card reveal${delay}`} data-category={p.category}>
  <figure>
    <img src={cutoutImage} alt={p.title} loading="lazy" decoding="async" onerror="this.onerror=null; this.src='/assets/willow-mark-transparent.png'; this.style.opacity='0.15';" />
  </figure>
  <div class="product-body">
    <h3>{p.title}</h3>
    <p class="product-description">{p.shortDescription}</p>
    <div class="chip-row">
      {chips.map((chip: string) => (
        <span class="chip">{chip}</span>
      ))}
    </div>
    <div class="product-actions">
      <a href={`/${locale}/products/${encodeURIComponent(p.slug || p.id)}`} class="btn btn-ghost btn-small">
        {detailsLabel[locale] || detailsLabel.en}
      </a>
    </div>
  </div>
</article>

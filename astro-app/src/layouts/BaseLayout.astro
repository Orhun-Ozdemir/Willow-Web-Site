---
import "@/styles/globals.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  locale?: string;
  dataPage?: string;
}

const { title, description = "", canonical, locale = "en", dataPage } = Astro.props;
---

<!doctype html>
<html lang={locale} class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <ClientRouter />
  </head>
  <body data-page={dataPage} class="min-h-full flex flex-col">
    <slot />
    <script>
      import { initMotion } from "@/scripts/site-motion";
      import { initKineticMedia } from "@/scripts/kinetic-media";
      import { initPcbScene } from "@/scripts/pcb-scene";

      document.addEventListener("astro:page-load", () => {
        initMotion();
        initKineticMedia();
        initPcbScene();
      });
    </script>
  </body>
</html>


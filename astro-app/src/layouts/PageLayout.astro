---
import BaseLayout from "./BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { resolveLocale, type Locale } from "@/lib/cms";
import type { Alternate } from "@/lib/seo";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  locale: Locale;
  dataPage?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  alternates?: Alternate[];
  schema?: object | object[];
}

const locale = resolveLocale(Astro.props.locale, Astro.url.pathname);
---

<BaseLayout {...Astro.props}>
  <Header locale={locale} currentPath={Astro.url.pathname} />
  <slot />
  <Footer locale={locale} />
</BaseLayout>

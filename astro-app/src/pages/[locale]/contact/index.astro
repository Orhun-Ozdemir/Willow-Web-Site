---
import PageLayout from "@/layouts/PageLayout.astro";
import ContactForm from "@/components/ContactForm.astro";
import FaqAccordion from "@/components/FaqAccordion.astro";
import AIAnswerBlock from "@/components/AIAnswerBlock.astro";
import { loadContent } from "@/lib/content";
import { pageSeo, webPageNode, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA, SITE_ORIGIN } from "@/lib/seo";
import { pageText, resolveLocale, type Locale } from "@/lib/cms";
import { aiAnswerForPage, aiMetaForPage, appendSchemaNodes, fallbackFaqsForPage, faqItemsForPage, faqSchemaNode } from "@/lib/ai-search";
import { officesForContact, telHref } from "@/lib/company-contact";

export const prerender = false;

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const content = await loadContent();
const seoProps = pageSeo(content, "contact", locale, "/contact", "Contact | WillowSoft", "Contact WillowSoft for IoT hardware, backend, PostgreSQL, and software development projects.");
const contactFallbackFaqs = fallbackFaqsForPage("contact", locale);
const contactFaqItems = faqItemsForPage(content.faqs || [], "contact", locale, contactFallbackFaqs);
const aiAnswer = aiAnswerForPage(content, "contact", locale, seoProps.description);
const aiMeta = aiMetaForPage(content, "contact", locale);
const contactSchema = appendSchemaNodes({
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    {
      ...webPageNode("ContactPage", seoProps.canonical, seoProps.title, seoProps.description, locale),
      mainEntity: { "@id": `${SITE_ORIGIN}/#org` },
    },
  ],
}, [faqSchemaNode(seoProps.canonical, contactFaqItems)]);
const pageContent = content.pageContent?.contact || {};
const t = (cmsKey: string, fallback: string) => pageText(pageContent, cmsKey, locale, fallback);

const companyFacts = content.companyFacts || {};
const contactOffices = officesForContact(companyFacts, locale);
const officeTitle = (officeId: string, country: string) => {
  if (officeId === "office-tr") return getLabel("turkeyOffice");
  if (officeId === "office-uk") return getLabel("ukOffice");
  return country;
};

const labels = {
  turkeyOffice: { en: "Turkey Office", tr: "Türkiye Ofisi", de: "Büro Türkei", fr: "Bureau Turquie", es: "Oficina Turquía", it: "Ufficio Turchia", ar: "مكتب تركيا", ja: "トルコオフィス" },
  ukOffice: { en: "UK Office", tr: "İngiltere Ofisi", de: "Büro UK", fr: "Bureau Royaume-Uni", es: "Oficina Reino Unido", it: "Ufficio Regno Unito", ar: "مكتب المملكة المتحدة", ja: "イギリスオフィス" },
  contactUs: { en: "Contact us", tr: "Bizimle iletişime geçin", de: "Kontaktieren Sie uns", fr: "Contactez-nous", es: "Contáctenos", it: "Contattaci", ar: "اتصل بنا", ja: "お問い合わせ" },
  directTitle: { en: "Direct Connection", tr: "Doğrudan Bağlantı", de: "Direkter Kontakt", fr: "Contact direct", es: "Conexión directa", it: "Contatto diretto", ar: "تواصل مباشر", ja: "ダイレクト連絡" },
  directLead: {
    en: "Use the contact form for general messages, office communication and first conversations that do not yet need a full project brief.",
    tr: "Genel mesajlar, ofis iletişimi ve henüz tam bir proje özeti gerektirmeyen ilk görüşmeler için iletişim formunu kullanın.",
    de: "Nutzen Sie das Kontaktformular für allgemeine Nachrichten, die Kommunikation mit dem Büro und erste Gespräche, die noch kein vollständiges Projektbriefing erfordern.",
    fr: "Utilisez le formulaire de contact pour les messages généraux, les échanges avec le bureau et les premières conversations qui ne nécessitent pas encore de brief de projet complet.",
    es: "Use el formulario de contacto para mensajes generales, comunicación con la oficina y primeras conversaciones que aún no requieren un brief de proyecto completo.",
    it: "Usa il modulo di contatto per messaggi generali, comunicazioni con l'ufficio e primi contatti che non richiedono ancora un brief di progetto completo.",
    ar: "استخدم نموذج التواصل للرسائل العامة والتواصل مع المكتب والمحادثات الأولى التي لا تتطلب بعد ملخّص مشروع كامل.",
    ja: "一般的なお問い合わせ、オフィスとの連絡、まだ詳細なプロジェクト概要を必要としない初回のご相談には、お問い合わせフォームをご利用ください。",
  },
  faqEyebrow: { en: "Frequently asked", tr: "Sıkça sorulanlar", de: "Häufig gestellte Fragen", fr: "Questions fréquentes", es: "Preguntas frecuentes", it: "Domande frequenti", ar: "أسئلة مكررة", ja: "よくある質問" },
  faqTitle: { en: "Questions before contacting.", tr: "İletişime geçmeden önce sorular.", de: "Fragen vor dem Kontakt.", fr: "Questions avant de nous contacter.", es: "Preguntas antes de contactar.", it: "Domande prima di contattare.", ar: "أسئلة قبل الاتصال.", ja: "お問い合わせ前の質問" },
  faqLead: {
    en: "Here are answers to general questions regarding communications, office locations, and NDAs.",
    tr: "İletişim, ofis konumları ve NDA'ler hakkındaki genel soruların yanıtları.",
    de: "Hier finden Sie Antworten auf allgemeine Fragen zu Kommunikation, Bürostandorten und NDAs.",
    fr: "Voici les réponses aux questions générales concernant la communication, les bureaux et les accords de confidentialité.",
    es: "Aquí encontrará respuestas a preguntas generales sobre comunicaciones, ubicaciones de oficinas y acuerdos de confidencialidad.",
    it: "Ecco le risposte alle domande generali relative a comunicazioni, uffici e accordi di riservatezza.",
    ar: "إليك إجابات الأسئلة العامة المتعلقة بالاتصالات ومواقع المكاتب واتفاقيات عدم الإفصاح.",
    ja: "連絡方法、オフィス所在地、秘密保持契約（NDA）に関する一般的な質問への回答です。"
  }
};

const getLabel = (key: keyof typeof labels) => {
  return labels[key][locale] || labels[key]["en"];
};
---

<PageLayout
  {...seoProps}
  schema={contactSchema}
  locale={locale}
  dataPage="contact"
>
  <main>
    <section class="section soft">
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{t("heroEyebrow", getLabel("contactUs"))}</p>
          <h1 class="page-title">{t("heroTitle", "")}</h1>
          <p class="section-lead">{t("heroLead", "")}</p>

          {(t("directTitle", getLabel("directTitle")) || t("directLead", getLabel("directLead"))) && (
            <div class="handoff-note" style={{ marginTop: "24px" }}>
              {t("directTitle", getLabel("directTitle")) && <strong>{t("directTitle", getLabel("directTitle"))}</strong>}
              {t("directLead", getLabel("directLead")) && <span>{t("directLead", getLabel("directLead"))}</span>}
            </div>
          )}
          
          <div class="office-contact-grid">
            {contactOffices.map((office) => (
              <article class="office-contact-card">
                <span>{getLabel("contactUs")}</span>
                <h3>{officeTitle(office.id, office.country)}</h3>
                {office.phone && (
                  <a href={telHref(office.phone)} data-company-fact={office.id === "office-tr" ? "turkeyPhone" : office.id === "office-uk" ? "ukPhone" : undefined}>
                    {office.phone}
                  </a>
                )}
                {office.email && (
                  <a href={`mailto:${office.email}`} data-company-fact="email">
                    {office.email}
                  </a>
                )}
                {office.address && <p>{office.address}</p>}
              </article>
            ))}
          </div>
        </div>
        
        <div class="reveal delay-1">
          <ContactForm locale={locale} />
        </div>
      </div>
    </section>

    <section class="section tight">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
      </div>
    </section>

    <!-- FAQ -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "36px" }}>
          <p class="eyebrow">{getLabel("faqEyebrow")}</p>
          <h2 class="page-title">{getLabel("faqTitle")}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {getLabel("faqLead")}
          </p>
        </div>
        <div class="reveal delay-1">
          <FaqAccordion faqs={content.faqs || []} pageKey="contact" locale={locale} fallbackFaqs={contactFallbackFaqs} />
        </div>
      </div>
    </section>
  </main>
</PageLayout>

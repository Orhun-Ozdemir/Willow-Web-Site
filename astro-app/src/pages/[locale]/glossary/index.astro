---
import PageLayout from "@/layouts/PageLayout.astro";
import { loadContent } from "@/lib/content";
import { pageSeo } from "@/lib/seo";
import { localizeItem, pageText, resolveLocale, type Locale } from "@/lib/cms";

export const prerender = false;

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const content = await loadContent();
const pageContent = content.pageContent?.glossary || {};
const glossaryList = content.glossary || [];
const seoProps = pageSeo(content, "glossary", locale, "/glossary", "IoT & LoRaWAN Glossary | WillowSoft", "Plain-English definitions of LoRaWAN, Modbus RTU, Industrial IoT, embedded systems, MCU, IP67, edge computing and other terms used by WillowSoft engineering.");
const t = (key: string, fallback = "") => pageText(pageContent, key, locale, fallback);

const getGlossaryItems = (category: string) => {
  return glossaryList
    .filter((item: any) => item.category === category)
    .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0))
    .map((item: any) => localizeItem(item, locale));
};

const connectivityItems = getGlossaryItems("connectivity");
const devicesItems = getGlossaryItems("devices");
const softwareItems = getGlossaryItems("software");

const getNoteLabel = () => {
  const noteLabels: Record<string, string> = {
    en: "WillowSoft uses it in:",
    tr: "WillowSoft kullanım alanları:",
    de: "WillowSoft setzt es ein in:",
    fr: "WillowSoft l'utilise dans :",
    es: "WillowSoft lo usa en:",
    it: "WillowSoft lo usa in:",
    ar: "تستخدمه WillowSoft في:",
    ja: "WillowSoftでの用途：",
  };
  return noteLabels[locale] || noteLabels.en;
};

const labels = {
  talkToEngineering: { en: "Talk to Engineering", tr: "Mühendislerle Görüşün", de: "Mit Engineering sprechen", fr: "Parler à l'ingénierie", es: "Hablar con ingeniería", it: "Parla con il team", ar: "تحدث إلى الهندسة", ja: "技術チームへ相談" },
};
const getLabel = (key: keyof typeof labels) => labels[key][locale] || labels[key].en;
---

<PageLayout
  {...seoProps}
  locale={locale}
  dataPage="glossary"
>
  <main>
    <!-- Hero -->
    <section class="hero compact">
      <canvas class="signal-canvas" data-density="28" data-color="26, 163, 196"></canvas>
      <div class="hero-inner">
        <p class="eyebrow reveal">{t("heroEyebrow")}</p>
        <h1 class="reveal delay-1" set:html={t("heroTitle")} />
        <p class="reveal delay-2">{t("heroLead")}</p>
      </div>
    </section>

    <!-- Connectivity Section -->
    <section class="section">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{t("connectivityEyebrow")}</p>
          <h2>{t("connectivityTitle")}</h2>
        </div>
        <div class="grid grid-2">
          {connectivityItems.map((item: any, index: number) => {
            const delay = index % 2 ? " delay-1" : "";
            return (
              <article class={`card reveal${delay}`} id={item.id}>
                <h3>{item.term}</h3>
                <p>{item.definition}</p>
                {item.note && (
                  <p>
                    <strong>{getNoteLabel()}</strong> {item.note}
                  </p>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Devices Section -->
    <section class="section soft">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{t("devicesEyebrow")}</p>
          <h2>{t("devicesTitle")}</h2>
        </div>
        <div class="grid grid-2">
          {devicesItems.map((item: any, index: number) => {
            const delay = index % 2 ? " delay-1" : "";
            return (
              <article class={`card reveal${delay}`} id={item.id}>
                <h3>{item.term}</h3>
                <p>{item.definition}</p>
                {item.note && (
                  <p>
                    <strong>{getNoteLabel()}</strong> {item.note}
                  </p>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Software Section -->
    <section class="section">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{t("softwareEyebrow")}</p>
          <h2>{t("softwareTitle")}</h2>
        </div>
        <div class="grid grid-2">
          {softwareItems.map((item: any, index: number) => {
            const delay = index % 2 ? " delay-1" : "";
            return (
              <article class={`card reveal${delay}`} id={item.id}>
                <h3>{item.term}</h3>
                <p>{item.definition}</p>
                {item.note && (
                  <p>
                    <strong>{getNoteLabel()}</strong> {item.note}
                  </p>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section dark">
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{t("ctaEyebrow")}</p>
          <h2 class="page-title">{t("ctaTitle")}</h2>
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{t("ctaLead")}</p>
          <p><a class="btn btn-primary" href={`/${locale}/contact`}>{getLabel("talkToEngineering")}</a></p>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

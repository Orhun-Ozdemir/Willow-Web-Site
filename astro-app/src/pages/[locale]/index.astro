const INDUSTRY_ICONS = ["🏙️", "⚙️", "🩺", "📦"];
const industryIconKeysFor = (lane: any) => {
  const text = `${lane?.title || ""} ${lane?.desc || ""}`.toLocaleLowerCase();
  const has = (pattern: RegExp) => pattern.test(text);

  if (has(/medtech|health|sağlık|gesund|santé|salud|salute|医療|صحة/)) return ["activity"];
  if (has(/energy|enerji|energie|energía|energia|エネルギー|طاقة/)) return ["battery"];

  const isLogistics = has(/logistic|lojistik|logistik|logistique|logística|物流|لوجست/);
  const isTelecom = has(/telecom|telekom|télécom|telecomunic|通信|اتصالات/);
  if (isLogistics && isTelecom) return ["map", "radio"];
  if (isLogistics) return ["map"];
  if (isTelecom) return ["radio"];

  if (has(/industrial|endüstri|industrie|industria|産業|صناع/)) return ["factory"];
  if (has(/infrastr|altyapı|smart city|akıllı şehir|infraestructura|infrastrutt|インフラ|بنية/)) return ["building"];
  return ["stack"];
};

const DEFAULT_INDUSTRY_LANES: { title: L10n; desc: L10n }[] = [
  {
    title: { en: "Smart Infrastructure", tr: "Akıllı Altyapı", de: "Smarte Infrastruktur", fr: "Infrastructures intelligentes", es: "Infraestructura inteligente", it: "Infrastrutture intelligenti", ar: "البنية التحتية الذكية", ja: "スマートインフラ" },
    desc: {
      en: "Field sensors designed for flood prevention, reservoir tracking and smart lighting systems.",
      tr: "Taşkın önleme, su deposu takibi ve akıllı aydınlatma sistemleri için tasarlanmış saha sensörleri.",
      de: "Feldsensoren für Hochwasserschutz, Wassertanküberwachung und intelligente Beleuchtungssysteme.",
      fr: "Capteurs de terrain conçus pour la prévention des inondations, le suivi des réservoirs et l'éclairage intelligent.",
      es: "Sensores de campo diseñados para prevención de inundaciones, seguimiento de depósitos y sistemas de alumbrado inteligente.",
      it: "Sensori da campo progettati per prevenzione allagamenti, monitoraggio serbatoi e illuminazione intelligente.",
      ar: "مستشعرات ميدانية مصممة لمنع الفيضانات وتتبع خزانات المياه وأنظمة الإنارة الذكية.",
      ja: "洪水防止、貯水池監視、スマート照明システム向けに設計された現場センサー。",
    },
  },
  {
    title: { en: "Industrial Monitoring", tr: "Endüstriyel İzleme", de: "Industrielle Überwachung", fr: "Surveillance industrielle", es: "Monitoreo industrial", it: "Monitoraggio industriale", ar: "المراقبة الصناعية", ja: "産業モニタリング" },
    desc: {
      en: "Machine data, predictive maintenance, factories, warehouses and energy systems.",
      tr: "Makine verileri, kestirimci bakım, fabrikalar, depolar ve enerji sistemleri.",
      de: "Maschinendaten, vorausschauende Wartung, Fabriken, Lager und Energiesysteme.",
      fr: "Données machines, maintenance prédictive, usines, entrepôts et systèmes énergétiques.",
      es: "Datos de máquinas, mantenimiento predictivo, fábricas, almacenes y sistemas energéticos.",
      it: "Dati macchina, manutenzione predittiva, fabbriche, magazzini e sistemi energetici.",
      ar: "بيانات الآلات والصيانة التنبؤية والمصانع والمستودعات وأنظمة الطاقة.",
      ja: "機械データ、予知保全、工場、倉庫、エネルギーシステム。",
    },
  },
  {
    title: { en: "MedTech & Healthcare", tr: "MedTech ve Sağlık", de: "MedTech & Gesundheit", fr: "MedTech & Santé", es: "MedTech y Salud", it: "MedTech e Sanità", ar: "التقنية الطبية والرعاية الصحية", ja: "医療・ヘルスケア" },
    desc: {
      en: "Low-power wireless sensor nodes for hospitals, laboratories and care units.",
      tr: "Hastane, laboratuvar ve bakım üniteleri için düşük güçlü kablosuz sensör düğümleri.",
      de: "Energieeffiziente drahtlose Sensorknoten für Krankenhäuser, Labore und Pflegeeinheiten.",
      fr: "Nœuds capteurs sans fil basse consommation pour hôpitaux, laboratoires et unités de soins.",
      es: "Nodos sensores inalámbricos de bajo consumo para hospitales, laboratorios y unidades de cuidados.",
      it: "Nodi sensore wireless a basso consumo per ospedali, laboratori e unità di cura.",
      ar: "عقد استشعار لاسلكية منخفضة الطاقة للمستشفيات والمختبرات ووحدات الرعاية.",
      ja: "病院、研究所、ケアユニット向けの低消費電力ワイヤレスセンサーノード。",
    },
  },
  {
    title: { en: "Logistics & Telecom", tr: "Lojistik ve Telekom", de: "Logistik & Telekom", fr: "Logistique & Télécoms", es: "Logística y Telecomunicaciones", it: "Logistica e Telecomunicazioni", ar: "اللوجستيات والاتصالات", ja: "物流・通信" },
    desc: {
      en: "Smart devices designed for asset tracking, GNSS positioning and mobile operations.",
      tr: "Varlık takibi, GNSS tabanlı konumlandırma ve mobil operasyonlar için tasarlanmış akıllı cihazlar.",
      de: "Intelligente Geräte für Asset-Tracking, GNSS-Positionierung und mobile Einsätze.",
      fr: "Appareils intelligents conçus pour le suivi d'actifs, le positionnement GNSS et les opérations mobiles.",
      es: "Dispositivos inteligentes diseñados para seguimiento de activos, posicionamiento GNSS y operaciones móviles.",
      it: "Dispositivi intelligenti progettati per tracciamento asset, posizionamento GNSS e operazioni mobili.",
      ar: "أجهزة ذكية مصممة لتتبع الأصول وتحديد المواقع GNSS والعمليات المتنقلة.",
      ja: "資産追跡、GNSS測位、移動オペレーション向けに設計されたスマートデバイス。",
    },
  },
];

const cmsIndustryLanes = industryLanesFromPageContent(pageContent, locale);
const industryLanes = cmsIndustryLanes.length > 0
  ? cmsIndustryLanes.map((lane, idx) => ({
      icon: INDUSTRY_ICONS[idx] || "📦",
      title: lane.title,
      desc: lane.desc,
    }))
  : DEFAULT_INDUSTRY_LANES.map((lane, idx) => ({
      icon: INDUSTRY_ICONS[idx] || "📦",
      title: loc(lane.title),
      desc: loc(lane.desc),
    }));

const homeSchema = appendSchemaNodes({
  "@context": "https://schema.org",
  "@graph": [ORGANIZATION_SCHEMA, WEBSITE_SCHEMA],
}, [faqSchemaNode(seoProps.canonical, homeFaqItems)]);
---

<PageLayout
  {...seoProps}
  schema={homeSchema}
  locale={locale}
  dataPage="home"
>
  <main id="main-content">
    <!-- Hero -->
    <section class="hero motion-hero">
      <div class="hero-media">
        <img src={`${import.meta.env.BASE_URL}assets/hero-industrial-iot.jpg`} alt="Industrial IoT hardware on a lab bench" loading="lazy" decoding="async" />
      </div>
      <canvas class="hero-shader-canvas" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></canvas>
      <canvas class="signal-canvas" data-density="42" data-color="75, 87, 170"></canvas>
      <div class="hero-inner hero-layout">
        <div class="hero-copy">
          {heroEyebrow.trim() && <p class="eyebrow reveal">{heroEyebrow}</p>}
          <h1 class="reveal delay-1" set:html={getVal("heroTitle", loc(heroTitleFallback))} />
          <p class="reveal delay-2">{getVal("heroLead")}</p>
          <div class="hero-ctas reveal delay-3">
            <a class="btn btn-primary" href={heroCtaHref}>{heroCtaLabel}</a>
            <a class="btn btn-secondary" href={heroCtaSecondaryHref}>{heroCtaSecondaryLabel}</a>
          </div>
          <div class="hero-proof reveal delay-4">
            <div class="proof-item">
              <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket}</strong>
              <span>{getLabel("productsOnMarket")}</span>
            </div>
            <div class="proof-item">
              <strong data-company-fact="happyClients">{companyFacts.happyClients}</strong>
              <span>{getLabel("happyClients")}</span>
            </div>
            <div class="proof-item">
              <strong data-company-fact="founded">{companyFacts.founded}</strong>
              <span>{getLabel("founded")}</span>
            </div>
          </div>
        </div>

        <aside class="hero-product-stage reveal delay-2" aria-label="WillowSoft hardware showcase">
          <div class="product-spotlight"></div>
          <article class="floating-product product-one" style="--delay:0ms">
            <figure><img src={`${import.meta.env.BASE_URL}pdf-assets/p06_01_X13.jpg`} alt="WillowBee LoRaWAN module" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowBee</strong><span>Compact LoRaWAN MCU module</span></div>
          </article>
          <article class="floating-product product-two" style="--delay:180ms">
            <figure><img src={`${import.meta.env.BASE_URL}pdf-assets/p08_01_X22.jpg`} alt="WillowAir sensor" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowAir</strong><span>Indoor air quality monitoring</span></div>
          </article>
          <article class="floating-product product-three" style="--delay:360ms">
            <figure><img src={`${import.meta.env.BASE_URL}pdf-assets/p14_01_X50.jpg`} alt="WillowMod sensor" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowMod</strong><span>Wireless Modbus integration</span></div>
          </article>
        </aside>
      </div>
    </section>

    <!-- Service Rail -->
    <section class="section tight home-service-section">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
        <div class="service-rail reveal">
          {serviceRail.map((item, idx) => (
            <article><span class="service-number">{String(idx + 1).padStart(2, "0")}</span><h3>{item.title}</h3><p>{item.desc}</p></article>
          ))}
        </div>
      </div>
    </section>

    <!-- Trust Showcase -->
    <section class="trust-showcase" id="trusted-brands" aria-label="Trusted by clients">
      <div class="section-inner trust-layout">
        <div class="trust-copy reveal-left">
          <p class="eyebrow">{getVal("trustEyebrow")}</p>
          <h2 set:html={getVal("trustTitle")} />
          <p>{getVal("trustLead")}</p>
          <div class="trust-more" aria-label="Additional sectors">
            {trustChips.map((chip) => <span>{loc(chip)}</span>)}
          </div>
        </div>
        <div class="trust-stage reveal-right delay-1">
          <div class="logo-cloud" data-cms-clients>
            {featuredClients.map((client: any, idx: number) => {
              const depths = [18, 54, 28, 42, 12, 66, 36, 24];
              const z = depths[idx % depths.length];
              const delay = idx * 130;
              return (
                <div class="logo-tile" style={`--z:${z}px;--delay:${delay}ms`} title={client.name}>
                  {client.logo ? <img src={resolveAsset(client.logo)} alt={client.name} loading="lazy" decoding="async" /> : <strong>{client.name}</strong>}
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Ecosystem -->
    <section class="section dark ecosystem-section ecosystem-signature">
      <div class="section-inner">
        <div class="ecosystem-signature-head reveal">
          <div>
            <p class="eyebrow">{getVal("ecosystemEyebrow")}</p>
            <h2 set:html={getVal("ecosystemTitle")} />
          </div>
          <p class="section-lead">{getVal("ecosystemLead", loc(ecosystemLead))}</p>
        </div>
        <div class="tech-flow signature-tech-flow reveal delay-1">
          <div class="flow-row signature-flow-row">
            {flowNodes.map((node, idx) => (
              <article
                class="flow-node signature-flow-node"
                style={`--stage:${idx}`}
                data-stage={idx}
                data-transfer={flowTransferCodes[idx] || "DATA"}
              >
                <div class="signature-node-head">
                  <small>{String(idx + 1).padStart(2, "0")}</small>
                </div>
                <div class={`signature-node-visual signature-node-visual--${idx}`} aria-hidden="true">
                  <img
                    class="signature-node-image"
                    src={flowIllustrationAssets[idx] || flowIllustrationAssets[0]}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="signature-visual-packet">{flowTransferCodes[idx] || "DATA"}</span>
                </div>
                <strong>{node.title}</strong>
                <span class="signature-node-desc">{node.desc}</span>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="section home-products">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("productsEyebrow")}</p>
            <h2 set:html={getVal("productsTitle")} />
            {getVal("productsLead") && <p class="section-lead">{getVal("productsLead")}</p>}
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/products`}>{getLabel("viewProducts")}</a>
        </div>
        <div class="grid grid-4" data-cms-featured-products>
          {featuredProducts.map((p: any, idx: number) => (
            <ProductCard product={p} locale={locale} index={idx} />
          ))}
        </div>
      </div>
    </section>

    <!-- Industries -->
    <section class="section soft industries-section">
      <div class="section-inner">
        <div class="section-head center reveal">
          <p class="eyebrow">{getVal("industriesEyebrow")}</p>
          <h2 set:html={getVal("industriesTitle")} />
        </div>
        <div class="industry-lanes">
          {industryLanes.map((lane, idx) => {
            const iconKeys = industryIconKeysFor(lane);
            return (
              <article class={`industry-lane reveal${idx > 0 ? ` delay-${idx}` : ""}`} data-industry={idx}>
                <span class="industry-lane-index" aria-hidden="true">{String(idx + 1).padStart(2, "0")}</span>
                <div class="industry-lane-copy"><h3>{lane.title}</h3><p>{lane.desc}</p></div>
                <div class={`industry-lane-schematic${iconKeys.length > 1 ? " is-dual" : ""}`} aria-hidden="true">
                  {iconKeys.map((key) => <span class="industry-icon-glyph" set:html={PRODUCT_ICON_SVG[key] || PRODUCT_ICON_SVG.stack} />)}
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- News -->
    <section class="section proof-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("newsEyebrow")}</p>
            <h2 set:html={getVal("newsTitle")} />
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/news`}>{getLabel("viewNews")}</a>
        </div>
        <div class="grid grid-3" data-cms-news>
          {latestNews.map((n: any, idx: number) => (
            <NewsCard item={n} locale={locale} index={idx} variant="compact" />
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "24px" }}>
          <p class="eyebrow">{getVal("faqEyebrow") || getLabel("faqEyebrow")}</p>
          <h2 class="page-title">{getVal("faqTitle") || getLabel("faqTitle")}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {getVal("faqLead") || getLabel("faqLead")}
          </p>
        </div>
        <FaqAccordion faqs={content.faqs || []} pageKey="home" locale={locale} fallbackFaqs={homeFallbackFaqs} />
      </div>
    </section>

    <section class="section dark final-cta">
      <canvas class="signal-canvas" data-density="26" data-color="215, 154, 43"></canvas>
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getVal("ctaEyebrow")}</p>
          <h2 class="page-title" set:html={getVal("ctaTitle")} />
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{getVal("ctaLead")}</p>
          <div class="cta-choice-grid" aria-label="Common project starting points">
            <span>{getVal("ctaChoice_0") || getLabel("ctaChoice_0")}</span>
            <span>{getVal("ctaChoice_1") || getLabel("ctaChoice_1")}</span>
            <span>{getVal("ctaChoice_2") || getLabel("ctaChoice_2")}</span>
          </div>
          <p><a class="btn btn-primary" href={ctaCtaHref}>{ctaCtaLabel}</a></p>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

---
import PageLayout from "@/layouts/PageLayout.astro";
import { loadContent } from "@/lib/content";
import { localizedValue, localizeItem, locales, type Locale } from "@/lib/cms";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const content = loadContent();
const pageContent = content.pageContent?.home || {};
const companyFacts = content.companyFacts || {};
const seo = content.pageSeo?.home?.[locale] || {};

const getVal = (key: string) => localizedValue(pageContent[key], locale);

const featuredProducts = (content.products || [])
  .filter((p: any) => p.featured)
  .slice(0, 4)
  .map((p: any) => localizeItem(p, locale));
const latestNews = (content.news || []).slice(0, 3).map((n: any) => localizeItem(n, locale));
const featureNews = latestNews[0];
const sideNews = latestNews.slice(1);
const featuredClients = (content.clients || [])
  .filter((c: any) => c.featured)
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

const labels: Record<string, Record<string, string>> = {
  productsOnMarket: { en: "Products on market", tr: "Piyasadaki ürünler", de: "Produkte am Markt", fr: "Produits sur le marché", es: "Productos en el mercado", it: "Prodotti sul mercato", ar: "منتج في السوق", ja: "市場実績製品" },
  happyClients: { en: "Happy clients", tr: "Mutlu müşteriler", de: "Zufriedene Kunden", fr: "Clients satisfaits", es: "Clientes satisfechos", it: "Clienti felici", ar: "عميل سعيد", ja: "取引先企業数" },
  founded: { en: "Founded", tr: "Kuruluş", de: "Gegründet", fr: "Fondation", es: "Fundación", it: "Fondazione", ar: "تأسست عام", ja: "設立年" },
  officesWorldwide: { en: "Offices worldwide", tr: "Dünya çapında ofis", de: "Büros weltweit", fr: "Bureaux dans le monde", es: "Oficinas en el mundo", it: "Uffici nel mondo", ar: "مكتب حول العالم", ja: "拠点数" },
  exploreServices: { en: "Explore Services", tr: "Hizmetleri Keşfet", de: "Dienste erkunden", fr: "Découvrir les services", es: "Explorar servicios", it: "Esplora i servizi", ar: "استكشف الخدمات", ja: "提供サービスを見る" },
  startProject: { en: "Start Your Project", tr: "Projeye Başla", de: "Projekt starten", fr: "Démarrer un projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "ابدأ مشروعًا", ja: "プロジェクトを開始" },
  viewProducts: { en: "Browse Products", tr: "Ürünlere Göz At", de: "Produkte durchsuchen", fr: "Parcourir les produits", es: "Ver productos", it: "Sfoglia i prodotti", ar: "تصفح المنتجات", ja: "製品カタログを見る" },
  viewNews: { en: "View News", tr: "Haberleri Görüntüle", de: "News anzeigen", fr: "Voir les actualités", es: "Ver noticias", it: "Vedi le news", ar: "عرض الأخبار", ja: "ニュースを見る" },
  talkEngineering: { en: "Talk to Engineering", tr: "Mühendislerimizle Görüşün", de: "Mit Engineering sprechen", fr: "Parler à l'ingénierie", es: "Hablar con ingeniería", it: "Parla con il team", ar: "تحدث إلى الهندسة", ja: "技術チームへ相談" },
};

const getLabel = (key: string) => labels[key]?.[locale] || labels[key]?.en || key;
---

<PageLayout
  title={seo.seoTitle || "WillowSoft | Embedded Hardware & Industrial IoT Engineering"}
  description={seo.metaDescription || "Embedded hardware and Industrial IoT engineering."}
  canonical={seo.canonical || `https://willowsoft.co/${locale}`}
  locale={locale}
  dataPage="home"
>
  <main>
    <!-- Hero — kinetic type -->
    <section class="hero kinetic-hero">
      <span class="ghost-word" aria-hidden="true">ENGINEERING</span>
      <div class="hero-inner hero-grid">
        <div class="hero-copy-col">
          <p class="eyebrow reveal">{getVal("heroEyebrow")}</p>
          <h1 class="kinetic-title" set:html={getVal("heroTitle")} />
          <div class="hero-foot">
            <p class="hero-lead reveal delay-2">{getVal("heroLead")}</p>
            <div class="hero-ctas reveal delay-3">
              <a class="btn btn-primary" href={`/${locale}/start-project`}>{getLabel("startProject")}</a>
              <a class="btn btn-secondary" href={`/${locale}/services`}>{getLabel("exploreServices")}</a>
            </div>
          </div>
        </div>
        <div class="pcb-stage" aria-label="WillowSoft embedded board, 3D">
          <canvas class="pcb-canvas" aria-hidden="true"></canvas>
          <span class="fig-note pcb-note">FIG. 00 — WILLOWBEE BOARD / SIGNALS LIVE</span>
        </div>
      </div>
    </section>

    <!-- Capability marquee -->
    <div class="marquee marquee-dark" data-speed="30" aria-hidden="true">
      <div class="marquee-track">
        {[0, 1].map(() => (
          <span class="marquee-group">
            <span>Embedded Systems</span><i>/</i>
            <span>LoRaWAN</span><i>/</i>
            <span>Firmware &amp; OTA</span><i>/</i>
            <span>IoT Platforms</span><i>/</i>
            <span>Dashboards</span><i>/</i>
            <span>Mobile &amp; VR</span><i>/</i>
          </span>
        ))}
      </div>
    </div>

    <!-- Hero media band — Three.js liquid distortion -->
    <section class="hero-media-band kinetic-media" aria-label="WillowSoft engineering bench">
      <img src="/assets/hero-industrial-iot.png" alt="Industrial IoT hardware on a lab bench" decoding="async" />
      <span class="fig-note">FIG. 01 — ENGINEERING BENCH / WILLOWBEE · WILLOWAIR · WILLOWMOD</span>
    </section>

    <!-- Proof strip -->
    <section class="section tight proof-strip">
      <div class="section-inner">
        <div class="hero-proof">
          <div class="proof-item reveal">
            <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket}</strong>
            <span>{getLabel("productsOnMarket")}</span>
          </div>
          <div class="proof-item reveal delay-1">
            <strong data-company-fact="happyClients">{companyFacts.happyClients}</strong>
            <span>{getLabel("happyClients")}</span>
          </div>
          <div class="proof-item reveal delay-2">
            <strong>2020</strong>
            <span>{getLabel("founded")}</span>
          </div>
          <div class="proof-item reveal delay-3">
            <strong data-company-fact="officesWorldwide">{companyFacts.officesWorldwide}</strong>
            <span>{getLabel("officesWorldwide")}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Services — editorial ledger -->
    <section class="section ledger-section">
      <div class="section-inner">
        <div class="ledger">
          <a class="ledger-row" href={`/${locale}/services`}>
            <span class="ledger-index">01</span>
            <span class="ledger-title">Embedded</span>
            <span class="ledger-desc">Hardware, firmware, RF and low-power architecture.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
          <a class="ledger-row" href={`/${locale}/services`}>
            <span class="ledger-index">02</span>
            <span class="ledger-title">Platform</span>
            <span class="ledger-desc">Backend APIs, PostgreSQL, dashboards and admin panels.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
          <a class="ledger-row" href={`/${locale}/services`}>
            <span class="ledger-index">03</span>
            <span class="ledger-title">Interfaces</span>
            <span class="ledger-desc">Mobile apps, web portals and product websites.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
          <a class="ledger-row" href={`/${locale}/services`}>
            <span class="ledger-index">04</span>
            <span class="ledger-title">Simulation</span>
            <span class="ledger-desc">VR training, product demos and digital twin views.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Trust Showcase -->
    <section class="trust-showcase" id="trusted-brands" aria-label="Trusted by clients">
      <div class="section-inner trust-layout">
        <div class="trust-copy reveal-left">
          <p class="eyebrow">{getVal("trustEyebrow")}</p>
          <h2 set:html={getVal("trustTitle")} />
          <p>{getVal("trustLead")}</p>
          <div class="trust-more" aria-label="Additional sectors">
            <span>Industrial Automation</span><span>MedTech</span><span>Energy</span><span>Telecom</span><span>Smart Logistics</span>
          </div>
        </div>
      </div>
      <div class="marquee logo-marquee" data-speed="36" data-cms-clients>
        <div class="marquee-track">
          {[0, 1].map(() => (
            <span class="marquee-group">
              {featuredClients.map((client: any) => (
                <span class="logo-tile" title={client.name}>
                  {client.logo ? <img src={`/${client.logo}`} alt={client.name} loading="lazy" decoding="async" /> : <strong>{client.name}</strong>}
                </span>
              ))}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Ecosystem — sticky stack theatre -->
    <section class="stack-section" id="ecosystem">
      <div class="section-inner stack-head reveal">
        <p class="eyebrow">{getVal("ecosystemEyebrow")}</p>
        <h2 set:html={getVal("ecosystemTitle")} />
        <p class="section-lead">Each layer is planned against the next one, so field telemetry becomes useful operational software instead of isolated device data.</p>
      </div>
      <div class="stack-panels">
        <article class="stack-panel stack-navy">
          <div class="stack-panel-inner">
            <span class="stack-index">01</span>
            <h3>Hardware</h3>
            <p>Custom PCB, sensors, power architecture.</p>
          </div>
        </article>
        <article class="stack-panel stack-paper">
          <div class="stack-panel-inner">
            <span class="stack-index">02</span>
            <h3>Firmware</h3>
            <p>RTOS, OTA, protocols, low-power logic.</p>
          </div>
        </article>
        <article class="stack-panel stack-cyan">
          <div class="stack-panel-inner">
            <span class="stack-index">03</span>
            <h3>Connectivity</h3>
            <p>LoRaWAN, BLE, Wi-Fi, RF optimization.</p>
          </div>
        </article>
        <article class="stack-panel stack-amber">
          <div class="stack-panel-inner">
            <span class="stack-index">04</span>
            <h3>Backend</h3>
            <p>APIs, PostgreSQL, auth, integrations.</p>
          </div>
        </article>
        <article class="stack-panel stack-deep">
          <div class="stack-panel-inner">
            <span class="stack-index">05</span>
            <h3>Interfaces</h3>
            <p>Mobile apps, dashboards, admin panels, VR.</p>
          </div>
        </article>
      </div>
    </section>

    <!-- Featured Products — pinned horizontal gallery -->
    <section class="hgallery" data-cms-featured-products>
      <div class="hgallery-pin">
        <div class="section-inner hgallery-head reveal">
          <div>
            <p class="eyebrow">{getVal("productsEyebrow")}</p>
            <h2 set:html={getVal("productsTitle")} />
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/products`}>{getLabel("viewProducts")}</a>
        </div>
        <div class="hgallery-track">
          {featuredProducts.map((p: any, idx: number) => (
            <article class="hplate">
              <span class="hplate-index" aria-hidden="true">0{idx + 1}</span>
              <figure>
                <img src={p.cardImage || `/assets/product-cutouts/${p.id}.png`} alt={p.title} loading="lazy" decoding="async" />
              </figure>
              <div class="hplate-body">
                <h3>{p.title}</h3>
                <p>{p.shortDescription}</p>
                <a class="hplate-link" href={`/${locale}/products/${encodeURIComponent(p.slug || p.id)}`}>
                  Explore <span aria-hidden="true">↗</span>
                </a>
              </div>
            </article>
          ))}
          <article class="hplate hplate-cta">
            <a href={`/${locale}/products`}>
              <span>{getLabel("viewProducts")}</span>
              <span aria-hidden="true">↗</span>
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- Industries — editorial index -->
    <section class="section soft industries-section">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{getVal("industriesEyebrow")}</p>
          <h2 set:html={getVal("industriesTitle")} />
        </div>
        <div class="ledger ledger-compact">
          <a class="ledger-row" href={`/${locale}/solutions`}>
            <span class="ledger-index">A</span>
            <span class="ledger-title">Smart <em class="hw-serif">Infrastructure</em></span>
            <span class="ledger-desc">Flood levels, water tanks, smart lighting and public utility monitoring.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
          <a class="ledger-row" href={`/${locale}/solutions`}>
            <span class="ledger-index">B</span>
            <span class="ledger-title">Industrial <em class="hw-serif">Monitoring</em></span>
            <span class="ledger-desc">Machine data, Modbus devices, factories, warehouses and energy systems.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
          <a class="ledger-row" href={`/${locale}/solutions`}>
            <span class="ledger-index">C</span>
            <span class="ledger-title">MedTech &amp; <em class="hw-serif">Healthcare</em></span>
            <span class="ledger-desc">Low-power sensor nodes for environmental and patient-adjacent monitoring.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
          <a class="ledger-row" href={`/${locale}/solutions`}>
            <span class="ledger-index">D</span>
            <span class="ledger-title">Logistics &amp; <em class="hw-serif">Telecoms</em></span>
            <span class="ledger-desc">Asset tracking, GNSS, and field-connected devices for mobile operations.</span>
            <span class="ledger-arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- News — editorial spread -->
    <section class="section news-spread-section" data-cms-news>
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("newsEyebrow")}</p>
            <h2 set:html={getVal("newsTitle")} />
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/news`}>{getLabel("viewNews")}</a>
        </div>
        <div class="news-spread">
          {featureNews && (
            <a class="news-feature reveal" href={`/${locale}/news/${encodeURIComponent(featureNews.slug || featureNews.id)}`}>
              {featureNews.image && (
                <figure class="kinetic-media">
                  <img src={featureNews.image} alt={featureNews.title} loading="lazy" decoding="async" />
                </figure>
              )}
              <div class="news-feature-body">
                <span class="news-meta">{featureNews.category}{featureNews.date ? ` — ${featureNews.date}` : ""}</span>
                <h3>{featureNews.title}</h3>
                <p>{featureNews.excerpt}</p>
              </div>
            </a>
          )}
          <div class="news-side ledger ledger-compact">
            {sideNews.map((n: any) => (
              <a class="ledger-row" href={`/${locale}/news/${encodeURIComponent(n.slug || n.id)}`}>
                <span class="ledger-index news-meta">{n.date || n.category}</span>
                <span class="ledger-title">{n.title}</span>
                <span class="ledger-arrow" aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section dark final-cta">
      <span class="ghost-word" aria-hidden="true">BUILD</span>
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getVal("ctaEyebrow")}</p>
          <h2 class="page-title" set:html={getVal("ctaTitle")} />
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{getVal("ctaLead")}</p>
          <div class="cta-choice-grid" aria-label="Common project starting points">
            <span>Hardware + Firmware</span><span>Backend + PostgreSQL</span><span>Web, Mobile + VR</span>
          </div>
          <p><a class="btn btn-primary" href={`/${locale}/contact`}>{getLabel("talkEngineering")}</a></p>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

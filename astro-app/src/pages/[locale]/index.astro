---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import NewsCard from "@/components/NewsCard.astro";
import { loadContent } from "@/lib/content";
import { localizedValue, locales, type Locale } from "@/lib/cms";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const content = loadContent();
const pageContent = content.pageContent?.home || {};
const companyFacts = content.companyFacts || {};
const seo = content.pageSeo?.home?.[locale] || {};

const getVal = (key: string) => localizedValue(pageContent[key], locale);

const featuredProducts = (content.products || []).filter((p: any) => p.featured).slice(0, 4);
const latestNews = (content.news || []).slice(0, 3);
const featuredClients = (content.clients || [])
  .filter((c: any) => c.featured)
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

const labels: Record<string, Record<string, string>> = {
  productsOnMarket: { en: "Products on market", tr: "Piyasadaki ürünler", de: "Produkte am Markt", fr: "Produits sur le marché", es: "Productos en el mercado", it: "Prodotti sul mercato", ar: "منتج في السوق", ja: "市場実績製品" },
  happyClients: { en: "Happy clients", tr: "Mutlu müşteriler", de: "Zufriedene Kunden", fr: "Clients satisfaits", es: "Clientes satisfechos", it: "Clienti felici", ar: "عميل سعيد", ja: "取引先企業数" },
  founded: { en: "Founded", tr: "Kuruluş", de: "Gegründet", fr: "Fondation", es: "Fundación", it: "Fondazione", ar: "تأسست عام", ja: "設立年" },
  officesWorldwide: { en: "Offices worldwide", tr: "Dünya çapında ofis", de: "Büros weltweit", fr: "Bureaux dans le monde", es: "Oficinas en el mundo", it: "Uffici nel mondo", ar: "مكتب حول العالم", ja: "拠点数" },
  exploreServices: { en: "Explore Services", tr: "Hizmetleri Keşfet", de: "Dienste erkunden", fr: "Découvrir les services", es: "Explorar servicios", it: "Esplora i servizi", ar: "استكشف الخدمات", ja: "提供サービスを見る" },
  startProject: { en: "Start Your Project", tr: "Projeye Başla", de: "Projekt starten", fr: "Démarrer un projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "ابدأ مشروعًا", ja: "プロジェクトを開始" },
  viewProducts: { en: "Browse Products", tr: "Ürünlere Göz At", de: "Produkte durchsuchen", fr: "Parcourir les produits", es: "Ver productos", it: "Sfoglia i prodotti", ar: "تصفح المنتجات", ja: "製品カタログを見る" },
  viewNews: { en: "View News", tr: "Haberleri Görüntüle", de: "News anzeigen", fr: "Voir les actualités", es: "Ver noticias", it: "Vedi le news", ar: "عرض الأخبار", ja: "ニュースを見る" },
  talkEngineering: { en: "Talk to Engineering", tr: "Mühendislerimizle Görüşün", de: "Mit Engineering sprechen", fr: "Parler à l'ingénierie", es: "Hablar con ingeniería", it: "Parla con il team", ar: "تحدث إلى الهندسة", ja: "技術チームへ相談" },
};

const getLabel = (key: string) => labels[key]?.[locale] || labels[key]?.en || key;
---

<PageLayout
  title={seo.seoTitle || "WillowSoft | Embedded Hardware & Industrial IoT Engineering"}
  description={seo.metaDescription || "Embedded hardware and Industrial IoT engineering."}
  canonical={seo.canonical || `https://willowsoft.co/${locale}`}
  locale={locale}
  dataPage="home"
>
  <main>
    <!-- Hero -->
    <section class="hero motion-hero">
      <div class="hero-media">
        <img src="/assets/hero-industrial-iot.png" alt="Industrial IoT hardware on a lab bench" loading="lazy" decoding="async" />
      </div>
      <canvas class="hero-shader-canvas" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></canvas>
      <canvas class="signal-canvas" data-density="42" data-color="75, 87, 170"></canvas>
      <div class="hero-inner hero-layout">
        <div class="hero-copy">
          <p class="eyebrow reveal">{getVal("heroEyebrow")}</p>
          <h1 class="reveal delay-1" set:html={getVal("heroTitle")} />
          <p class="reveal delay-2">{getVal("heroLead")}</p>
          <div class="hero-ctas reveal delay-3">
            <a class="btn btn-primary" href={`/${locale}/start-project`}>{getLabel("startProject")}</a>
            <a class="btn btn-secondary" href={`/${locale}/services`}>{getLabel("exploreServices")}</a>
          </div>
          <div class="hero-proof reveal delay-4">
            <div class="proof-item">
              <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket}</strong>
              <span>{getLabel("productsOnMarket")}</span>
            </div>
            <div class="proof-item">
              <strong data-company-fact="happyClients">{companyFacts.happyClients}</strong>
              <span>{getLabel("happyClients")}</span>
            </div>
            <div class="proof-item">
              <strong>2020</strong>
              <span>{getLabel("founded")}</span>
            </div>
            <div class="proof-item">
              <strong data-company-fact="officesWorldwide">{companyFacts.officesWorldwide}</strong>
              <span>{getLabel("officesWorldwide")}</span>
            </div>
          </div>
        </div>

        <aside class="hero-product-stage reveal delay-2" aria-label="WillowSoft hardware showcase">
          <div class="product-spotlight"></div>
          <article class="floating-product product-one" style="--delay:0ms">
            <figure><img src="/pdf-assets/p06_01_X13.jpg" alt="WillowBee LoRaWAN module" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowBee</strong><span>Compact LoRaWAN MCU module</span></div>
          </article>
          <article class="floating-product product-two" style="--delay:180ms">
            <figure><img src="/pdf-assets/p08_01_X22.jpg" alt="WillowAir sensor" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowAir</strong><span>Indoor air quality monitoring</span></div>
          </article>
          <article class="floating-product product-three" style="--delay:360ms">
            <figure><img src="/pdf-assets/p14_01_X50.jpg" alt="WillowMod sensor" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowMod</strong><span>Wireless Modbus integration</span></div>
          </article>
        </aside>
      </div>
    </section>

    <!-- Service Rail -->
    <section class="section tight">
      <div class="section-inner">
        <div class="service-rail reveal">
          <article><span class="service-number">01</span><h3>Embedded</h3><p>Hardware, firmware, RF and low-power architecture.</p></article>
          <article><span class="service-number">02</span><h3>Platform</h3><p>Backend APIs, PostgreSQL, dashboards and admin panels.</p></article>
          <article><span class="service-number">03</span><h3>Interfaces</h3><p>Mobile apps, web portals and product websites.</p></article>
          <article><span class="service-number">04</span><h3>Simulation</h3><p>VR training, product demos and digital twin views.</p></article>
        </div>
      </div>
    </section>

    <!-- Trust Showcase -->
    <section class="trust-showcase" id="trusted-brands" aria-label="Trusted by clients">
      <div class="section-inner trust-layout">
        <div class="trust-copy reveal-left">
          <p class="eyebrow">{getVal("trustEyebrow")}</p>
          <h2 set:html={getVal("trustTitle")} />
          <p>{getVal("trustLead")}</p>
          <div class="trust-more" aria-label="Additional sectors">
            <span>Industrial Automation</span><span>MedTech</span><span>Energy</span><span>Telecom</span><span>Smart Logistics</span>
          </div>
        </div>
        <div class="trust-stage reveal-right delay-1">
          <div class="trust-mark"><img src="/pdf-assets/p01_01_X0.jpg" alt="WillowSoft mark" loading="lazy" decoding="async" /></div>
          <div class="logo-cloud" data-cms-clients>
            {featuredClients.map((client: any, idx: number) => {
              const depths = [18, 54, 28, 42, 12, 66, 36, 24];
              const z = depths[idx % depths.length];
              const delay = idx * 130;
              return (
                <div class="logo-tile" style={`--z:${z}px;--delay:${delay}ms`} title={client.name}>
                  {client.logo ? <img src={`/${client.logo}`} alt={client.name} loading="lazy" decoding="async" /> : <strong>{client.name}</strong>}
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Ecosystem -->
    <section class="section dark ecosystem-section">
      <canvas class="signal-canvas" data-density="34" data-color="91, 166, 91"></canvas>
      <div class="section-inner">
        <div class="section-head center reveal">
          <p class="eyebrow">{getVal("ecosystemEyebrow")}</p>
          <h2 set:html={getVal("ecosystemTitle")} />
          <p class="section-lead">Each layer is planned against the next one, so field telemetry becomes useful operational software instead of isolated device data.</p>
        </div>
        <div class="tech-flow reveal delay-1">
          <div class="flow-row">
            <div class="flow-node"><small>01</small><strong>Hardware</strong><span>Custom PCB, sensors, power architecture.</span></div>
            <div class="flow-node"><small>02</small><strong>Firmware</strong><span>RTOS, OTA, protocols, low-power logic.</span></div>
            <div class="flow-node"><small>03</small><strong>Connectivity</strong><span>LoRaWAN, BLE, Wi-Fi, RF optimization.</span></div>
            <div class="flow-node"><small>04</small><strong>Backend</strong><span>APIs, PostgreSQL, auth, integrations.</span></div>
            <div class="flow-node"><small>05</small><strong>Interfaces</strong><span>Mobile apps, dashboards, admin panels, VR.</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="section home-products">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("productsEyebrow")}</p>
            <h2 set:html={getVal("productsTitle")} />
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/products`}>{getLabel("viewProducts")}</a>
        </div>
        <div class="grid grid-4" data-cms-featured-products>
          {featuredProducts.map((p: any, idx: number) => (
            <ProductCard product={p} locale={locale} index={idx} />
          ))}
        </div>
      </div>
    </section>

    <!-- Industries -->
    <section class="section soft industries-section">
      <div class="section-inner">
        <div class="section-head center reveal">
          <p class="eyebrow">{getVal("industriesEyebrow")}</p>
          <h2 set:html={getVal("industriesTitle")} />
        </div>
        <div class="industry-lanes">
          <article class="industry-lane reveal"><div class="industry-lane-icon" aria-hidden="true">🏙️</div><h3>Smart Infrastructure</h3><p>Flood levels, water tanks, smart lighting and public utility monitoring.</p></article>
          <article class="industry-lane reveal delay-1"><div class="industry-lane-icon" aria-hidden="true">⚙️</div><h3>Industrial Monitoring</h3><p>Machine data, Modbus devices, factories, warehouses and energy systems.</p></article>
          <article class="industry-lane reveal delay-2"><div class="industry-lane-icon" aria-hidden="true">🩺</div><h3>MedTech &amp; Healthcare</h3><p>Low-power sensor nodes for environmental and patient-adjacent monitoring.</p></article>
          <article class="industry-lane reveal delay-3"><div class="industry-lane-icon" aria-hidden="true">📦</div><h3>Logistics &amp; Telecoms</h3><p>Asset tracking, GNSS, and field-connected devices for mobile operations.</p></article>
        </div>
      </div>
    </section>

    <!-- News -->
    <section class="section proof-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("newsEyebrow")}</p>
            <h2 set:html={getVal("newsTitle")} />
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/news`}>{getLabel("viewNews")}</a>
        </div>
        <div class="grid grid-3" data-cms-news>
          {latestNews.map((n: any, idx: number) => (
            <NewsCard item={n} locale={locale} index={idx} />
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section dark final-cta">
      <canvas class="signal-canvas" data-density="26" data-color="215, 154, 43"></canvas>
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getVal("ctaEyebrow")}</p>
          <h2 class="page-title" set:html={getVal("ctaTitle")} />
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{getVal("ctaLead")}</p>
          <div class="cta-choice-grid" aria-label="Common project starting points">
            <span>Hardware + Firmware</span><span>Backend + PostgreSQL</span><span>Web, Mobile + VR</span>
          </div>
          <p><a class="btn btn-primary" href={`/${locale}/contact`}>{getLabel("talkEngineering")}</a></p>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

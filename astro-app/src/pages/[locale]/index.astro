---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import NewsCard from "@/components/NewsCard.astro";
import FaqAccordion from "@/components/FaqAccordion.astro";
import AIAnswerBlock from "@/components/AIAnswerBlock.astro";
import { loadContent } from "@/lib/content";
import { pageSeo, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA } from "@/lib/seo";
import { localizedValue, locales, type Locale } from "@/lib/cms";
import { aiAnswerForPage, aiMetaForPage, appendSchemaNodes, fallbackFaqsForPage, faqItemsForPage, faqSchemaNode } from "@/lib/ai-search";

export const prerender = false;

const { locale } = Astro.params as { locale: Locale };
const content = await loadContent();
const pageContent = content.pageContent?.home || {};
const companyFacts = content.companyFacts || {};
const seoProps = pageSeo(content, "home", locale, "", "WillowSoft | Embedded Hardware & Industrial IoT Engineering", "Embedded hardware and Industrial IoT engineering.");

const getVal = (key: string) => localizedValue(pageContent[key], locale);
const homeFallbackFaqs = fallbackFaqsForPage("home", locale);
const homeFaqItems = faqItemsForPage(content.faqs || [], "home", locale, homeFallbackFaqs);
const aiAnswer = aiAnswerForPage(content, "home", locale, seoProps.description);
const aiMeta = aiMetaForPage(content, "home", locale);

const featuredProducts = (content.products || []).filter((p: any) => p.featured).slice(0, 4);
const latestNews = (content.news || []).slice(0, 3);
const featuredClients = (content.clients || [])
  .filter((c: any) => c.featured)
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

const labels: Record<string, Record<string, string>> = {
  productsOnMarket: { en: "Products on market", tr: "Piyasadaki ürünler", de: "Produkte am Markt", fr: "Produits sur le marché", es: "Productos en el mercado", it: "Prodotti sul mercato", ar: "منتج في السوق", ja: "市場実績製品" },
  happyClients: { en: "Happy clients", tr: "Mutlu müşteriler", de: "Zufriedene Kunden", fr: "Clients satisfaits", es: "Clientes satisfechos", it: "Clienti felici", ar: "عميل سعيد", ja: "取引先企業数" },
  founded: { en: "Founded", tr: "Kuruluş", de: "Gegründet", fr: "Fondation", es: "Fundación", it: "Fondazione", ar: "تأسست عام", ja: "設立年" },
  officesWorldwide: { en: "Offices worldwide", tr: "Dünya çapında ofis", de: "Büros weltweit", fr: "Bureaux dans le monde", es: "Oficinas en el mundo", it: "Uffici nel mondo", ar: "مكتب حول العالم", ja: "拠点数" },
  exploreServices: { en: "Explore Services", tr: "Hizmetleri Keşfet", de: "Dienste erkunden", fr: "Découvrir les services", es: "Explorar servicios", it: "Esplora i servizi", ar: "استكشف الخدمات", ja: "提供サービスを見る" },
  startProject: { en: "Start Your Project", tr: "Projeye Başla", de: "Projekt starten", fr: "Démarrer un projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "ابدأ مشروعًا", ja: "プロジェクトを開始" },
  viewProducts: { en: "Browse Products", tr: "Ürünlere Göz At", de: "Produkte durchsuchen", fr: "Parcourir les produits", es: "Ver productos", it: "Sfoglia i prodotti", ar: "تصفح المنتجات", ja: "製品カタログを見る" },
  viewNews: { en: "View News", tr: "Haberleri Görüntüle", de: "News anzeigen", fr: "Voir les actualités", es: "Ver noticias", it: "Vedi le news", ar: "عرض الأخبار", ja: "ニュースを見る" },
  talkEngineering: { en: "Talk to Engineering", tr: "Mühendislerimizle Görüşün", de: "Mit Engineering sprechen", fr: "Parler à l'ingénierie", es: "Hablar con ingeniería", it: "Parla con il team", ar: "تحدث إلى الهندسة", ja: "技術チームへ相談" },
};

const getLabel = (key: string) => labels[key]?.[locale] || labels[key]?.en || key;

type L10n = Record<string, string>;
const loc = (m: L10n) => m[locale] || m.en;

const serviceRail: { title: L10n; desc: L10n }[] = [
  {
    title: { en: "Embedded", tr: "Gömülü Sistemler", de: "Embedded", fr: "Embarqué", es: "Embebido", it: "Embedded", ar: "الأنظمة المدمجة", ja: "組み込み" },
    desc: { en: "Hardware, firmware, RF and low-power architecture.", tr: "Donanım, gömülü yazılım, RF ve düşük güç mimarisi.", de: "Hardware, Firmware, HF und Low-Power-Architektur.", fr: "Matériel, firmware, RF et architecture basse consommation.", es: "Hardware, firmware, RF y arquitectura de bajo consumo.", it: "Hardware, firmware, RF e architettura a basso consumo.", ar: "العتاد والبرامج الثابتة والترددات اللاسلكية وبنية الطاقة المنخفضة.", ja: "ハードウェア、ファームウェア、RF、低消費電力設計。" },
  },
  {
    title: { en: "Platform", tr: "Platform", de: "Plattform", fr: "Plateforme", es: "Plataforma", it: "Piattaforma", ar: "المنصة", ja: "プラットフォーム" },
    desc: { en: "Backend APIs, PostgreSQL, dashboards and admin panels.", tr: "Backend API'ler, PostgreSQL, kontrol panelleri ve yönetim ekranları.", de: "Backend-APIs, PostgreSQL, Dashboards und Admin-Panels.", fr: "API backend, PostgreSQL, tableaux de bord et panneaux d'administration.", es: "APIs de backend, PostgreSQL, paneles de control y administración.", it: "API backend, PostgreSQL, dashboard e pannelli di amministrazione.", ar: "واجهات برمجة خلفية وPostgreSQL ولوحات تحكم وإدارة.", ja: "バックエンドAPI、PostgreSQL、ダッシュボード、管理画面。" },
  },
  {
    title: { en: "Interfaces", tr: "Arayüzler", de: "Schnittstellen", fr: "Interfaces", es: "Interfaces", it: "Interfacce", ar: "الواجهات", ja: "インターフェース" },
    desc: { en: "Mobile apps, web portals and product websites.", tr: "Mobil uygulamalar, web portalları ve ürün siteleri.", de: "Mobile Apps, Webportale und Produkt-Websites.", fr: "Applications mobiles, portails web et sites produits.", es: "Aplicaciones móviles, portales web y sitios de producto.", it: "App mobili, portali web e siti di prodotto.", ar: "تطبيقات الجوال وبوابات الويب ومواقع المنتجات.", ja: "モバイルアプリ、Webポータル、製品サイト。" },
  },
  {
    title: { en: "Simulation", tr: "Simülasyon", de: "Simulation", fr: "Simulation", es: "Simulación", it: "Simulazione", ar: "المحاكاة", ja: "シミュレーション" },
    desc: { en: "VR training, product demos and digital twin views.", tr: "VR eğitimleri, ürün demoları ve dijital ikiz görünümleri.", de: "VR-Training, Produktdemos und Digital-Twin-Ansichten.", fr: "Formation VR, démos produits et vues de jumeau numérique.", es: "Entrenamiento VR, demos de producto y vistas de gemelo digital.", it: "Formazione VR, demo di prodotto e viste digital twin.", ar: "تدريب الواقع الافتراضي وعروض المنتجات والتوأم الرقمي.", ja: "VRトレーニング、製品デモ、デジタルツイン。" },
  },
];

const trustChips: L10n[] = [
  { en: "Industrial Automation", tr: "Endüstriyel Otomasyon", de: "Industrieautomation", fr: "Automatisation industrielle", es: "Automatización industrial", it: "Automazione industriale", ar: "الأتمتة الصناعية", ja: "産業オートメーション" },
  { en: "MedTech", tr: "MedTech", de: "MedTech", fr: "MedTech", es: "MedTech", it: "MedTech", ar: "التقنية الطبية", ja: "医療技術" },
  { en: "Energy", tr: "Enerji", de: "Energie", fr: "Énergie", es: "Energía", it: "Energia", ar: "الطاقة", ja: "エネルギー" },
  { en: "Telecom", tr: "Telekom", de: "Telekom", fr: "Télécoms", es: "Telecom", it: "Telecom", ar: "الاتصالات", ja: "通信" },
  { en: "Smart Logistics", tr: "Akıllı Lojistik", de: "Smarte Logistik", fr: "Logistique intelligente", es: "Logística inteligente", it: "Logistica intelligente", ar: "اللوجستيات الذكية", ja: "スマート物流" },
];

const ecosystemLead: L10n = {
  en: "Each layer is planned against the next one, so field telemetry becomes useful operational software instead of isolated device data.",
  tr: "Her katman bir sonrakiyle birlikte planlanır; böylece saha telemetrisi izole cihaz verisi yerine işe yarayan operasyonel yazılıma dönüşür.",
  de: "Jede Ebene wird mit Blick auf die nächste geplant, damit Feldtelemetrie zu nützlicher Betriebssoftware statt isolierter Gerätedaten wird.",
  fr: "Chaque couche est conçue en fonction de la suivante, afin que la télémétrie de terrain devienne un logiciel opérationnel utile plutôt que des données isolées.",
  es: "Cada capa se planifica junto con la siguiente, para que la telemetría de campo se convierta en software operativo útil en lugar de datos aislados.",
  it: "Ogni livello è progettato in funzione del successivo, così la telemetria sul campo diventa software operativo utile invece di dati isolati.",
  ar: "يُخطط كل مستوى مع المستوى التالي، لتتحول بيانات القياس الميدانية إلى برمجيات تشغيلية مفيدة بدلاً من بيانات معزولة.",
  ja: "各レイヤーは次のレイヤーを見据えて設計され、フィールドのテレメトリーが孤立したデータではなく実用的な運用ソフトウェアになります。",
};

const flowNodes: { title: L10n; desc: L10n }[] = [
  {
    title: { en: "Hardware", tr: "Donanım", de: "Hardware", fr: "Matériel", es: "Hardware", it: "Hardware", ar: "العتاد", ja: "ハードウェア" },
    desc: { en: "Custom PCB, sensors, power architecture.", tr: "Özel PCB, sensörler, güç mimarisi.", de: "Custom-PCB, Sensoren, Stromarchitektur.", fr: "PCB sur mesure, capteurs, architecture d'alimentation.", es: "PCB a medida, sensores, arquitectura de energía.", it: "PCB su misura, sensori, architettura di alimentazione.", ar: "لوحات PCB مخصصة ومستشعرات وبنية الطاقة.", ja: "カスタムPCB、センサー、電源設計。" },
  },
  {
    title: { en: "Firmware", tr: "Gömülü Yazılım", de: "Firmware", fr: "Firmware", es: "Firmware", it: "Firmware", ar: "البرامج الثابتة", ja: "ファームウェア" },
    desc: { en: "RTOS, OTA, protocols, low-power logic.", tr: "RTOS, OTA, protokoller, düşük güç mantığı.", de: "RTOS, OTA, Protokolle, Low-Power-Logik.", fr: "RTOS, OTA, protocoles, logique basse consommation.", es: "RTOS, OTA, protocolos, lógica de bajo consumo.", it: "RTOS, OTA, protocolli, logica a basso consumo.", ar: "RTOS وتحديثات OTA والبروتوكولات ومنطق الطاقة المنخفضة.", ja: "RTOS、OTA、プロトコル、低消費電力ロジック。" },
  },
  {
    title: { en: "Connectivity", tr: "Bağlantı", de: "Konnektivität", fr: "Connectivité", es: "Conectividad", it: "Connettività", ar: "الاتصال", ja: "コネクティビティ" },
    desc: { en: "LoRaWAN, BLE, Wi-Fi, RF optimization.", tr: "LoRaWAN, BLE, Wi-Fi, RF optimizasyonu.", de: "LoRaWAN, BLE, WLAN, HF-Optimierung.", fr: "LoRaWAN, BLE, Wi-Fi, optimisation RF.", es: "LoRaWAN, BLE, Wi-Fi, optimización RF.", it: "LoRaWAN, BLE, Wi-Fi, ottimizzazione RF.", ar: "LoRaWAN وBLE وWi-Fi وتحسين الترددات.", ja: "LoRaWAN、BLE、Wi-Fi、RF最適化。" },
  },
  {
    title: { en: "Backend", tr: "Backend", de: "Backend", fr: "Backend", es: "Backend", it: "Backend", ar: "الخلفية", ja: "バックエンド" },
    desc: { en: "APIs, PostgreSQL, auth, integrations.", tr: "API'ler, PostgreSQL, kimlik doğrulama, entegrasyonlar.", de: "APIs, PostgreSQL, Auth, Integrationen.", fr: "API, PostgreSQL, authentification, intégrations.", es: "APIs, PostgreSQL, autenticación, integraciones.", it: "API, PostgreSQL, autenticazione, integrazioni.", ar: "واجهات برمجة وPostgreSQL ومصادقة وتكاملات.", ja: "API、PostgreSQL、認証、外部連携。" },
  },
  {
    title: { en: "Interfaces", tr: "Arayüzler", de: "Schnittstellen", fr: "Interfaces", es: "Interfaces", it: "Interfacce", ar: "الواجهات", ja: "インターフェース" },
    desc: { en: "Mobile apps, dashboards, admin panels, VR.", tr: "Mobil uygulamalar, kontrol panelleri, yönetim ekranları, VR.", de: "Mobile Apps, Dashboards, Admin-Panels, VR.", fr: "Applications mobiles, tableaux de bord, panneaux d'administration, VR.", es: "Aplicaciones móviles, paneles de control, administración, VR.", it: "App mobili, dashboard, pannelli admin, VR.", ar: "تطبيقات الجوال ولوحات التحكم ولوحات الإدارة والواقع الافتراضي.", ja: "モバイルアプリ、ダッシュボード、管理画面、VR。" },
  },
];

const industryLanes: { icon: string; title: L10n; desc: L10n }[] = [
  {
    icon: "🏙️",
    title: { en: "Smart Infrastructure", tr: "Akıllı Altyapı", de: "Smarte Infrastruktur", fr: "Infrastructures intelligentes", es: "Infraestructura inteligente", it: "Infrastrutture intelligenti", ar: "البنية التحتية الذكية", ja: "スマートインフラ" },
    desc: { en: "Flood levels, water tanks, smart lighting and public utility monitoring.", tr: "Taşkın seviyeleri, su depoları, akıllı aydınlatma ve kamu hizmeti izleme.", de: "Hochwasserpegel, Wassertanks, intelligente Beleuchtung und Überwachung öffentlicher Versorgung.", fr: "Niveaux de crue, réservoirs d'eau, éclairage intelligent et suivi des services publics.", es: "Niveles de inundación, tanques de agua, alumbrado inteligente y monitoreo de servicios públicos.", it: "Livelli di piena, serbatoi d'acqua, illuminazione intelligente e monitoraggio dei servizi pubblici.", ar: "مستويات الفيضانات وخزانات المياه والإنارة الذكية ومراقبة المرافق العامة.", ja: "洪水水位、貯水タンク、スマート照明、公共インフラの監視。" },
  },
  {
    icon: "⚙️",
    title: { en: "Industrial Monitoring", tr: "Endüstriyel İzleme", de: "Industrielle Überwachung", fr: "Surveillance industrielle", es: "Monitoreo industrial", it: "Monitoraggio industriale", ar: "المراقبة الصناعية", ja: "産業モニタリング" },
    desc: { en: "Machine data, Modbus devices, factories, warehouses and energy systems.", tr: "Makine verileri, Modbus cihazları, fabrikalar, depolar ve enerji sistemleri.", de: "Maschinendaten, Modbus-Geräte, Fabriken, Lager und Energiesysteme.", fr: "Données machines, équipements Modbus, usines, entrepôts et systèmes énergétiques.", es: "Datos de máquinas, dispositivos Modbus, fábricas, almacenes y sistemas de energía.", it: "Dati macchina, dispositivi Modbus, fabbriche, magazzini e sistemi energetici.", ar: "بيانات الآلات وأجهزة Modbus والمصانع والمستودعات وأنظمة الطاقة.", ja: "機械データ、Modbus機器、工場、倉庫、エネルギーシステム。" },
  },
  {
    icon: "🩺",
    title: { en: "MedTech & Healthcare", tr: "MedTech ve Sağlık", de: "MedTech & Gesundheit", fr: "MedTech & Santé", es: "MedTech y Salud", it: "MedTech e Sanità", ar: "التقنية الطبية والرعاية الصحية", ja: "医療・ヘルスケア" },
    desc: { en: "Low-power sensor nodes for environmental and patient-adjacent monitoring.", tr: "Çevresel ve hasta yakını izleme için düşük güçlü sensör düğümleri.", de: "Low-Power-Sensorknoten für Umgebungs- und patientennahe Überwachung.", fr: "Capteurs basse consommation pour la surveillance environnementale et proche du patient.", es: "Nodos sensores de bajo consumo para monitoreo ambiental y cercano al paciente.", it: "Nodi sensore a basso consumo per il monitoraggio ambientale e in prossimità del paziente.", ar: "عقد استشعار منخفضة الطاقة للمراقبة البيئية والمحيطة بالمريض.", ja: "環境および患者周辺モニタリング向けの低消費電力センサーノード。" },
  },
  {
    icon: "📦",
    title: { en: "Logistics & Telecoms", tr: "Lojistik ve Telekom", de: "Logistik & Telekom", fr: "Logistique & Télécoms", es: "Logística y Telecomunicaciones", it: "Logistica e Telecomunicazioni", ar: "اللوجستيات والاتصالات", ja: "物流・通信" },
    desc: { en: "Asset tracking, GNSS, and field-connected devices for mobile operations.", tr: "Varlık takibi, GNSS ve mobil operasyonlar için sahaya bağlı cihazlar.", de: "Asset-Tracking, GNSS und feldvernetzte Geräte für mobile Einsätze.", fr: "Suivi d'actifs, GNSS et appareils connectés pour les opérations mobiles.", es: "Seguimiento de activos, GNSS y dispositivos conectados para operaciones móviles.", it: "Tracciamento asset, GNSS e dispositivi connessi per operazioni mobili.", ar: "تتبع الأصول وGNSS وأجهزة ميدانية متصلة للعمليات المتنقلة.", ja: "資産追跡、GNSS、移動オペレーション向けフィールド接続デバイス。" },
  },
];

const homeSchema = appendSchemaNodes({
  "@context": "https://schema.org",
  "@graph": [ORGANIZATION_SCHEMA, WEBSITE_SCHEMA],
}, [faqSchemaNode(seoProps.canonical, homeFaqItems)]);
---

<PageLayout
  {...seoProps}
  schema={homeSchema}
  locale={locale}
  dataPage="home"
>
  <main id="main-content">
    <!-- Hero -->
    <section class="hero motion-hero">
      <div class="hero-media">
        <img src={`${import.meta.env.BASE_URL}assets/hero-industrial-iot.png`} alt="Industrial IoT hardware on a lab bench" loading="lazy" decoding="async" />
      </div>
      <canvas class="hero-shader-canvas" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></canvas>
      <canvas class="signal-canvas" data-density="42" data-color="75, 87, 170"></canvas>
      <div class="hero-inner hero-layout">
        <div class="hero-copy">
          <p class="eyebrow reveal">{getVal("heroEyebrow")}</p>
          <h1 class="reveal delay-1" set:html={getVal("heroTitle") || "From <span class='serif-accent'>bare metal</span> to <span class='hw-display'>dashboard</span> — without fragmented vendors."} />
          <p class="reveal delay-2">{getVal("heroLead")}</p>
          <div class="hero-ctas reveal delay-3">
            <a class="btn btn-primary" href={`/${locale}/start-project`}>{locale === "tr" ? "Projeni Anlat" : getLabel("startProject")}</a>
            <a class="btn btn-secondary" href={`/${locale}/services`}>{getLabel("exploreServices")}</a>
          </div>
          <div class="hero-proof reveal delay-4">
            <div class="proof-item">
              <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket}</strong>
              <span>{getLabel("productsOnMarket")}</span>
            </div>
            <div class="proof-item">
              <strong data-company-fact="happyClients">{companyFacts.happyClients}</strong>
              <span>{getLabel("happyClients")}</span>
            </div>
            <div class="proof-item">
              <strong>2020</strong>
              <span>{getLabel("founded")}</span>
            </div>
            <div class="proof-item">
              <strong data-company-fact="officesWorldwide">{companyFacts.officesWorldwide}</strong>
              <span>{getLabel("officesWorldwide")}</span>
            </div>
          </div>
        </div>

        <aside class="hero-product-stage reveal delay-2" aria-label="WillowSoft hardware showcase">
          <div class="product-spotlight"></div>
          <article class="floating-product product-one" style="--delay:0ms">
            <figure><img src={`${import.meta.env.BASE_URL}pdf-assets/p06_01_X13.jpg`} alt="WillowBee LoRaWAN module" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowBee</strong><span>Compact LoRaWAN MCU module</span></div>
          </article>
          <article class="floating-product product-two" style="--delay:180ms">
            <figure><img src={`${import.meta.env.BASE_URL}pdf-assets/p08_01_X22.jpg`} alt="WillowAir sensor" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowAir</strong><span>Indoor air quality monitoring</span></div>
          </article>
          <article class="floating-product product-three" style="--delay:360ms">
            <figure><img src={`${import.meta.env.BASE_URL}pdf-assets/p14_01_X50.jpg`} alt="WillowMod sensor" loading="lazy" decoding="async" /></figure>
            <div><strong>WillowMod</strong><span>Wireless Modbus integration</span></div>
          </article>
        </aside>
      </div>
    </section>

    <!-- Service Rail -->
    <section class="section tight">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
        <div class="service-rail reveal">
          {serviceRail.map((item, idx) => (
            <article><span class="service-number">{String(idx + 1).padStart(2, "0")}</span><h3>{loc(item.title)}</h3><p>{loc(item.desc)}</p></article>
          ))}
        </div>
      </div>
    </section>

    <!-- Trust Showcase -->
    <section class="trust-showcase" id="trusted-brands" aria-label="Trusted by clients">
      <div class="section-inner trust-layout">
        <div class="trust-copy reveal-left">
          <p class="eyebrow">{getVal("trustEyebrow")}</p>
          <h2 set:html={getVal("trustTitle")} />
          <p>{getVal("trustLead")}</p>
          <div class="trust-more" aria-label="Additional sectors">
            {trustChips.map((chip) => <span>{loc(chip)}</span>)}
          </div>
        </div>
        <div class="trust-stage reveal-right delay-1">
          <div class="trust-mark"><img src={`${import.meta.env.BASE_URL}pdf-assets/p01_01_X0.jpg`} alt="WillowSoft mark" loading="lazy" decoding="async" /></div>
          <div class="logo-cloud" data-cms-clients>
            {featuredClients.map((client: any, idx: number) => {
              const depths = [18, 54, 28, 42, 12, 66, 36, 24];
              const z = depths[idx % depths.length];
              const delay = idx * 130;
              return (
                <div class="logo-tile" style={`--z:${z}px;--delay:${delay}ms`} title={client.name}>
                  {client.logo ? <img src={`/${client.logo}`} alt={client.name} loading="lazy" decoding="async" /> : <strong>{client.name}</strong>}
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Ecosystem -->
    <section class="section dark ecosystem-section">
      <canvas class="signal-canvas" data-density="34" data-color="91, 166, 91"></canvas>
      <div class="section-inner">
        <div class="section-head center reveal">
          <p class="eyebrow">{getVal("ecosystemEyebrow")}</p>
          <h2 set:html={getVal("ecosystemTitle")} />
          <p class="section-lead">{loc(ecosystemLead)}</p>
        </div>
        <div class="tech-flow reveal delay-1">
          <div class="flow-row">
            {flowNodes.map((node, idx) => (
              <div class="flow-node"><small>{String(idx + 1).padStart(2, "0")}</small><strong>{loc(node.title)}</strong><span>{loc(node.desc)}</span></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="section home-products">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("productsEyebrow")}</p>
            <h2 set:html={getVal("productsTitle")} />
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/products`}>{getLabel("viewProducts")}</a>
        </div>
        <div class="grid grid-4" data-cms-featured-products>
          {featuredProducts.map((p: any, idx: number) => (
            <ProductCard product={p} locale={locale} index={idx} />
          ))}
        </div>
      </div>
    </section>

    <!-- Industries -->
    <section class="section soft industries-section">
      <div class="section-inner">
        <div class="section-head center reveal">
          <p class="eyebrow">{getVal("industriesEyebrow")}</p>
          <h2 set:html={getVal("industriesTitle")} />
        </div>
        <div class="industry-lanes">
          {industryLanes.map((lane, idx) => (
            <article class={`industry-lane reveal${idx > 0 ? ` delay-${idx}` : ""}`}><div class="industry-lane-icon" aria-hidden="true">{lane.icon}</div><h3>{loc(lane.title)}</h3><p>{loc(lane.desc)}</p></article>
          ))}
        </div>
      </div>
    </section>

    <!-- News -->
    <section class="section proof-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("newsEyebrow")}</p>
            <h2 set:html={getVal("newsTitle")} />
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/news`}>{getLabel("viewNews")}</a>
        </div>
        <div class="grid grid-3" data-cms-news>
          {latestNews.map((n: any, idx: number) => (
            <NewsCard item={n} locale={locale} index={idx} />
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "36px" }}>
          <p class="eyebrow">FAQ</p>
          <h2 class="page-title">WillowSoft FAQ</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>{aiAnswer}</p>
        </div>
        <FaqAccordion faqs={content.faqs || []} pageKey="home" locale={locale} fallbackFaqs={homeFallbackFaqs} />
      </div>
    </section>

    <section class="section dark final-cta">
      <canvas class="signal-canvas" data-density="26" data-color="215, 154, 43"></canvas>
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getVal("ctaEyebrow")}</p>
          <h2 class="page-title" set:html={getVal("ctaTitle")} />
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{getVal("ctaLead")}</p>
          <div class="cta-choice-grid" aria-label="Common project starting points">
            <span>Hardware + Firmware</span><span>Backend + PostgreSQL</span><span>Web, Mobile + VR</span>
          </div>
          <p><a class="btn btn-primary" href={`/${locale}/contact`}>{getLabel("talkEngineering")}</a></p>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

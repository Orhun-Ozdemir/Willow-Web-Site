---
import PageLayout from "@/layouts/PageLayout.astro";
import NewsCard from "@/components/NewsCard.astro";
import { loadContent } from "@/lib/content";
import { pageSeo, webPageNode, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA, SITE_ORIGIN } from "@/lib/seo";
import { localizedValue, localizeItem, pageText, resolveLocale, type Locale } from "@/lib/cms";

export const prerender = false;

type LabelKey =
  | "heroAlt"
  | "heroEyebrow"
  | "heroTitle"
  | "heroLead"
  | "featuredEyebrow"
  | "featuredTitle"
  | "featuredCta"
  | "allEyebrow"
  | "allTitle"
  | "allLead"
  | "totalUpdates"
  | "categories"
  | "latestUpdate"
  | "filterEyebrow"
  | "filterTitle"
  | "searchLabel"
  | "searchPlaceholder"
  | "allCategories"
  | "sortLabel"
  | "sortNewest"
  | "sortOldest"
  | "sortTitle"
  | "emptyTitle"
  | "emptyLead"
  | "resetFilters"
  | "ctaEyebrow"
  | "ctaTitle"
  | "ctaLead"
  | "startProject";

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const content = await loadContent();
const pageContent = content.pageContent?.news || {};
const seoProps = pageSeo(content, "news", locale, "/news", "News | WillowSoft", "WillowSoft company updates, events, export news, and engineering updates.");

const toTime = (value: any) => {
  const time = value ? new Date(`${value}T00:00:00`).getTime() : 0;
  return Number.isFinite(time) ? time : 0;
};

const basePath = import.meta.env.BASE_URL || "/";
const assetPath = (value: any) => {
  if (!value || typeof value !== "string") return "";
  if (value.startsWith("http") || value.startsWith("data:")) return value;
  return `${basePath}${value.replace(/^\/+/, "")}`.replace(/([^:]\/)\/+/g, "$1");
};

const formatDate = (value: any, month: "short" | "long" = "short") => {
  if (!value) return "";
  const date = new Date(`${value}T00:00:00`);
  if (Number.isNaN(date.getTime())) return "";
  return date.toLocaleDateString(locale, { year: "numeric", month, day: "numeric" });
};

const categoryKey = (value: any) => String(value || "").trim().toLowerCase();
const categoryLabels: Record<string, Record<Locale, string>> = {
  proof: { en: "Field signal", tr: "Saha sinyali", de: "Feldsignal", fr: "Signal terrain", es: "Señal de campo", it: "Segnale sul campo", ar: "إشارة ميدانية", ja: "現場シグナル" },
  tracking: { en: "Field update", tr: "Saha güncellemesi", de: "Feld-Update", fr: "Mise à jour terrain", es: "Actualización de campo", it: "Aggiornamento sul campo", ar: "تحديث ميداني", ja: "現場アップデート" },
  "field-update": { en: "Field update", tr: "Saha güncellemesi", de: "Feld-Update", fr: "Mise à jour terrain", es: "Actualización de campo", it: "Aggiornamento sul campo", ar: "تحديث ميداني", ja: "現場アップデート" },
  "export": { en: "Export", tr: "İhracat", de: "Export", fr: "Export", es: "Exportación", it: "Export", ar: "تصدير", ja: "輸出" },
  event: { en: "Event", tr: "Etkinlik", de: "Event", fr: "Événement", es: "Evento", it: "Evento", ar: "فعالية", ja: "イベント" },
  company: { en: "Corporate", tr: "Kurumsal", de: "Unternehmen", fr: "Entreprise", es: "Empresa", it: "Azienda", ar: "الشركة", ja: "会社" },
  workshop: { en: "Workshop", tr: "Atölye", de: "Workshop", fr: "Atelier", es: "Workshop", it: "Workshop", ar: "ورشة عمل", ja: "ワークショップ" },
  update: { en: "Update", tr: "Güncelleme", de: "Update", fr: "Mise à jour", es: "Actualización", it: "Aggiornamento", ar: "تحديث", ja: "更新" },
};
const displayCategory = (value: any) => {
  const key = categoryKey(value);
  return categoryLabels[key]?.[locale] || categoryLabels[key]?.en || String(value || "News");
};

const newsList = [...(content.news || [])].sort((a: any, b: any) => toTime(b.date) - toTime(a.date));
const featuredRaw = newsList.find((item: any) => item.featured) || newsList[0];
const featured = featuredRaw ? localizeItem(featuredRaw, locale) : null;
const featuredDate = featured ? formatDate(featured.date, "long") : "";
const featuredGalleryImage = Array.isArray(featured?.images) ? featured.images.find((src: any) => typeof src === "string" && src.trim()) : "";
const featuredImage = assetPath(featured?.image || featuredGalleryImage);
const renderedNews = newsList.map((item: any) => localizeItem(item, locale));

const categoryMap = new Map<string, string>();
renderedNews.forEach((item: any) => {
  const label = item.category || "News";
  const key = categoryKey(label);
  if (key && !categoryMap.has(key)) categoryMap.set(key, label);
});
const categories = Array.from(categoryMap.entries()).map(([key, label]) => ({
  key,
  label: displayCategory(label),
  count: renderedNews.filter((item: any) => categoryKey(item.category || "News") === key).length,
}));
const latestDate = formatDate(newsList[0]?.date, "short");

const newsItemListId = `${seoProps.canonical}#itemlist`;
const newsSchema = {
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    {
      ...webPageNode("CollectionPage", seoProps.canonical, seoProps.title, seoProps.description, locale),
      mainEntity: { "@id": newsItemListId },
    },
    {
      "@type": "ItemList",
      "@id": newsItemListId,
      itemListElement: newsList.map((item: any, idx: number) => ({
        "@type": "ListItem",
        position: idx + 1,
        name: localizedValue(item.title, locale),
        url: `${SITE_ORIGIN}/${locale}/news/${encodeURIComponent(localizedValue(item.slug, locale) || item.slug?.en || item.id)}`,
      })),
    },
  ],
};

const labels: Record<LabelKey, Record<Locale, string>> = {
  heroAlt: { en: "WillowSoft engineering updates", tr: "WillowSoft mühendislik haberleri", de: "WillowSoft Engineering-Neuigkeiten", fr: "Actualités d'ingénierie WillowSoft", es: "Actualizaciones de ingeniería de WillowSoft", it: "Aggiornamenti tecnici WillowSoft", ar: "تحديثات WillowSoft الهندسية", ja: "WillowSoft エンジニアリングニュース" },
  heroEyebrow: { en: "News & Updates", tr: "Haberler ve Güncellemeler", de: "News & Updates", fr: "Actualités et mises à jour", es: "Noticias y novedades", it: "News e aggiornamenti", ar: "الأخبار والتحديثات", ja: "ニュースと更新" },
  heroTitle: { en: "Company signals that build trust.", tr: "Güven veren kurumsal gelişmeler.", de: "Unternehmenssignale, die Vertrauen schaffen.", fr: "Des signaux d'entreprise qui inspirent confiance.", es: "Señales corporativas que generan confianza.", it: "Segnali aziendali che costruiscono fiducia.", ar: "إشارات مؤسسية تبني الثقة.", ja: "信頼を築く企業アップデート。" },
  heroLead: { en: "Events, export milestones, workshops and engineering updates show how WillowSoft stays active in the field.", tr: "Etkinlikler, ihracat dönüm noktaları, atölyeler ve mühendislik güncellemeleri WillowSoft'un sahadaki aktifliğini gösterir.", de: "Events, Exportmeilensteine, Workshops und Engineering-Updates zeigen WillowSofts Aktivität im Feld.", fr: "Événements, jalons export, ateliers et mises à jour techniques montrent l'activité terrain de WillowSoft.", es: "Eventos, hitos de exportación, workshops y novedades técnicas muestran la actividad de WillowSoft en campo.", it: "Eventi, traguardi export, workshop e aggiornamenti tecnici mostrano l'attività sul campo di WillowSoft.", ar: "تُظهر الفعاليات ومحطات التصدير وورش العمل والتحديثات الهندسية نشاط WillowSoft في الميدان.", ja: "イベント、輸出の節目、ワークショップ、技術更新が WillowSoft の現場での活動を示します。" },
  featuredEyebrow: { en: "Featured update", tr: "Öne çıkan haber", de: "Ausgewähltes Update", fr: "Actualité à la une", es: "Actualización destacada", it: "Aggiornamento in evidenza", ar: "تحديث مميز", ja: "注目の更新" },
  featuredTitle: { en: "The latest signal customers can trust.", tr: "Müşterilerin güvenebileceği en yeni sinyal.", de: "Das neueste Signal, dem Kunden vertrauen können.", fr: "Le dernier signal auquel les clients peuvent faire confiance.", es: "La señal más reciente en la que los clientes pueden confiar.", it: "Il segnale più recente di cui i clienti possono fidarsi.", ar: "أحدث إشارة يمكن للعملاء الوثوق بها.", ja: "顧客が信頼できる最新の実績。" },
  featuredCta: { en: "Read", tr: "Oku", de: "Lesen", fr: "Lire", es: "Leer", it: "Leggi", ar: "اقرأ", ja: "読む" },
  allEyebrow: { en: "News archive", tr: "Haber arşivi", de: "Newsarchiv", fr: "Archive des actualités", es: "Archivo de noticias", it: "Archivio news", ar: "أرشيف الأخبار", ja: "ニュースアーカイブ" },
  allTitle: { en: "Browse field signals, launches and company milestones.", tr: "Saha sinyallerini, lansmanları ve şirket dönüm noktalarını keşfedin.", de: "Durchsuchen Sie Feldsignale, Launches und Unternehmensmeilensteine.", fr: "Parcourez les signaux terrain, lancements et jalons d'entreprise.", es: "Explore señales de campo, lanzamientos e hitos de la empresa.", it: "Esplora segnali dal campo, lanci e traguardi aziendali.", ar: "تصفح إشارات الميدان والإطلاقات ومحطات الشركة.", ja: "現場での実績、発表、企業の節目を確認できます。" },
  allLead: { en: "Use search and filters to find the update type that matters for your project.", tr: "Projeniz için önemli olan haber türünü arama ve filtrelerle bulun.", de: "Nutzen Sie Suche und Filter, um den passenden Update-Typ für Ihr Projekt zu finden.", fr: "Utilisez la recherche et les filtres pour trouver l'actualité utile à votre projet.", es: "Use búsqueda y filtros para encontrar la actualización relevante para su proyecto.", it: "Usa ricerca e filtri per trovare l'aggiornamento più utile al tuo progetto.", ar: "استخدم البحث والفلاتر للعثور على نوع التحديث المناسب لمشروعك.", ja: "検索とフィルターで、プロジェクトに必要な更新を探せます。" },
  totalUpdates: { en: "Updates", tr: "Haber", de: "Updates", fr: "Actualités", es: "Actualizaciones", it: "Aggiornamenti", ar: "تحديثات", ja: "更新数" },
  categories: { en: "Categories", tr: "Kategori", de: "Kategorien", fr: "Catégories", es: "Categorías", it: "Categorie", ar: "فئات", ja: "カテゴリ" },
  latestUpdate: { en: "Latest update", tr: "Son haber", de: "Neuestes Update", fr: "Dernière actualité", es: "Actualización reciente", it: "Ultimo aggiornamento", ar: "أحدث تحديث", ja: "最新更新" },
  filterEyebrow: { en: "Explore the archive", tr: "Arşivi keşfet", de: "Archiv erkunden", fr: "Explorer l'archive", es: "Explorar archivo", it: "Esplora archivio", ar: "استكشف الأرشيف", ja: "アーカイブを探索" },
  filterTitle: { en: "Find updates by topic, market signal or date.", tr: "Haberleri konuya, saha sinyaline veya tarihe göre bulun.", de: "Updates nach Thema, Marktsignal oder Datum finden.", fr: "Trouvez les actualités par sujet, signal marché ou date.", es: "Encuentre novedades por tema, señal de mercado o fecha.", it: "Trova aggiornamenti per tema, segnale di mercato o data.", ar: "اعثر على التحديثات حسب الموضوع أو الإشارة السوقية أو التاريخ.", ja: "トピック、市場シグナル、日付で更新を探せます。" },
  searchLabel: { en: "Search updates", tr: "Haberlerde ara", de: "Updates suchen", fr: "Rechercher", es: "Buscar novedades", it: "Cerca aggiornamenti", ar: "ابحث في التحديثات", ja: "更新を検索" },
  searchPlaceholder: { en: "Search by title, category or summary", tr: "Başlık, kategori veya özet ile ara", de: "Nach Titel, Kategorie oder Zusammenfassung suchen", fr: "Rechercher par titre, catégorie ou résumé", es: "Buscar por título, categoría o resumen", it: "Cerca per titolo, categoria o sintesi", ar: "ابحث بالعنوان أو الفئة أو الملخص", ja: "タイトル、カテゴリ、要約で検索" },
  allCategories: { en: "All", tr: "Tümü", de: "Alle", fr: "Tout", es: "Todo", it: "Tutto", ar: "الكل", ja: "すべて" },
  sortLabel: { en: "Sort", tr: "Sırala", de: "Sortieren", fr: "Trier", es: "Ordenar", it: "Ordina", ar: "ترتيب", ja: "並び替え" },
  sortNewest: { en: "Newest first", tr: "En yeni önce", de: "Neueste zuerst", fr: "Plus récent", es: "Más reciente", it: "Più recenti", ar: "الأحدث أولاً", ja: "新しい順" },
  sortOldest: { en: "Oldest first", tr: "En eski önce", de: "Älteste zuerst", fr: "Plus ancien", es: "Más antiguo", it: "Meno recenti", ar: "الأقدم أولاً", ja: "古い順" },
  sortTitle: { en: "Title A-Z", tr: "Başlık A-Z", de: "Titel A-Z", fr: "Titre A-Z", es: "Título A-Z", it: "Titolo A-Z", ar: "العنوان أ-ي", ja: "タイトル順" },
  emptyTitle: { en: "No matching updates", tr: "Eşleşen haber yok", de: "Keine passenden Updates", fr: "Aucune actualité trouvée", es: "No hay novedades coincidentes", it: "Nessun aggiornamento corrispondente", ar: "لا توجد تحديثات مطابقة", ja: "一致する更新はありません" },
  emptyLead: { en: "Clear the filters or try a broader search term.", tr: "Filtreleri temizleyin veya daha geniş bir arama deneyin.", de: "Filter löschen oder einen breiteren Suchbegriff verwenden.", fr: "Effacez les filtres ou élargissez votre recherche.", es: "Limpie los filtros o use una búsqueda más amplia.", it: "Cancella i filtri o prova una ricerca più ampia.", ar: "امسح الفلاتر أو جرّب مصطلح بحث أوسع.", ja: "フィルターを解除するか、より広い検索語を試してください。" },
  resetFilters: { en: "Clear filters", tr: "Filtreleri temizle", de: "Filter löschen", fr: "Effacer les filtres", es: "Limpiar filtros", it: "Cancella filtri", ar: "مسح الفلاتر", ja: "フィルター解除" },
  ctaEyebrow: { en: "Turn updates into a project", tr: "Haberleri projeye dönüştür", de: "Updates in ein Projekt verwandeln", fr: "Transformer l'actualité en projet", es: "Convertir novedades en proyecto", it: "Trasforma gli aggiornamenti in progetto", ar: "حوّل التحديثات إلى مشروع", ja: "更新をプロジェクトへ" },
  ctaTitle: { en: "Bring the same field-tested engineering into your connected product.", tr: "Sahada test edilmiş mühendisliği kendi IoT projenize taşıyın.", de: "Bringen Sie dieselbe feldgetestete Technik in Ihr vernetztes Produkt.", fr: "Intégrez cette ingénierie testée sur le terrain à votre produit connecté.", es: "Lleve esta ingeniería validada en campo a su producto conectado.", it: "Porta la stessa ingegneria testata sul campo nel tuo prodotto connesso.", ar: "انقل هذه الهندسة المختبرة ميدانياً إلى منتجك المتصل.", ja: "現場で検証されたエンジニアリングを、あなたのコネクテッド製品へ。" },
  ctaLead: { en: "Share your hardware, firmware, backend or interface challenge and the engineering team will map the next practical step.", tr: "Donanım, firmware, backend veya arayüz probleminizi paylaşın; mühendislik ekibi uygulanabilir sonraki adımı netleştirsin.", de: "Teilen Sie Ihre Hardware-, Firmware-, Backend- oder Interface-Herausforderung und das Engineering-Team skizziert den nächsten praktischen Schritt.", fr: "Partagez votre défi matériel, firmware, backend ou interface et l'équipe technique définira la prochaine étape concrète.", es: "Comparta su reto de hardware, firmware, backend o interfaz y el equipo técnico definirá el siguiente paso práctico.", it: "Condividi la tua sfida hardware, firmware, backend o interfaccia e il team tecnico definirà il prossimo passo pratico.", ar: "شارك تحدي العتاد أو البرامج الثابتة أو الخلفية أو الواجهة وسيحدد فريق الهندسة الخطوة العملية التالية.", ja: "ハードウェア、ファームウェア、バックエンド、UIの課題を共有すれば、技術チームが次の実行可能な一歩を整理します。" },
  startProject: { en: "Start Project", tr: "Projeye Başla", de: "Projekt starten", fr: "Démarrer un projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "ابدأ مشروعًا", ja: "プロジェクト開始" },
};

const getLabel = (key: LabelKey) => labels[key][locale] || labels[key].en;
const t = (cmsKey: string, labelKey: LabelKey) => pageText(pageContent, cmsKey, locale, getLabel(labelKey));
---

<PageLayout
  {...seoProps}
  schema={newsSchema}
  locale={locale}
  dataPage="news"
>
  <main id="main-content" data-news-proof data-active-category="all">
    <section class="hero compact news-proof-hero">
      <div class="hero-media"><img src={`${import.meta.env.BASE_URL}pdf-assets/p29_06_X111.jpg`} alt={getLabel("heroAlt")} loading="lazy" decoding="async"/></div>
      <canvas class="signal-canvas" data-density="28"></canvas>
      <div class="hero-inner">
        <p class="eyebrow reveal">{t("heroEyebrow", "heroEyebrow")}</p>
        <h1 class="reveal delay-1">{t("heroTitle", "heroTitle")}</h1>
        <p class="reveal delay-2">{t("heroLead", "heroLead")}</p>
      </div>
    </section>

    <section class="section news-proof-overview">
      <div class="section-inner">
        <div class="news-proof-strip reveal" aria-label="News summary">
          <article>
            <div class="news-proof-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5V5.25A2.25 2.25 0 0 1 6.25 3h11.5A2.25 2.25 0 0 1 20 5.25v14.25" />
                <path d="M4 19.5h16" />
                <path d="M8 8h8" />
                <path d="M8 12h5" />
              </svg>
            </div>
            <div>
              <span>{getLabel("totalUpdates")}</span>
              <strong>{newsList.length}</strong>
            </div>
          </article>
          <article>
            <div class="news-proof-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 7.5h16" />
                <path d="M7 4.5v6" />
                <path d="M17 13.5v6" />
                <path d="M4 16.5h16" />
              </svg>
            </div>
            <div>
              <span>{getLabel("categories")}</span>
              <strong>{categories.length}</strong>
            </div>
          </article>
          <article>
            <div class="news-proof-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 3v3" />
                <path d="M17 3v3" />
                <path d="M4 9h16" />
                <rect x="4" y="5" width="16" height="16" rx="2.5" />
              </svg>
            </div>
            <div>
              <span>{getLabel("latestUpdate")}</span>
              <strong>{latestDate || "-"}</strong>
            </div>
          </article>
        </div>

        {featured && (
          <article class="news-featured-card reveal delay-1">
            <figure class={!featuredImage ? "is-empty" : ""}>
              {featuredImage ? (
                <img
                  src={featuredImage}
                  alt={featured.title}
                  loading="lazy"
                  decoding="async"
                  onerror="this.closest('figure').classList.add('is-empty'); this.remove();"
                />
              ) : (
                <span>WillowSoft</span>
              )}
            </figure>
            <div class="news-featured-copy">
              <p class="eyebrow">{getLabel("featuredEyebrow")}</p>
              <div class="news-card-meta">
                <span class="news-badge">{displayCategory(featured.category || "News")}</span>
                {featuredDate && <time datetime={featured.date}>{featuredDate}</time>}
              </div>
              <h2>{featured.title || getLabel("featuredTitle")}</h2>
              <p>{featured.excerpt}</p>
              <a class="btn btn-primary" href={`/${locale}/news/${encodeURIComponent(featured.slug || featured.id)}`}>{getLabel("featuredCta")}</a>
            </div>
          </article>
        )}
      </div>
    </section>

    <section class="section news-proof-list-section">
      <div class="section-inner">
        <div class="section-head product-headline reveal">
          <div>
            <p class="eyebrow">{t("latestEyebrow", "allEyebrow")}</p>
            <h2>{t("latestTitle", "allTitle")}</h2>
            <p class="section-lead">{getLabel("allLead")}</p>
          </div>
        </div>

        <div class="news-controls reveal delay-1" aria-label="News filters">
          <div class="news-controls-head">
            <span>{getLabel("filterEyebrow")}</span>
            <strong>{getLabel("filterTitle")}</strong>
          </div>
          <label class="news-search">
            <span>{getLabel("searchLabel")}</span>
            <input type="search" data-news-search-input placeholder={getLabel("searchPlaceholder")} />
          </label>
          <div class="news-filter-row" role="group" aria-label="News categories">
            <button type="button" class="news-filter-chip is-active" data-news-filter="all" aria-pressed="true">
              {getLabel("allCategories")}
              <span class="news-chip-count">{newsList.length}</span>
            </button>
            {categories.map((category) => (
              <button type="button" class="news-filter-chip" data-news-filter={category.key} aria-pressed="false">
                {category.label}
                <span class="news-chip-count">{category.count}</span>
              </button>
            ))}
          </div>
          <label class="news-sort">
            <span>{getLabel("sortLabel")}</span>
            <select data-news-sort>
              <option value="newest">{getLabel("sortNewest")}</option>
              <option value="oldest">{getLabel("sortOldest")}</option>
              <option value="title">{getLabel("sortTitle")}</option>
            </select>
          </label>
        </div>

        <div class="news-empty-state" data-news-empty hidden>
          <h3>{getLabel("emptyTitle")}</h3>
          <p>{getLabel("emptyLead")}</p>
          <button type="button" class="btn btn-secondary btn-small" data-news-reset>{getLabel("resetFilters")}</button>
        </div>

        <div class="grid grid-3 news-grid" data-news-grid>
          {newsList.map((n, idx) => (
            <NewsCard item={n} locale={locale} index={idx} />
          ))}
        </div>
      </div>
    </section>

    <section class="section dark news-proof-cta">
      <canvas class="signal-canvas" data-density="26" data-color="215, 154, 43"></canvas>
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{t("pipelineEyebrow", "ctaEyebrow")}</p>
          <h2 class="page-title">{t("pipelineTitle", "ctaTitle")}</h2>
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{t("pipelineLead", "ctaLead")}</p>
          <p><a class="btn btn-primary" href={`/${locale}/start-project`}>{getLabel("startProject")}</a></p>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (function () {
      var root = document.querySelector("[data-news-proof]");
      if (!root) return;

      var grid = root.querySelector("[data-news-grid]");
      var searchInput = root.querySelector("[data-news-search-input]");
      var sortSelect = root.querySelector("[data-news-sort]");
      var emptyState = root.querySelector("[data-news-empty]");
      var resetButton = root.querySelector("[data-news-reset]");
      var filters = Array.prototype.slice.call(root.querySelectorAll("[data-news-filter]"));
      var cards = Array.prototype.slice.call(root.querySelectorAll("[data-news-card]"));
      var pageLocale = document.documentElement.lang || "en";

      function normalize(value) {
        return String(value || "").trim().toLowerCase();
      }

      function activeCategory() {
        return normalize(root.getAttribute("data-active-category") || "all");
      }

      function applyFilters() {
        var query = normalize(searchInput && searchInput.value);
        var category = activeCategory();
        var visibleCount = 0;

        cards.forEach(function (card) {
          var text = normalize(card.dataset.newsSearch);
          var cardCategory = normalize(card.dataset.newsCategory);
          var matchesSearch = !query || text.indexOf(query) !== -1;
          var matchesCategory = category === "all" || cardCategory === category;
          var shouldShow = matchesSearch && matchesCategory;

          card.hidden = !shouldShow;
          if (shouldShow) visibleCount += 1;
        });

        if (emptyState) emptyState.hidden = visibleCount !== 0;
      }

      function sortCards() {
        if (!grid) return;
        var mode = sortSelect ? sortSelect.value : "newest";

        cards
          .slice()
          .sort(function (a, b) {
            if (mode === "title") {
              return normalize(a.dataset.newsTitle).localeCompare(normalize(b.dataset.newsTitle), pageLocale);
            }

            var dateA = Number(a.dataset.newsDate || 0);
            var dateB = Number(b.dataset.newsDate || 0);
            return mode === "oldest" ? dateA - dateB : dateB - dateA;
          })
          .forEach(function (card) {
            grid.appendChild(card);
          });

        applyFilters();
      }

      filters.forEach(function (button) {
        button.addEventListener("click", function () {
          var next = normalize(button.getAttribute("data-news-filter") || "all");
          root.setAttribute("data-active-category", next);
          filters.forEach(function (item) {
            var active = item === button;
            item.classList.toggle("is-active", active);
            item.setAttribute("aria-pressed", active ? "true" : "false");
          });
          applyFilters();
        });
      });

      if (searchInput) searchInput.addEventListener("input", applyFilters);
      if (sortSelect) sortSelect.addEventListener("change", sortCards);
      if (resetButton) {
        resetButton.addEventListener("click", function () {
          if (searchInput) searchInput.value = "";
          if (sortSelect) sortSelect.value = "newest";
          root.setAttribute("data-active-category", "all");
          filters.forEach(function (item) {
            var active = item.getAttribute("data-news-filter") === "all";
            item.classList.toggle("is-active", active);
            item.setAttribute("aria-pressed", active ? "true" : "false");
          });
          sortCards();
        });
      }

      sortCards();
    })();
  </script>
</PageLayout>

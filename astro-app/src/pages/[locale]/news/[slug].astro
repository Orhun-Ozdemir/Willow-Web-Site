---
import PageLayout from "@/layouts/PageLayout.astro";
import { loadContent } from "@/lib/content";
import { localizedValue, localizeItem, locales, resolveLocale, type Locale } from "@/lib/cms";
import { buildAlternates, DEFAULT_OG_IMAGE, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA, SITE_ORIGIN } from "@/lib/seo";
import { normalizeProductSlug } from "@/lib/product-model";

export const prerender = false;

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const { slug } = Astro.params as { slug: string };
const content = await loadContent();
const normalizedSlug = normalizeProductSlug(slug);
const normalizeRouteSlug = (value: any) => normalizeProductSlug(value);
const raw = (content.news || []).find((n: any) => {
  const localSlug = normalizeRouteSlug(localizedValue(n.slug, locale) || n.slug?.en || n.id);
  return localSlug === normalizedSlug || normalizeRouteSlug(n.id) === normalizedSlug;
});

if (!raw) return Astro.redirect(`/${locale}/news`);

const article = localizeItem(raw, locale);
const seo = raw.seo?.[locale] || {};

const slugByLocale = Object.fromEntries(
  locales.map((l) => [l, `/news/${localizedValue(raw.slug, l) || raw.slug?.en || raw.id}`]),
) as Record<Locale, string>;
const canonical = seo.canonical || `${SITE_ORIGIN}/${locale}${slugByLocale[locale]}`;
const ogImage = article.image ? `${SITE_ORIGIN}${article.image.startsWith("/") ? "" : "/"}${article.image}` : DEFAULT_OG_IMAGE;
const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    {
      "@type": "NewsArticle",
      headline: article.title,
      description: seo.metaDescription || article.excerpt || "",
      image: [ogImage],
      inLanguage: locale,
      mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
      ...(article.date ? { datePublished: article.date } : {}),
      author: { "@id": `${SITE_ORIGIN}/#org` },
      publisher: { "@id": `${SITE_ORIGIN}/#org` },
    },
  ],
};

const labels = {
  backNews: { en: "News", tr: "Haberler", de: "Neuigkeiten", fr: "Actualités", es: "Noticias", it: "Notizie", ar: "الأخبار", ja: "ニュース" },
};
const getLabel = (key: keyof typeof labels) => labels[key][locale] || labels[key].en;
---

<PageLayout
  title={seo.seoTitle || `${article.title} | WillowSoft`}
  description={seo.metaDescription || article.excerpt || ""}
  canonical={canonical}
  ogTitle={seo.ogTitle || article.title}
  ogDescription={seo.ogDescription || seo.metaDescription || article.excerpt || ""}
  ogImage={ogImage}
  ogType="article"
  alternates={buildAlternates(slugByLocale[locale], slugByLocale)}
  schema={articleSchema}
  locale={locale}
  dataPage="news-detail"
>
  <main>
    <article>
      <section class="hero compact">
        <div class="hero-inner">
          <a href={`/${locale}/news`} class="back-link reveal">← {getLabel("backNews")}</a>
          {article.category && <span class="eyebrow reveal">{article.category}</span>}
          <h1 class="reveal delay-1">{article.title}</h1>
          {article.date && <time class="reveal delay-2">{article.date}</time>}
        </div>
      </section>

      {article.image && (
        <section class="section">
          <div class="section-inner">
            <img src={article.image} alt={article.title} class="article-hero-img" loading="lazy" />
          </div>
        </section>
      )}

      <section class="section">
        <div class="section-inner prose" set:html={article.content || article.excerpt || ""} />
      </section>
    </article>
  </main>
</PageLayout>

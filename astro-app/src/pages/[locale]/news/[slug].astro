---
import PageLayout from "@/layouts/PageLayout.astro";
import { loadContent } from "@/lib/content";
import { localizedValue, localizeItem, locales, type Locale } from "@/lib/cms";
import { buildAlternates, DEFAULT_OG_IMAGE, SITE_ORIGIN } from "@/lib/seo";

export function getStaticPaths() {
  const content = loadContent();
  const news = content.news || [];
  const paths: any[] = [];
  for (const locale of locales) {
    for (const item of news) {
      const slug = localizedValue(item.slug, locale) || item.slug?.en || item.id;
      paths.push({ params: { locale, slug }, props: { newsId: item.id } });
    }
  }
  return paths;
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
const { newsId } = Astro.props;
const content = loadContent();
const raw = (content.news || []).find((n: any) => n.id === newsId);

if (!raw) return Astro.redirect(`/${locale}/news`);

const article = localizeItem(raw, locale);
const seo = raw.seo?.[locale] || {};

const slugByLocale = Object.fromEntries(
  locales.map((l) => [l, `/news/${localizedValue(raw.slug, l) || raw.slug?.en || raw.id}`]),
) as Record<Locale, string>;
const canonical = seo.canonical || `${SITE_ORIGIN}/${locale}${slugByLocale[locale]}`;
const ogImage = article.image ? `${SITE_ORIGIN}${article.image.startsWith("/") ? "" : "/"}${article.image}` : DEFAULT_OG_IMAGE;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: article.title,
  description: seo.metaDescription || article.excerpt || "",
  image: [ogImage],
  inLanguage: locale,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  ...(article.date ? { datePublished: article.date } : {}),
  author: { "@type": "Organization", name: "WillowSoft", url: SITE_ORIGIN },
  publisher: {
    "@type": "Organization",
    "@id": `${SITE_ORIGIN}/#org`,
    name: "WillowSoft",
    logo: { "@type": "ImageObject", url: `${SITE_ORIGIN}/assets/willow-mark-transparent.png` },
  },
};
---

<PageLayout
  title={seo.seoTitle || `${article.title} | WillowSoft`}
  description={seo.metaDescription || article.excerpt || ""}
  canonical={canonical}
  ogTitle={seo.ogTitle || article.title}
  ogDescription={seo.ogDescription || seo.metaDescription || article.excerpt || ""}
  ogImage={ogImage}
  ogType="article"
  alternates={buildAlternates(slugByLocale[locale], slugByLocale)}
  schema={articleSchema}
  locale={locale}
  dataPage="news-detail"
>
  <main>
    <article>
      <section class="hero compact">
        <div class="hero-inner">
          <a href={`/${locale}/news`} class="back-link reveal">← News</a>
          {article.category && <span class="eyebrow reveal">{article.category}</span>}
          <h1 class="reveal delay-1">{article.title}</h1>
          {article.date && <time class="reveal delay-2">{article.date}</time>}
        </div>
      </section>

      {article.image && (
        <section class="section">
          <div class="section-inner">
            <img src={article.image} alt={article.title} class="article-hero-img" loading="lazy" />
          </div>
        </section>
      )}

      <section class="section">
        <div class="section-inner prose" set:html={article.content || article.excerpt || ""} />
      </section>
    </article>
  </main>
</PageLayout>

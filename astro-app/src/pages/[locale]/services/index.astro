  officesWorldwide: { en: "offices worldwide", tr: "dünya çapında ofis", de: "Büros weltweit", fr: "bureaux dans le monde", es: "oficinas en el mundo", it: "uffici nel mondo", ar: "مكتب حول العالم", ja: "拠点数" },

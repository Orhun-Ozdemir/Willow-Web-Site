  batteryLife: { en: "Battery Life", tr: "Pil Ömrü", de: "Batterielaufzeit", fr: "Autonomie batterie", es: "Duración de batería", it: "Autonomia batteria", ar: "عمر البطارية", ja: "バッテリー寿命" },
  tempAlerts: { en: "Temp Alerts", tr: "Sıcaklık Uyarıları", de: "Temperatur-Alarme", fr: "Alertes temp.", es: "Alertas de temp.", it: "Allarmi temp.", ar: "تنبيهات الحرارة", ja: "温度アラート" },

  conceptToProduction: { en: "Concept to production", tr: "Konseptten üretime", de: "Konzept bis Produktion", fr: "Du concept à la production", es: "Del concepto a la producción", it: "Dal concept alla produzione", ar: "من الفكرة إلى الإنتاج", ja: "設計から量産まで" },
  cleanerPath: { en: "A cleaner path from idea to deployed system.", tr: "Fikirden çalışan sisteme giden en net yol.", de: "Ein klarer Weg von der Idee zum installierten System.", fr: "Un chemin plus clair de l'idée au système déployé.", es: "Un camino más claro de la idea al sistema implementado.", it: "Un percorso più lineare dall'idea al sistema installato.", ar: "مسار أكثر وضوحاً من الفكرة إلى النظام المفعل.", ja: "アイデアを確実に形にする合理的な開発ステップ" },
  analyze: { en: "Analyze", tr: "Analiz", de: "Analysieren", fr: "Analyser", es: "Analizar", it: "Analizzare", ar: "التحليل", ja: "分析" },
  analyzeDesc: { en: "Requirements, field conditions, integrations and technical risks are clarified first.", tr: "Gereksinimler, saha koşulları, entegrasyonlar ve teknik riskler ilk aşamada netleştirilir.", de: "Anforderungen, Feldbedingungen, Integrationen und technische Risiken werden zuerst geklärt.", fr: "Les exigences, les conditions sur le terrain, les intégrations et les risques techniques sont clarifiés en premier.", es: "Primero se aclaran los requisitos, las condiciones del campo, las integraciones y los riesgos técnicos.", it: "I requisiti, le condizioni sul campo, le integrazioni e i rischi tecnici vengono chiariti per primi.", ar: "يتم توضيح المتطلبات والظروف الميدانية وعمليات التكامل والمخاطر الفنية أولاً.", ja: "要件、設置環境、他システム連携, 技術リスクを事前に明確化します。" },
  architect: { en: "Architect", tr: "Tasarım", de: "Architektur", fr: "Concevoir", es: "Diseñar", it: "Progettare", ar: "الهندسة", ja: "設計" },
  architectDesc: { en: "Hardware, firmware, API, database and interfaces are planned as one system.", tr: "Donanım, firmware, API, veritabanı ve arayüzler tek bir sistem olarak planlanır.", de: "Hardware, Firmware, API, Datenbank und Schnittstellen werden als ein System geplant.", fr: "Le matériel, le firmware, l'API, la base de données et les interfaces sont planifiés comme un seul système.", es: "El hardware, el firmware, la API, la base de datos y las interfaces se planifican como un solo sistema.", it: "L'hardware, il firmware, l'API, il database e le interfacce vengono pianificati come un unico sistema.", ar: "يتم التخطيط للعتاد والبرمجيات وواجهات البرمجة وقاعدة البيانات والواجهات كنظام واحد.", ja: "ハード、ファーム、API、DB、UIのすべてを、1つのシステムとして設計します。" },
  build: { en: "Build", tr: "Geliştirme", de: "Bauen", fr: "Construire", es: "Construir", it: "Sviluppare", ar: "البناء", ja: "開発" },
  buildDesc: { en: "The product is developed across layers without vendor hand-off gaps.", tr: "Ürün, tedarikçi el değiştirme boşlukları olmadan tüm katmanlarda geliştirilir.", de: "Das Produkt wird über alle Schichten hinweg ohne Übergabelücken der Anbieter entwickelt.", fr: "Le produit est développé à travers les couches sans lacunes de transfert de fournisseur.", es: "El producto se desarrolla a través de capas sin brechas de transferencia del proveedor.", it: "Il prodotto viene sviluppato su tutti i livelli senza interruzioni di consegna dei fornitori.", ar: "يتم تطوير المنتج عبر الطبقات المختلفة دون فجوات تسليم بين الموردين.", ja: "ベンダー間の伝達ロスなく、全レイヤーの同時開発を自社内で行います。" },
  validate: { en: "Validate", tr: "Doğrulama", de: "Validieren", fr: "Valider", es: "Validar", it: "Validare", ar: "التحقق", ja: "検証" },
  validateDesc: { en: "RF, device stability, API reliability, UX and field readiness are tested together.", tr: "RF, cihaz kararlılığı, API güvenilirliği, UX ve sahaya hazırlık birlikte test edilir.", de: "RF, Gerätestabilität, API-Zuverlässigkeit, UX und Feldbereitschaft werden zusammen getestet.", fr: "RF, stabilité des dispositifs, fiabilité des APIs, UX et préparation sur le terrain sont testés ensemble.", es: "Se prueban juntos la RF, la estabilidad del dispositivo, la confiabilidad de la API, la UX y la preparación para el campo.", it: "RF, stabilità del dispositivo, affidabilità delle API, UX e prontezza sul campo vengono testate insieme.", ar: "يتم اختبار الـ RF، واستقرار الجهاز، وموثوقية واجهة البرمجة، وتجربة المستخدم، وجاهزية الموقع معاً.", ja: "アンテナ性能、稼働安定性、API負荷、操作性、実地テストを統合検証します。" },

  questionsBefore: { en: "Frequently asked", tr: "Sıkça Sorulan", de: "Häufig gestellte", fr: "Foire aux questions", es: "Preguntas frecuentes", it: "Domande frequenti", ar: "الأسئلة الشائعة", ja: "よくある質問" },
  engineeringBuyers: {
    en: "Engineering buyers usually arrive with the same operational questions. Here are the answers — the rest happens in the discovery call.",
    tr: "Mühendislik alıcıları genellikle aynı operasyonel sorularla gelir. İşte yanıtlar; geri kalanı keşif görüşmesinde gerçekleşir.",
    de: "Engineering-Einkäufer kommen meist mit denselben betrieblichen Fragen. Hier sind die Antworten – der Rest klärt sich im Erstgespräch.",
    fr: "Les acheteurs d'ingénierie arrivent généralement avec les mêmes questions opérationnelles. Voici les réponses — le reste se passe lors de l'appel de découverte.",
    es: "Los compradores de ingeniería suelen llegar con las mismas preguntas operativas. Aquí están las respuestas; el resto ocurre en la llamada de descubrimiento.",
    it: "I responsabili tecnici arrivano in genere con le stesse domande operative. Ecco le risposte: il resto viene approfondito nella chiamata conoscitiva.",
    ar: "عادة ما يأتي مهندسو المشتريات بالأسئلة التشغيلية نفسها. إليك الإجابات — ويتم توضيح الباقي في مكالمة الاستكشاف.",
    ja: "開発のご担当者様からよくいただく共通の質問と回答をまとめました。詳細な要件は、初回面談時にヒアリングいたします。"
  },

  startWithEng: { en: "Start with engineering", tr: "Mühendislikle başlayın", de: "Beginnen Sie mit dem Engineering", fr: "Commencer par l'ingénierie", es: "Comenzar con la ingeniería", it: "Inizia dall'ingegneria", ar: "ابدأ من الجانب الهندسي", ja: "技術検証からスタート" },
  readyToShip: { en: "Ready to ship a connected product that actually works in the field?", tr: "Sahada gerçekten çalışan bağlı bir ürün sunmaya hazır mısınız?", de: "Bereit für ein vernetztes Produkt, das in der Praxis wirklich funktioniert?", fr: "Prêt à livrer un produit connecté qui fonctionne réellement sur le terrain ?", es: "¿Listo para lanzar un producto conectado que realmente funcione en el campo?", it: "Pronto a lanciare un prodotto connesso che funzioni davvero sul campo?", ar: "جاهز لإطلاق منتج متصل يعمل بالفعل في موقع التشغيل؟", ja: "現場で「実用に耐える」IoT製品を構築しませんか？" },
  ctaLead: {
    en: "Tell us which layer you need first — hardware, firmware, backend, mobile, web or immersive — and WillowSoft engineering will respond with a discovery plan and a realistic timeline.",
    tr: "İlk etapta hangi katmana ihtiyacınız olduğunu bize söyleyin (donanım, yazılım, backend, mobil, web veya simülasyon) ve WillowSoft mühendisliği size bir keşif planı ve gerçekçi bir zaman çizelgesiyle dönsün.",
    de: "Teilen Sie uns mit, welche Schicht Sie zuerst benötigen – Hardware, Firmware, Backend, Mobile, Web oder Immersiv – und das WillowSoft-Engineering wird mit einem Entdeckungsplan und einem realistischen Zeitplan antworten.",
    fr: "Dites-nous de quelle couche vous avez besoin en premier — matériel, firmware, backend, mobile, web ou immersif — et l'ingénierie de WillowSoft vous répondra avec un plan de découverte et un calendrier réaliste.",
    es: "Díganos qué capa necesita primero (hardware, firmware, backend, móvil, web o inmersivo) y el equipo de ingeniería de WillowSoft responderá con un plan de descubrimiento y un cronograma realista.",
    it: "Diteci di quale livello avete bisogno per primo (hardware, firmware, backend, mobile, web o immersivo) e il team tecnico di WillowSoft vi risponderà con un piano di lavoro e una tempistica realistica.",
    ar: "أخبرنا بالطبقة التي تحتاجها أولاً — عتاد، برمجيات، منصة خلفية، تطبيق جوال، ويب أو محاكاة — وسيقوم مهندسو WillowSoft بالرد عليك بخطة استكشاف وجدول زمني واقعي.",
    ja: "ハードウェア、ファームウェア、バックエンド、アプリ、3Dシミュレータなど、まず必要な開発内容をお知らせください。技術検討プランと開発スケジュールをご提案します。"
  },
  talkToEngineering: { en: "Talk to Engineering", tr: "Mühendislerle Görüşün", de: "Mit Engineering sprechen", fr: "Parler à l'ingénierie", es: "Hablar con ingeniería", it: "Parla con il team", ar: "تحدث إلى الهندسة", ja: "技術チームへ相談" },
  startYourProject: { en: "Start Your Project", tr: "Projeye Başlayın", de: "Projekt starten", fr: "Démarrer le projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "ابدأ مشروعًا", ja: "プロジェクトを開始" }
};

const getLabel = (key: keyof typeof labels) => {
  return labels[key][locale] || labels[key]["en"];
};
---

<PageLayout
  {...seoProps}
  schema={servicesSchema}
  locale={locale}
  dataPage="services"
>
  <main class="services-premium">
    <!-- HERO: light premium motion + service architecture -->
    <section class="hero compact hero-services services-motion-hero">
      <canvas class="signal-canvas" data-density="34" data-color="24, 167, 255"></canvas>
      <div class="services-hero-light" aria-hidden="true"></div>
      <div class="hero-inner services-hero-grid">
        <div class="services-hero-copy">
          <p class="eyebrow reveal">{getVal("heroEyebrow")}</p>
          <h1 class="reveal delay-1">{getVal("heroTitle")}</h1>
          <p class="reveal delay-2">{getVal("heroLead")}</p>
          <div class="services-hero-meta reveal delay-3" role="list" aria-label={getLabel("serviceCapacity")}>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket}</strong>
              <span>{getLabel("productsOnMarket")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="happyClients">{companyFacts.happyClients}</strong>
              <span>{getLabel("happyClients")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="founded">2020</strong>
              <span>{getLabel("founded")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="officesWorldwide">{companyFacts.officesWorldwide}</strong>
              <span>{getLabel("officesWorldwide")}</span>
            </span>
          </div>
        </div>
        <div class="service-architecture reveal delay-2" aria-label="Connected product architecture summary">
          <div class="architecture-deck architecture-deck-simple">
            <p class="architecture-label">{getLabel("serviceArchitecture")}</p>
            <h2>{getLabel("deviceToData")}</h2>
            <div class="architecture-flow">
              <div class="flow-node-large">
                <span>01</span>
                <strong>{getLabel("device")}</strong>
                <small>{getLabel("hwFirmware")}</small>
              </div>
              <div class="flow-node-large">
                <span>02</span>
                <strong>{getLabel("data")}</strong>
                <small>{getLabel("apiPostgres")}</small>
              </div>
              <div class="flow-node-large">
                <span>03</span>
                <strong>{getLabel("interface")}</strong>
                <small>{getLabel("webMobileVr")}</small>
              </div>
            </div>
            <div class="summary-metrics">
              <div>
                <strong>8</strong>
                <span>{getLabel("capabilities")}</span>
              </div>
              <div>
                <strong>4</strong>
                <span>{getLabel("deliveryLayers")}</span>
              </div>
              <div>
                <strong>1</strong>
                <span>{getLabel("systemView")}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section tight">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
      </div>
    </section>

    <!-- TRUSTED BY — global customer logos for immediate trust signal -->
    <section class="section trusted-by-section">
      <div class="section-inner">
        <div class="trusted-by-row reveal">
          <p class="trusted-by-label">{getLabel("trustedByGlobal")}</p>
          <div class="trusted-by-logos" aria-label={getLabel("customerLogos")}>
            {featuredClients.map((client: any) => (
              <div class="trusted-logo" title={client.name}>
                {client.logo ? <img src={`/${client.logo}`} alt={client.name} loading="lazy" decoding="async" /> : <strong>{client.name}</strong>}
              </div>
            ))}
          </div>
          <span class="trusted-by-pill">{getLabel("exportCountries")}</span>
        </div>
      </div>
    </section>

    <!-- SERVICE SYSTEM: grouped by the way connected products are actually built -->
    <section class="section tight service-capabilities-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getLabel("serviceSystem")}</p>
            <h2>{getLabel("chooseLayer")}</h2>
            <p class="section-lead">{getLabel("servicesLead")}</p>
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/start-project`}>{getLabel("startDiscovery")}</a>
        </div>
        <div class="service-system-grid reveal delay-1">
          <article class="system-layer-card">
            <span class="layer-index">01</span>
            <p class="service-card-kicker">{getLabel("deviceEng")}</p>
            <h3>{getLabel("deviceEngTitle")}</h3>
            <p>{getLabel("deviceEngDesc")}</p>
            <div class="layer-services">
              <span>Embedded Hardware</span>
              <span>Firmware</span>
              <span>Connectivity</span>
            </div>
            <p class="layer-output">
              <strong>{getLabel("typicalOutputLabel")}</strong> {getLabel("deviceOutput")}
            </p>
          </article>
          <article class="system-layer-card">
            <span class="layer-index">02</span>
            <p class="service-card-kicker">{getLabel("cloudData")}</p>
            <h3>{getLabel("cloudDataTitle")}</h3>
            <p>{getLabel("cloudDataDesc")}</p>
            <div class="layer-services">
              <span>Backend API</span>
              <span>PostgreSQL</span>
              <span>IoT Cloud</span>
            </div>
            <p class="layer-output">
              <strong>{getLabel("typicalOutputLabel")}</strong> {getLabel("cloudOutput")}
            </p>
          </article>
          <article class="system-layer-card">
            <span class="layer-index">03</span>
            <p class="service-card-kicker">{getLabel("operatorInterface")}</p>
            <h3>{getLabel("operatorTitle")}</h3>
            <p>{getLabel("operatorDesc")}</p>
            <div class="layer-services">
              <span>Web/Admin</span>
              <span>Mobile Apps</span>
              <span>Customer Portal</span>
            </div>
            <p class="layer-output">
              <strong>{getLabel("typicalOutputLabel")}</strong> {getLabel("operatorOutput")}
            </p>
          </article>
          <article class="system-layer-card">
            <span class="layer-index">04</span>
            <p class="service-card-kicker">{getLabel("immersive")}</p>
            <h3>{getLabel("immersiveTitle")}</h3>
            <p>{getLabel("immersiveDesc")}</p>
            <div class="layer-services">
              <span>VR Training</span>
              <span>Product Demo</span>
              <span>Digital Twin</span>
            </div>
            <p class="layer-output">
              <strong>{getLabel("typicalOutputLabel")}</strong> {getLabel("immersiveOutput")}
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- DELIVERABLES — what customers receive -->
    <section class="section service-outcomes-section">
      <div class="section-inner">
        <div class="deliverables-split">
          <div class="section-head reveal">
            <p class="eyebrow">{getLabel("deliverables")}</p>
            <h2 class="page-title">{getLabel("whatLeaves")}</h2>
            <p class="section-lead">{getLabel("deliverablesLead")}</p>
            <div class="handoff-note">
              <strong>{getLabel("projectHandoff")}</strong>
              <span>{getLabel("handoffDesc")}</span>
            </div>
          </div>
          <div class="deliverable-ledger reveal delay-1">
            <div>
              <span>{getLabel("devicePackage")}</span>
              <strong>{getLabel("devicePackageDesc")}</strong>
            </div>
            <div>
              <span>{getLabel("firmwarePackage")}</span>
              <strong>{getLabel("firmwarePackageDesc")}</strong>
            </div>
            <div>
              <span>{getLabel("platformPackage")}</span>
              <strong>{getLabel("platformPackageDesc")}</strong>
            </div>
            <div>
              <span>{getLabel("interfacePackage")}</span>
              <strong>{getLabel("interfacePackageDesc")}</strong>
            </div>
            <div>
              <span>{getLabel("launchPackage")}</span>
              <strong>{getLabel("launchPackageDesc")}</strong>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CASE STUDIES — real-world engineering proof -->
    <section class="section services-case-studies-section" id="case-studies" style={{ background: "var(--surface)", borderTop: "1px solid var(--line)", borderBottom: "1px solid var(--line)" }}>
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "48px" }}>
          <p class="eyebrow">{getLabel("caseStudies")}</p>
          <h2 class="page-title">{getLabel("provenInProduction")}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {getLabel("caseStudiesLead")}
          </p>
        </div>
        
        <div class="case-studies-list" style={{ display: "grid", gap: "64px" }}>
          {/* Case Study 1 */}
          <article class="split reveal" style={{ alignItems: "stretch" }}>
            <div class="split-media" style={{ position: "relative", display: "flex", flexDirection: "column", justifyContent: "center", background: "rgba(255,255,255,0.8)", border: "1px solid var(--line)", overflow: "hidden", borderRadius: "var(--radius)", boxShadow: "var(--shadow)" }}>
              <img src={`${import.meta.env.BASE_URL}assets/client-logos/slb.png`} alt="SLB" style={{ maxHeight: "44px", width: "auto", objectFit: "contain", margin: "40px auto 20px", opacity: 0.85 }} />
              <div class="case-stats" style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "10px", padding: "20px", background: "rgba(240, 245, 255, 0.5)", borderTop: "1px solid var(--line)", textAlign: "center" }}>
                <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>-32%</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{getLabel("maintenanceCosts")}</span></div>
                <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>99.6%</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{getLabel("networkUptime")}</span></div>
                <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>&lt;5m</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{getLabel("faultAlerts")}</span></div>
              </div>
            </div>
            <div style={{ display: "flex", flexDirection: "column", justifyContent: "center" }}>
              <p class="eyebrow" style={{ color: "var(--accent)", marginBottom: "8px" }}>{getLabel("solarTitle")}</p>
              <h3 style={{ fontFamily: "var(--font-display)", fontSize: "clamp(1.6rem, 2.4vw, 2.5rem)", margin: "0 0 16px", color: "var(--ink)", lineHeight: 1.1, letterSpacing: "-0.02em" }}>{getLabel("solarSub")}</h3>
              <p style={{ color: "var(--muted)", fontSize: "0.98rem", lineHeight: 1.6, margin: "0 0 20px 0" }} set:html={getLabel("solarProblem")}></p>
              <blockquote style={{ margin: 0, paddingLeft: "20px", borderLeft: "3px solid var(--accent)", fontStyle: "italic", color: "var(--muted)", fontSize: "0.94rem", lineHeight: 1.55 }}>
                {getLabel("solarQuote")}
                <cite style={{ display: "block", marginTop: "8px", fontWeight: 700, fontStyle: "normal", fontSize: "0.82rem", textTransform: "uppercase", letterSpacing: "0.04em", color: "var(--ink)" }}>{getLabel("solarQuoteAuthor")}</cite>
              </blockquote>
            </div>
          </article>

          {/* Case Study 2 */}
          <article class="split reveal" style={{ alignItems: "stretch" }}>
            <div class="split-media" style={{ position: "relative", display: "flex", flexDirection: "column", justifyContent: "center", background: "rgba(255,255,255,0.8)", border: "1px solid var(--line)", overflow: "hidden", borderRadius: "var(--radius)", boxShadow: "var(--shadow)" }}>
              <img src={`${import.meta.env.BASE_URL}assets/client-logos/cocacola.png`} alt="Coca-Cola" style={{ maxHeight: "44px", width: "auto", objectFit: "contain", margin: "40px auto 20px", opacity: 0.85 }} />
              <div class="case-stats" style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "10px", padding: "20px", background: "rgba(240, 245, 255, 0.5)", borderTop: "1px solid var(--line)", textAlign: "center" }}>
                <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>0%</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{getLabel("spoilageIncidents")}</span></div>
                <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>5 Yrs</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{getLabel("batteryLife")}</span></div>
                <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>Realtime</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{getLabel("tempAlerts")}</span></div>
              </div>
            </div>
            <div style={{ display: "flex", flexDirection: "column", justifyContent: "center" }}>
              <p class="eyebrow" style={{ color: "var(--accent)", marginBottom: "8px" }}>{getLabel("coldTitle")}</p>
              <h3 style={{ fontFamily: "var(--font-display)", fontSize: "clamp(1.6rem, 2.4vw, 2.5rem)", margin: "0 0 16px", color: "var(--ink)", lineHeight: 1.1, letterSpacing: "-0.02em" }}>{getLabel("coldSub")}</h3>
              <p style={{ color: "var(--muted)", fontSize: "0.98rem", lineHeight: 1.6, margin: "0 0 20px 0" }} set:html={getLabel("coldProblem")}></p>
              <blockquote style={{ margin: 0, paddingLeft: "20px", borderLeft: "3px solid var(--accent)", fontStyle: "italic", color: "var(--muted)", fontSize: "0.94rem", lineHeight: 1.55 }}>
                {getLabel("coldQuote")}
                <cite style={{ display: "block", marginTop: "8px", fontWeight: 700, fontStyle: "normal", fontSize: "0.82rem", textTransform: "uppercase", letterSpacing: "0.04em", color: "var(--ink)" }}>{getLabel("coldQuoteAuthor")}</cite>
              </blockquote>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- PROCESS TIMELINE PREMIUM -->
    <section class="section soft process-section">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{getLabel("conceptToProduction")}</p>
          <h2>{getLabel("cleanerPath")}</h2>
        </div>
        <div class="process process-premium process-compact">
          <div class="process-step reveal">
            <div class="step-dot">1</div>
            <article class="card process-card">
              <h3>{getLabel("analyze")}</h3>
              <p>{getLabel("analyzeDesc")}</p>
            </article>
          </div>
          <div class="process-step reveal delay-1">
            <div class="step-dot">2</div>
            <article class="card process-card">
              <h3>{getLabel("architect")}</h3>
              <p>{getLabel("architectDesc")}</p>
            </article>
          </div>
          <div class="process-step reveal delay-2">
            <div class="step-dot">3</div>
            <article class="card process-card">
              <h3>{getLabel("build")}</h3>
              <p>{getLabel("buildDesc")}</p>
            </article>
          </div>
          <div class="process-step reveal delay-3">
            <div class="step-dot">4</div>
            <article class="card process-card">
              <h3>{getLabel("validate")}</h3>
              <p>{getLabel("validateDesc")}</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "36px" }}>
          <p class="eyebrow">{getLabel("questionsBefore")}</p>
          <h2 class="page-title">{getVal("stackTitle") || "Questions before you brief us."}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {getLabel("engineeringBuyers")}
          </p>
        </div>
        <FaqAccordion pageKey="services" faqs={content.faqs || []} locale={locale} />
      </div>
    </section>

    <!-- FINAL PREMIUM CTA -->
    <section class="section soft services-cta-section">
      <div class="section-inner">
        <div class="services-cta-block reveal">
          <div class="services-cta-content">
            <p class="eyebrow">{getLabel("startWithEng")}</p>
            <h2 class="page-title">{getLabel("readyToShip")}</h2>
            <p class="section-lead">{getLabel("ctaLead")}</p>
          </div>
          <div class="services-cta-actions">
            <a class="btn btn-primary" href={`/${locale}/contact`}>{getLabel("talkToEngineering")}</a>
            <a class="btn btn-secondary" href={`/${locale}/start-project`}>{getLabel("startYourProject")}</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

---
import PageLayout from "@/layouts/PageLayout.astro";
import FaqAccordion from "@/components/FaqAccordion.astro";
import AIAnswerBlock from "@/components/AIAnswerBlock.astro";
import { loadContent } from "@/lib/content";
import { pageSeo, webPageNode, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA } from "@/lib/seo";
import { localizedValue, locales, resolveLocale, type Locale } from "@/lib/cms";
import { aiAnswerForPage, aiMetaForPage, appendSchemaNodes, fallbackFaqsForPage, faqItemsForPage, faqSchemaNode } from "@/lib/ai-search";

export const prerender = false;

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const content = await loadContent();
const seoProps = pageSeo(content, "services", locale, "/services", "Services | WillowSoft", "Embedded systems & Industrial IoT services.");
const pageContent = content.pageContent?.services || {};
const companyFacts = content.companyFacts || {};

// Helper to get localized page content value
const getVal = (key: string) => localizedValue(pageContent[key], locale);

// Helper to get localized value from an item's localized map, fallback to top-level
const getItemVal = (item: any, key: string) => {
  const loc = item?.localized?.[locale]?.[key];
  if (loc) return loc;
  return item?.[key] || "";
};

const servicesFallbackFaqs = fallbackFaqsForPage("services", locale);
const servicesFaqItems = faqItemsForPage(content.faqs || [], "services", locale, servicesFallbackFaqs);
const aiAnswer = aiAnswerForPage(content, "services", locale, seoProps.description);
const aiMeta = aiMetaForPage(content, "services", locale);
const servicesSchema = appendSchemaNodes({
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    webPageNode("WebPage", seoProps.canonical, seoProps.title, seoProps.description, locale),
  ],
}, [faqSchemaNode(seoProps.canonical, servicesFaqItems)]);

const featuredClients = (content.clients || [])
  .filter((c: any) => c.featured)
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

// ── CMS-driven dynamic data with sensible fallbacks ──
const serviceLayers = ((pageContent.serviceLayers || []) as any[])
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

const caseStudies = ((pageContent.caseStudies || []) as any[])
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

const deliverablesList = ((pageContent.deliverables || []) as any[])
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

const processSteps = ((pageContent.processSteps || []) as any[])
  .sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));

// ── Fallback static labels (used when CMS fields are empty) ──
const labels: Record<string, Record<string, string>> = {
  productsOnMarket: { en: "Products on Market", tr: "Piyasadaki Ürünler", de: "Produkte am Markt", fr: "Produits sur le marché", es: "Productos en el mercado", it: "Prodotti sul mercato", ar: "منتج في السوق", ja: "市場実績製品" },
  happyClients: { en: "happy clients", tr: "mutlu müşteriler", de: "zufriedene Kunden", fr: "clients satisfaits", es: "clientes satisfechos", it: "clienti felici", ar: "عميل سعيد", ja: "取引先企業数" },
  founded: { en: "Founded", tr: "Kuruluş", de: "Gegründet", fr: "Fondation", es: "Fundación", it: "Fondazione", ar: "تأسست عام", ja: "設立年" },
  officesWorldwide: { en: "offices worldwide", tr: "dünya çapında ofis", de: "Büros weltweit", fr: "bureaux dans le monde", es: "oficinas en el mundo", it: "uffici nel mondo", ar: "مكتب حول العالم", ja: "拠点数" },
  serviceArchitecture: { en: "Service architecture", tr: "Hizmet mimarisi", de: "Dienstarchitektur", fr: "Architecture de service", es: "Arquitectura de servicio", it: "Architettura dei servizi", ar: "مخطط الخدمة", ja: "サービス構成" },
  deviceToData: { en: "Device to data to interface.", tr: "Cihazdan veriye, veriden arayüze.", de: "Gerät zu Daten zu Schnittstelle.", fr: "Du dispositif aux données à l'interface.", es: "Del dispositivo a los datos a la interfaz.", it: "Dal dispositivo ai dati all'interfaccia.", ar: "من الجهاز إلى البيانات إلى الواجهة.", ja: "デバイスからデータ、インターフェースまで。" },
  device: { en: "Device", tr: "Cihaz", de: "Gerät", fr: "Dispositif", es: "Dispositivo", it: "Dispositivo", ar: "الجهاز", ja: "デバイス" },
  hwFirmware: { en: "Hardware + firmware", tr: "Donanım + yazılım", de: "Hardware + Firmware", fr: "Matériel + firmware", es: "Hardware + firmware", it: "Hardware + firmware", ar: "العتاد + البرمجيات", ja: "ハードウェア + ファームウェア" },
  data: { en: "Data", tr: "Veri", de: "Daten", fr: "Données", es: "Datos", it: "Dati", ar: "البيانات", ja: "データ" },
  apiPostgres: { en: "API + PostgreSQL", tr: "API + PostgreSQL", de: "API + PostgreSQL", fr: "API + PostgreSQL", es: "API + PostgreSQL", it: "API + PostgreSQL", ar: "API + PostgreSQL", ja: "API + PostgreSQL" },
  interface: { en: "Interface", tr: "Arayüz", de: "Schnittstelle", fr: "Interface", es: "Interfaz", it: "Interfaccia", ar: "الواجهة", ja: "インターフェース" },
  webMobileVr: { en: "Web + mobile + VR", tr: "Web + mobil + VR", de: "Web + Mobile + VR", fr: "Web + mobile + VR", es: "Web + móvil + VR", it: "Web + mobile + VR", ar: "ويب + جوال + واقع افتراضي", ja: "Web + モバイル + VR" },
  capabilities: { en: "capabilities", tr: "kabiliyet", de: "Fähigkeiten", fr: "capacités", es: "capacidades", it: "funzionalità", ar: "قدرات", ja: "対応技術" },
  deliveryLayers: { en: "delivery layers", tr: "teslimat katmanı", de: "Lieferschichten", fr: "couches de livraison", es: "capas de entrega", it: "livelli di consegna", ar: "طبقات التسليم", ja: "提供レイヤー" },
  systemView: { en: "system view", tr: "sistem görünümü", de: "Systemansicht", fr: "vue système", es: "vista del sistema", it: "vista di sistema", ar: "عرض النظام", ja: "統合システムビュー" },
  trustedByGlobal: { en: "Trusted by global teams", tr: "Küresel ekiplerin güvendiği yapı", de: "Vertrauen globaler Teams", fr: "Approuvé par des équipes mondiales", es: "Con la confianza de equipos globales", it: "Scelto da team globali", ar: "موثوق به من فرق عالمية", ja: "世界中のチームから信頼されています" },
  customerLogos: { en: "Customer logos", tr: "Müşteri logoları", de: "Kundenlogos", fr: "Logos clients", es: "Logos de clientes", it: "Loghi clienti", ar: "شعارات العملاء", ja: "顧客ロゴ" },
  exportCountries: { en: "+ 15 export countries", tr: "+ 15 ihracat ülkesi", de: "+ 15 Exportländer", fr: "+ 15 pays d'exportation", es: "+ 15 países de exportación", it: "+ 15 paesi di esportazione", ar: "+ 15 دولة تصدير", ja: "15か国以上への輸出実績" },
  serviceCapacity: { en: "Service capacity", tr: "Hizmet kapasitesi", de: "Servicekapazität", fr: "Capacité de service", es: "Capacidad de servicio", it: "Capacità di servizio", ar: "قدرة الخدمة", ja: "サービス対応力" },
  typicalOutputLabel: { en: "Typical output", tr: "Tipik teslimat", de: "Typische Ausgabe", fr: "Livrable type", es: "Entregable típico", it: "Output tipico", ar: "المخرجات النموذجية", ja: "主な納品物" },
  startDiscovery: { en: "Start Discovery", tr: "Keşif Başlat", de: "Entdeckung starten", fr: "Démarrer la découverte", es: "Iniciar descubrimiento", it: "Avvia scoperta", ar: "ابدأ الاستكشاف", ja: "要件定義の相談をする" },
  questionsBefore: { en: "Frequently asked", tr: "Sıkça Sorulan", de: "Häufig gestellte", fr: "Foire aux questions", es: "Preguntas frecuentes", it: "Domande frequenti", ar: "الأسئلة الشائعة", ja: "よくある質問" },
  talkToEngineering: { en: "Talk to Engineering", tr: "Mühendislerle Görüşün", de: "Mit Engineering sprechen", fr: "Parler à l'ingénierie", es: "Hablar con ingeniería", it: "Parla con il team", ar: "تحدث إلى الهندسة", ja: "技術チームへ相談" },
  startYourProject: { en: "Start Your Project", tr: "Projeye Başlayın", de: "Projekt starten", fr: "Démarrer le projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "ابدأ مشروعًا", ja: "プロジェクトを開始" },
};

const getLabel = (key: string) => {
  return (labels[key] as any)?.[locale] || (labels[key] as any)?.["en"] || key;
};

// CMS text with static fallback
const txt = (cmsKey: string, fallbackKey?: string) => {
  const cms = getVal(cmsKey);
  if (cms) return cms;
  if (fallbackKey && labels[fallbackKey]) return getLabel(fallbackKey);
  return "";
};

// ── Fallback data for service layers if CMS is empty ──
const fallbackServiceLayers = [
  { title: "Device engineering", headline: "Hardware, firmware and connectivity.", description: "For teams building physical IoT products that need reliable sensing, power, RF behavior and production-ready firmware.", output: "PCB package, firmware source, RF notes and production handoff.", tags: ["Embedded Hardware", "Firmware", "Connectivity"] },
  { title: "Cloud & data", headline: "Backend APIs and PostgreSQL architecture.", description: "For products that collect device data, need authentication, reporting, alerts, dashboards and scalable operational data models.", output: "API contracts, database schema, auth flow and reporting queries.", tags: ["Backend API", "PostgreSQL", "IoT Cloud"] },
  { title: "Operator interface", headline: "Web platforms, admin panels and mobile apps.", description: "For teams that need operators, customers and field technicians to actually use the connected product every day.", output: "Dashboards, mobile flows, user roles, alerts and portal screens.", tags: ["Web/Admin", "Mobile Apps", "Customer Portal"] },
  { title: "Immersive", headline: "VR, simulation and digital twin experiences.", description: "For products or environments that are hard to explain through flat screens, training documents or static presentations.", output: "Simulation scene, training flow, 3D presentation and demo assets.", tags: ["VR Training", "Product Demo", "Digital Twin"] },
];

const fallbackDeliverables = [
  { title: "Device package", description: "Schematics, PCB, BOM, prototype notes, RF and power decisions." },
  { title: "Firmware package", description: "Firmware source, drivers, protocol logic, OTA and low-power behavior." },
  { title: "Platform package", description: "API contracts, WebSocket events, PostgreSQL schema, auth and reporting flow." },
  { title: "Interface package", description: "Dashboard, admin panel, mobile app, roles, alerts and operator workflows." },
  { title: "Launch package", description: "Testing notes, deployment support, documentation and production handoff." },
];

const fallbackProcessSteps = [
  { title: "Analyze", description: "Requirements, field conditions, integrations and technical risks are clarified first." },
  { title: "Architect", description: "Hardware, firmware, API, database and interfaces are planned as one system." },
  { title: "Build", description: "The product is developed across layers without vendor hand-off gaps." },
  { title: "Validate", description: "RF, device stability, API reliability, UX and field readiness are tested together." },
];

const activeServiceLayers = serviceLayers.length > 0 ? serviceLayers : fallbackServiceLayers;
const activeDeliverables = deliverablesList.length > 0 ? deliverablesList : fallbackDeliverables;
const activeProcessSteps = processSteps.length > 0 ? processSteps : fallbackProcessSteps;

// hero texts
const heroEyebrow = txt("heroEyebrow") || getVal("heroEyebrow") || "";
const heroTitle = txt("heroTitle") || getVal("heroTitle") || "";
const heroLead = txt("heroLead") || getVal("heroLead") || "";

// section texts
const serviceSystemEyebrow = txt("serviceSystemEyebrow") || "Service system";
const serviceSystemTitle = txt("serviceSystemTitle") || "Choose one layer, or build the whole stack.";
const serviceSystemLead = txt("serviceSystemLead") || "The services are grouped by product layer, so buyers can quickly understand where WillowSoft fits.";

const deliverablesEyebrow = txt("deliverablesEyebrow") || "Deliverables";
const deliverablesTitle = txt("deliverablesTitle") || "What leaves the project, layer by layer.";
const deliverablesLead = txt("deliverablesLead") || "The deliverables are practical: source files, firmware, APIs, data models, dashboards and deployment documentation.";
const handoffTitle = txt("handoffTitle") || "Project handoff";
const handoffDesc = txt("handoffDesc") || "Every layer is documented so your internal team can operate, extend and audit the system.";

const caseStudiesEyebrow = txt("caseStudiesEyebrow") || "Case Studies";
const caseStudiesTitle = txt("caseStudiesTitle") || "Proven in production.";
const caseStudiesLead = txt("caseStudiesLead") || "See how WillowSoft's integrated hardware, firmware, and digital stack delivers measurable operational ROI for our clients.";

const processEyebrow = txt("processEyebrow") || "Concept to production";
const processTitle = txt("processTitle") || "A cleaner path from idea to deployed system.";

const ctaEyebrow = txt("ctaEyebrow") || "Start with engineering";
const ctaTitle = txt("ctaTitle") || "Ready to ship a connected product that actually works in the field?";
const ctaLead = txt("ctaLead") || "Tell us which layer you need first — hardware, firmware, backend, mobile, web or immersive — and WillowSoft engineering will respond with a discovery plan and a realistic timeline.";
const ctaPrimary = txt("ctaPrimaryButton") || getLabel("talkToEngineering");
const ctaSecondary = txt("ctaSecondaryButton") || getLabel("startYourProject");

const faqEyebrow = txt("faqEyebrow") || getLabel("questionsBefore");
const faqTitle = txt("faqTitle") || getVal("stackTitle") || "Questions before you brief us.";
const faqLead = txt("faqLead") || "Engineering buyers usually arrive with the same operational questions. Here are the answers — the rest happens in the discovery call.";
---

<PageLayout
  {...seoProps}
  schema={servicesSchema}
  locale={locale}
  dataPage="services"
>
  <main class="services-premium">
    <!-- HERO -->
    <section class="hero compact hero-services services-motion-hero">
      <canvas class="signal-canvas" data-density="34" data-color="24, 167, 255"></canvas>
      <div class="services-hero-light" aria-hidden="true"></div>
      <div class="hero-inner services-hero-grid">
        <div class="services-hero-copy">
          <p class="eyebrow reveal">{heroEyebrow}</p>
          <h1 class="reveal delay-1">{heroTitle}</h1>
          <p class="reveal delay-2">{heroLead}</p>
          <div class="services-hero-meta reveal delay-3" role="list" aria-label={getLabel("serviceCapacity")}>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket}</strong>
              <span>{getLabel("productsOnMarket")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="happyClients">{companyFacts.happyClients}</strong>
              <span>{getLabel("happyClients")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="founded">2020</strong>
              <span>{getLabel("founded")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="officesWorldwide">{companyFacts.officesWorldwide}</strong>
              <span>{getLabel("officesWorldwide")}</span>
            </span>
          </div>
        </div>
        <div class="service-architecture reveal delay-2" aria-label="Connected product architecture summary">
          <div class="architecture-deck architecture-deck-simple">
            <p class="architecture-label">{getLabel("serviceArchitecture")}</p>
            <h2>{getLabel("deviceToData")}</h2>
            <div class="architecture-flow">
              <div class="flow-node-large">
                <span>01</span>
                <strong>{getLabel("device")}</strong>
                <small>{getLabel("hwFirmware")}</small>
              </div>
              <div class="flow-node-large">
                <span>02</span>
                <strong>{getLabel("data")}</strong>
                <small>{getLabel("apiPostgres")}</small>
              </div>
              <div class="flow-node-large">
                <span>03</span>
                <strong>{getLabel("interface")}</strong>
                <small>{getLabel("webMobileVr")}</small>
              </div>
            </div>
            <div class="summary-metrics">
              <div>
                <strong>8</strong>
                <span>{getLabel("capabilities")}</span>
              </div>
              <div>
                <strong>4</strong>
                <span>{getLabel("deliveryLayers")}</span>
              </div>
              <div>
                <strong>1</strong>
                <span>{getLabel("systemView")}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section tight">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
      </div>
    </section>

    <!-- TRUSTED BY -->
    <section class="section trusted-by-section">
      <div class="section-inner">
        <div class="trusted-by-row reveal">
          <p class="trusted-by-label">{getLabel("trustedByGlobal")}</p>
          <div class="trusted-by-logos" aria-label={getLabel("customerLogos")}>
            {featuredClients.map((client: any) => (
              <div class="trusted-logo" title={client.name}>
                {client.logo ? <img src={`/${client.logo}`} alt={client.name} loading="lazy" decoding="async" /> : <strong>{client.name}</strong>}
              </div>
            ))}
          </div>
          <span class="trusted-by-pill">{getLabel("exportCountries")}</span>
        </div>
      </div>
    </section>

    <!-- SERVICE SYSTEM — dynamic from CMS -->
    <section class="section tight service-capabilities-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{serviceSystemEyebrow}</p>
            <h2>{serviceSystemTitle}</h2>
            <p class="section-lead">{serviceSystemLead}</p>
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/start-project`}>{getLabel("startDiscovery")}</a>
        </div>
        <div class="service-system-grid reveal delay-1">
          {activeServiceLayers.map((layer: any, idx: number) => {
            const title = getItemVal(layer, "title") || layer.title;
            const headline = getItemVal(layer, "headline") || layer.headline;
            const desc = getItemVal(layer, "description") || layer.description;
            const output = getItemVal(layer, "output") || layer.output;
            const tags = Array.isArray(layer.tags) ? layer.tags : (typeof layer.tags === "string" ? layer.tags.split(",").map((t: string) => t.trim()).filter(Boolean) : []);
            return (
              <article class="system-layer-card">
                <span class="layer-index">{String(idx + 1).padStart(2, "0")}</span>
                <p class="service-card-kicker">{title}</p>
                <h3>{headline}</h3>
                <p>{desc}</p>
                {tags.length > 0 && (
                  <div class="layer-services">
                    {tags.map((tag: string) => <span>{tag}</span>)}
                  </div>
                )}
                {output && (
                  <p class="layer-output">
                    <strong>{getLabel("typicalOutputLabel")}</strong> {output}
                  </p>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- DELIVERABLES — dynamic from CMS -->
    <section class="section service-outcomes-section">
      <div class="section-inner">
        <div class="deliverables-split">
          <div class="section-head reveal">
            <p class="eyebrow">{deliverablesEyebrow}</p>
            <h2 class="page-title">{deliverablesTitle}</h2>
            <p class="section-lead">{deliverablesLead}</p>
            <div class="handoff-note">
              <strong>{handoffTitle}</strong>
              <span>{handoffDesc}</span>
            </div>
          </div>
          <div class="deliverable-ledger reveal delay-1">
            {activeDeliverables.map((d: any) => {
              const dTitle = getItemVal(d, "title") || d.title;
              const dDesc = getItemVal(d, "description") || d.description;
              return (
                <div>
                  <span>{dTitle}</span>
                  <strong>{dDesc}</strong>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- CASE STUDIES — dynamic from CMS -->
    {caseStudies.length > 0 && (
      <section class="section services-case-studies-section" id="case-studies" style={{ background: "var(--surface)", borderTop: "1px solid var(--line)", borderBottom: "1px solid var(--line)" }}>
        <div class="section-inner">
          <div class="section-head reveal center" style={{ marginBottom: "48px" }}>
            <p class="eyebrow">{caseStudiesEyebrow}</p>
            <h2 class="page-title">{caseStudiesTitle}</h2>
            <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
              {caseStudiesLead}
            </p>
          </div>
          <div class="case-studies-list" style={{ display: "grid", gap: "64px" }}>
            {caseStudies.map((cs: any) => {
              const csTitle = getItemVal(cs, "title");
              const csSub = getItemVal(cs, "subtitle");
              const csProblem = getItemVal(cs, "problem");
              const csQuote = getItemVal(cs, "quote");
              const csQuoteAuthor = getItemVal(cs, "quoteAuthor");
              const csLogo = cs.logo || "";
              const s1Val = cs.stat1Value || "";
              const s1Label = getItemVal(cs, "stat1Label") || cs.stat1Label || "";
              const s2Val = cs.stat2Value || "";
              const s2Label = getItemVal(cs, "stat2Label") || cs.stat2Label || "";
              const s3Val = cs.stat3Value || "";
              const s3Label = getItemVal(cs, "stat3Label") || cs.stat3Label || "";
              return (
                <article class="split reveal" style={{ alignItems: "stretch" }}>
                  <div class="split-media" style={{ position: "relative", display: "flex", flexDirection: "column", justifyContent: "center", background: "rgba(255,255,255,0.8)", border: "1px solid var(--line)", overflow: "hidden", borderRadius: "var(--radius)", boxShadow: "var(--shadow)" }}>
                    {csLogo && (
                      <img src={csLogo.startsWith("http") ? csLogo : `${import.meta.env.BASE_URL}${csLogo.replace(/^\/+/, "")}`} alt={csTitle} style={{ maxHeight: "44px", width: "auto", objectFit: "contain", margin: "40px auto 20px", opacity: 0.85 }} />
                    )}
                    {(s1Val || s2Val || s3Val) && (
                      <div class="case-stats" style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "10px", padding: "20px", background: "rgba(240, 245, 255, 0.5)", borderTop: "1px solid var(--line)", textAlign: "center" }}>
                        {s1Val && <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>{s1Val}</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{s1Label}</span></div>}
                        {s2Val && <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>{s2Val}</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{s2Label}</span></div>}
                        {s3Val && <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>{s3Val}</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{s3Label}</span></div>}
                      </div>
                    )}
                  </div>
                  <div style={{ display: "flex", flexDirection: "column", justifyContent: "center" }}>
                    <p class="eyebrow" style={{ color: "var(--accent)", marginBottom: "8px" }}>{csTitle}</p>
                    <h3 style={{ fontFamily: "var(--font-display)", fontSize: "clamp(1.6rem, 2.4vw, 2.5rem)", margin: "0 0 16px", color: "var(--ink)", lineHeight: 1.1, letterSpacing: "-0.02em" }}>{csSub}</h3>
                    {csProblem && <p style={{ color: "var(--muted)", fontSize: "0.98rem", lineHeight: 1.6, margin: "0 0 20px 0" }} set:html={csProblem}></p>}
                    {csQuote && (
                      <blockquote style={{ margin: 0, paddingLeft: "20px", borderLeft: "3px solid var(--accent)", fontStyle: "italic", color: "var(--muted)", fontSize: "0.94rem", lineHeight: 1.55 }}>
                        {csQuote}
                        {csQuoteAuthor && <cite style={{ display: "block", marginTop: "8px", fontWeight: 700, fontStyle: "normal", fontSize: "0.82rem", textTransform: "uppercase", letterSpacing: "0.04em", color: "var(--ink)" }}>{csQuoteAuthor}</cite>}
                      </blockquote>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- PROCESS TIMELINE — dynamic from CMS -->
    <section class="section soft process-section">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{processEyebrow}</p>
          <h2>{processTitle}</h2>
        </div>
        <div class="process process-premium process-compact">
          {activeProcessSteps.map((step: any, idx: number) => {
            const stepTitle = getItemVal(step, "title") || step.title;
            const stepDesc = getItemVal(step, "description") || step.description;
            const delayClass = idx === 0 ? "" : ` delay-${Math.min(idx, 3)}`;
            return (
              <div class={`process-step reveal${delayClass}`}>
                <div class="step-dot">{idx + 1}</div>
                <article class="card process-card">
                  <h3>{stepTitle}</h3>
                  <p>{stepDesc}</p>
                </article>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "36px" }}>
          <p class="eyebrow">{faqEyebrow}</p>
          <h2 class="page-title">{faqTitle}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {faqLead}
          </p>
        </div>
        <FaqAccordion pageKey="services" faqs={content.faqs || []} locale={locale} />
      </div>
    </section>

    <!-- FINAL PREMIUM CTA -->
    <section class="section soft services-cta-section">
      <div class="section-inner">
        <div class="services-cta-block reveal">
          <div class="services-cta-content">
            <p class="eyebrow">{ctaEyebrow}</p>
            <h2 class="page-title">{ctaTitle}</h2>
            <p class="section-lead">{ctaLead}</p>
          </div>
          <div class="services-cta-actions">
            <a class="btn btn-primary" href={`/${locale}/contact`}>{ctaPrimary}</a>
            <a class="btn btn-secondary" href={`/${locale}/start-project`}>{ctaSecondary}</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

    description: { en: "RF, device stability, API reliability, UX and field readiness are tested together.", tr: "RF performansı, cihaz kararlılığı, API güvenilirliği, UX ve saha hazırlığı birlikte test edilir.", de: "RF, Gerätestabilität, API-Zuverlässigkeit, UX und Feldreife werden gemeinsam getestet.", fr: "RF, stabilité device, fiabilité API, UX et préparation terrain sont testés ensemble.", es: "RF, estabilidad del dispositivo, fiabilidad API, UX y preparación de campo se prueban juntos.", it: "RF, stabilità del device, affidabilità API, UX e prontezza sul campo vengono testati insieme.", ar: "نختبر أداء RF، واستقرار الجهاز، وموثوقية API، وUX، وجاهزية الميدان معًا.", ja: "RF、デバイス安定性、API 信頼性、UX、現場投入準備をまとめて検証します。" }
  },
];

const activeServiceLayers = serviceLayers.length > 0 ? serviceLayers : fallbackServiceLayers;
const activeDeliverables = deliverablesList.length > 0 ? deliverablesList : fallbackDeliverables;
const activeProcessSteps = processSteps.length > 0 ? processSteps : fallbackProcessSteps;

// hero texts
const heroEyebrow = txt("heroEyebrow") || getVal("heroEyebrow") || "";
const heroTitle = txt("heroTitle") || getVal("heroTitle") || "";
const heroLead = txt("heroLead") || getVal("heroLead") || "";

// section texts
const serviceSystemEyebrow = txt("serviceSystemEyebrow") || l({ en: "Service system", tr: "Hizmet yapısı", de: "Service-System", fr: "Système de services", es: "Sistema de servicios", it: "Sistema di servizi", ar: "هيكل الخدمات", ja: "サービス構成" });
const serviceSystemTitle = txt("serviceSystemTitle") || l({ en: "Choose one layer, or build the whole stack.", tr: "Tek bir katmanı seçin ya da tüm sistemi birlikte kurun.", de: "Wählen Sie einen Layer oder bauen Sie den ganzen Stack.", fr: "Choisissez un layer ou construisez tout le stack.", es: "Elija una capa o construya todo el stack.", it: "Scegli un layer o costruisci l’intero stack.", ar: "اختر طبقة واحدة أو ابنِ الـ stack بالكامل.", ja: "一つのレイヤーだけでも、全体のスタック構築でも対応します。" });
const serviceSystemLead = txt("serviceSystemLead") || l({ en: "The services are grouped by product layer, so buyers can quickly understand where WillowSoft fits.", tr: "Hizmetler ürün katmanlarına göre ayrılır; böylece WillowSoft'un projede nerede değer katacağı hızlıca anlaşılır.", de: "Die Services sind nach Produkt-Layern gruppiert, damit schnell klar wird, wo WillowSoft ins Projekt passt.", fr: "Les services sont regroupés par layer produit afin de voir rapidement où WillowSoft apporte de la valeur.", es: "Los servicios se agrupan por capa de producto para entender rápido dónde encaja WillowSoft.", it: "I servizi sono raggruppati per layer di prodotto, così è chiaro dove WillowSoft porta valore.", ar: "نرتّب الخدمات حسب طبقات المنتج حتى يتضح سريعًا أين تضيف WillowSoft قيمة.", ja: "サービスは製品レイヤーごとに整理され、WillowSoft がどこで価値を出せるかをすぐ把握できます。" });

const deliverablesEyebrow = txt("deliverablesEyebrow") || l({ en: "Deliverables", tr: "Teslimatlar", de: "Deliverables", fr: "Livrables", es: "Entregables", it: "Deliverable", ar: "المخرجات", ja: "納品物" });
const deliverablesTitle = txt("deliverablesTitle") || l({ en: "What leaves the project, layer by layer.", tr: "Projeden çıkan teslimatlar, katman katman.", de: "Was aus dem Projekt hervorgeht, Layer für Layer.", fr: "Ce qui sort du projet, layer par layer.", es: "Lo que entrega el proyecto, capa por capa.", it: "Cosa viene consegnato dal progetto, layer per layer.", ar: "ما يخرج من المشروع، طبقة بطبقة.", ja: "プロジェクトから生まれる成果物をレイヤーごとに。" });
const deliverablesLead = txt("deliverablesLead") || l({ en: "The deliverables are practical: source files, firmware, APIs, data models, dashboards and deployment documentation.", tr: "Teslimatlar doğrudan kullanılabilir varlıklardır: kaynak dosyaları, firmware, API'ler, veri modelleri, dashboard'lar ve deployment dokümantasyonu.", de: "Die Deliverables sind praktisch nutzbar: Quelldateien, Firmware, APIs, Datenmodelle, Dashboards und Deployment-Dokumentation.", fr: "Les livrables sont concrets : fichiers source, firmware, API, modèles de données, dashboards et documentation de deployment.", es: "Los entregables son prácticos: archivos fuente, firmware, API, modelos de datos, dashboards y documentación de deployment.", it: "I deliverable sono pratici: file sorgente, firmware, API, modelli dati, dashboard e documentazione di deployment.", ar: "المخرجات عملية: ملفات مصدر، وfirmware، وAPIs، ونماذج بيانات، وdashboards، ووثائق deployment.", ja: "納品物は実用的なものです。ソースファイル、ファームウェア、API、データモデル、ダッシュボード、デプロイ資料など。" });
const handoffTitle = txt("handoffTitle") || l({ en: "Project handoff", tr: "Proje devri", de: "Projektübergabe", fr: "Handoff projet", es: "Traspaso del proyecto", it: "Handoff del progetto", ar: "تسليم المشروع", ja: "プロジェクト引き渡し" });
const handoffDesc = txt("handoffDesc") || l({ en: "Every layer is documented so your internal team can operate, extend and audit the system.", tr: "Her katman dokümante edilir; böylece ekibiniz sistemi işletebilir, geliştirebilir ve denetleyebilir.", de: "Jeder Layer wird dokumentiert, damit Ihr internes Team das System betreiben, erweitern und prüfen kann.", fr: "Chaque layer est documenté pour que votre équipe puisse exploiter, faire évoluer et auditer le système.", es: "Cada capa queda documentada para que su equipo pueda operar, ampliar y auditar el sistema.", it: "Ogni layer è documentato, così il team interno può gestire, estendere e auditare il sistema.", ar: "نوثّق كل طبقة حتى يستطيع فريقك تشغيل النظام وتوسيعه وتدقيقه.", ja: "各レイヤーを文書化し、社内チームが運用、拡張、監査できる状態にします。" });

const caseStudiesEyebrow = txt("caseStudiesEyebrow") || l({ en: "Case Studies", tr: "Vaka çalışmaları", de: "Case Studies", fr: "Cas clients", es: "Casos de estudio", it: "Case study", ar: "دراسات حالة", ja: "導入事例" });
const caseStudiesTitle = txt("caseStudiesTitle") || l({ en: "Proven in production.", tr: "Sahada kanıtlanmış işler.", de: "In Produktion bewährt.", fr: "Prouvé en production.", es: "Probado en producción.", it: "Validato in produzione.", ar: "مثبت في بيئات الإنتاج.", ja: "本番環境で実証済み。" });
const caseStudiesLead = txt("caseStudiesLead") || l({ en: "See how WillowSoft's integrated hardware, firmware, and digital stack delivers measurable operational ROI for our clients.", tr: "WillowSoft'un entegre donanım, firmware ve dijital stack yaklaşımının müşteriler için nasıl ölçülebilir operasyonel değer ürettiğini görün.", de: "Sehen Sie, wie WillowSofts integrierter Hardware-, Firmware- und Digital-Stack messbaren operativen ROI liefert.", fr: "Découvrez comment le stack intégré hardware, firmware et digital de WillowSoft crée un ROI opérationnel mesurable.", es: "Vea cómo el stack integrado de hardware, firmware y digital de WillowSoft genera ROI operativo medible.", it: "Scopri come lo stack integrato hardware, firmware e digitale di WillowSoft genera ROI operativo misurabile.", ar: "تعرّف كيف يحقق stack WillowSoft المتكامل من hardware وfirmware والأنظمة الرقمية قيمة تشغيلية قابلة للقياس.", ja: "WillowSoft のハードウェア、ファームウェア、デジタルスタック統合が、測定可能な運用価値をどう生むかをご覧ください。" });

const processEyebrow = txt("processEyebrow") || l({ en: "Concept to production", tr: "Fikirden üretime", de: "Vom Konzept zur Produktion", fr: "Du concept à la production", es: "Del concepto a producción", it: "Dal concept alla produzione", ar: "من الفكرة إلى الإنتاج", ja: "構想から本番まで" });
const processTitle = txt("processTitle") || l({ en: "A cleaner path from idea to deployed system.", tr: "Fikirden sahada çalışan sisteme daha net bir yol.", de: "Ein klarerer Weg von der Idee zum produktiven System.", fr: "Un chemin plus clair de l’idée au système déployé.", es: "Un camino más claro desde la idea hasta el sistema desplegado.", it: "Un percorso più chiaro dall’idea al sistema in produzione.", ar: "مسار أوضح من الفكرة إلى نظام يعمل في الميدان.", ja: "アイデアから現場で動くシステムまで、より明確な進め方。" });

const ctaEyebrow = txt("ctaEyebrow") || l({ en: "Start with engineering", tr: "Mühendislikle başlayın", de: "Mit Engineering starten", fr: "Commencer avec l’ingénierie", es: "Empiece con ingeniería", it: "Parti dall’ingegneria", ar: "ابدأ من الهندسة", ja: "エンジニアリングから始める" });
const ctaTitle = txt("ctaTitle") || l({ en: "Ready to ship a connected product that actually works in the field?", tr: "Sahada gerçekten çalışan bir IoT ürünü çıkarmaya hazır mısınız?", de: "Bereit, ein IoT-Produkt auszuliefern, das im Feld wirklich funktioniert?", fr: "Prêt à lancer un produit IoT qui fonctionne vraiment sur le terrain ?", es: "¿Listo para lanzar un producto IoT que realmente funcione en campo?", it: "Pronto a lanciare un prodotto IoT che funziona davvero sul campo?", ar: "هل أنت مستعد لإطلاق منتج IoT يعمل فعلاً في الميدان؟", ja: "現場で本当に動く IoT 製品を出荷する準備はできていますか？" });
const ctaLead = txt("ctaLead") || l({ en: "Tell us which layer you need first — hardware, firmware, backend, mobile, web or immersive — and WillowSoft engineering will respond with a discovery plan and a realistic timeline.", tr: "Önceliğinizin hangi katman olduğunu anlatın: donanım, firmware, backend, mobil, web ya da VR/simülasyon. WillowSoft mühendislik ekibi size keşif planı ve gerçekçi bir zaman çizelgesiyle döner.", de: "Sagen Sie uns, welchen Layer Sie zuerst brauchen: Hardware, Firmware, Backend, Mobile, Web oder Immersive. WillowSoft Engineering meldet sich mit Discovery-Plan und realistischer Timeline.", fr: "Dites-nous quel layer est prioritaire : hardware, firmware, backend, mobile, web ou immersive. L’équipe engineering WillowSoft reviendra avec un plan de discovery et un calendrier réaliste.", es: "Cuéntenos qué capa necesita primero: hardware, firmware, backend, mobile, web o inmersiva. El equipo de ingeniería de WillowSoft responderá con un plan de discovery y un calendario realista.", it: "Dicci quale layer serve per primo: hardware, firmware, backend, mobile, web o immersive. Il team engineering WillowSoft risponderà con un piano di discovery e una timeline realistica.", ar: "أخبرنا أي طبقة تحتاجها أولًا: hardware أو firmware أو backend أو mobile أو web أو immersive. سيعود فريق WillowSoft الهندسي بخطة discovery وجدول زمني واقعي.", ja: "まず必要なレイヤーを教えてください。ハードウェア、ファームウェア、バックエンド、モバイル、Web、またはイマーシブ領域。WillowSoft のエンジニアリングチームが、ディスカバリープランと現実的なスケジュールを返します。" });
const ctaPrimary = txt("ctaPrimaryButton") || getLabel("talkToEngineering");
const ctaSecondary = txt("ctaSecondaryButton") || getLabel("startYourProject");

const faqEyebrow = txt("faqEyebrow") || getLabel("questionsBefore");
const faqTitle = txt("faqTitle") || getVal("stackTitle") || getLabel("faqTitleFallback");
const faqLead = txt("faqLead") || l({ en: "Engineering buyers usually arrive with the same operational questions. Here are the answers — the rest happens in the discovery call.", tr: "Teknik ekipler genelde benzer operasyon sorularıyla gelir. Kısa yanıtlar burada; geri kalanı keşif görüşmesinde netleşir.", de: "Technische Teams kommen meist mit ähnlichen operativen Fragen. Die kurzen Antworten stehen hier, der Rest klärt sich im Discovery Call.", fr: "Les équipes techniques arrivent souvent avec les mêmes questions opérationnelles. Les réponses courtes sont ici, le reste se précise en discovery call.", es: "Los equipos técnicos suelen llegar con preguntas operativas parecidas. Aquí están las respuestas cortas; el resto se aclara en la llamada de discovery.", it: "I team tecnici arrivano spesso con domande operative simili. Le risposte brevi sono qui; il resto si chiarisce nella discovery call.", ar: "تأتي الفرق التقنية غالبًا بأسئلة تشغيلية متشابهة. الإجابات المختصرة هنا، والباقي يتضح في مكالمة discovery.", ja: "技術チームからよく出る運用面の質問をまとめました。概要はここで確認でき、詳細はディスカバリーコールで詰めます。" });
---

<PageLayout
  {...seoProps}
  schema={servicesSchema}
  locale={locale}
  dataPage="services"
>
  <main class="services-premium">
    <!-- HERO -->
    <section class="hero compact hero-services services-motion-hero">
      <canvas class="signal-canvas" data-density="34" data-color="24, 167, 255"></canvas>
      <div class="services-hero-light" aria-hidden="true"></div>
      <div class="hero-inner services-hero-grid">
        <div class="services-hero-copy">
          <p class="eyebrow reveal">{heroEyebrow}</p>
          <h1 class="reveal delay-1">{heroTitle}</h1>
          <p class="reveal delay-2">{heroLead}</p>
          <div class="services-hero-meta reveal delay-3" role="list" aria-label={getLabel("serviceCapacity")}>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket}</strong>
              <span>{getLabel("productsOnMarket")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="happyClients">{companyFacts.happyClients}</strong>
              <span>{getLabel("happyClients")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="founded">2020</strong>
              <span>{getLabel("founded")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="officesWorldwide">{companyFacts.officesWorldwide}</strong>
              <span>{getLabel("officesWorldwide")}</span>
            </span>
          </div>
        </div>
        <div class="service-architecture reveal delay-2" aria-label="Connected product architecture summary">
          <div class="architecture-deck architecture-deck-simple">
            <p class="architecture-label">{getLabel("serviceArchitecture")}</p>
            <h2>{getLabel("deviceToData")}</h2>
            <div class="architecture-flow">
              <div class="flow-node-large">
                <span>01</span>
                <strong>{getLabel("device")}</strong>
                <small>{getLabel("hwFirmware")}</small>
              </div>
              <div class="flow-node-large">
                <span>02</span>
                <strong>{getLabel("data")}</strong>
                <small>{getLabel("apiPostgres")}</small>
              </div>
              <div class="flow-node-large">
                <span>03</span>
                <strong>{getLabel("interface")}</strong>
                <small>{getLabel("webMobileVr")}</small>
              </div>
            </div>
            <div class="summary-metrics">
              <div>
                <strong>8</strong>
                <span>{getLabel("capabilities")}</span>
              </div>
              <div>
                <strong>4</strong>
                <span>{getLabel("deliveryLayers")}</span>
              </div>
              <div>
                <strong>1</strong>
                <span>{getLabel("systemView")}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section tight">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
      </div>
    </section>

    <!-- TRUSTED BY -->
    <section class="section trusted-by-section">
      <div class="section-inner">
        <div class="trusted-by-row reveal">
          <p class="trusted-by-label">{getLabel("trustedByGlobal")}</p>
          <div class="trusted-by-logos" aria-label={getLabel("customerLogos")}>
            {featuredClients.map((client: any) => (
              <div class="trusted-logo" title={client.name}>
                {client.logo ? <img src={`/${client.logo}`} alt={client.name} loading="lazy" decoding="async" /> : <strong>{client.name}</strong>}
              </div>
            ))}
          </div>
          <span class="trusted-by-pill">{getLabel("exportCountries")}</span>
        </div>
      </div>
    </section>

    <!-- SERVICE SYSTEM — dynamic from CMS -->
    <section class="section tight service-capabilities-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{serviceSystemEyebrow}</p>
            <h2>{serviceSystemTitle}</h2>
            <p class="section-lead">{serviceSystemLead}</p>
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/start-project`}>{getLabel("startDiscovery")}</a>
        </div>
        <div class="service-system-grid reveal delay-1">
          {activeServiceLayers.map((layer: any, idx: number) => {
            const title = getItemVal(layer, "title", l(layer.title));
            const headline = getItemVal(layer, "headline", l(layer.headline));
            const desc = getItemVal(layer, "description", l(layer.description));
            const output = getItemVal(layer, "output", l(layer.output));
            const tags = Array.isArray(layer.tags) ? layer.tags : (typeof layer.tags === "string" ? layer.tags.split(",").map((t: string) => t.trim()).filter(Boolean) : []);
            return (
              <article class="system-layer-card">
                <span class="layer-index">{String(idx + 1).padStart(2, "0")}</span>
                <p class="service-card-kicker">{title}</p>
                <h3>{headline}</h3>
                <p>{desc}</p>
                {tags.length > 0 && (
                  <div class="layer-services">
                    {tags.map((tag: string) => <span>{tag}</span>)}
                  </div>
                )}
                {output && (
                  <p class="layer-output">
                    <strong>{getLabel("typicalOutputLabel")}</strong> {output}
                  </p>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- DELIVERABLES — dynamic from CMS -->
    <section class="section service-outcomes-section">
      <div class="section-inner">
        <div class="deliverables-split">
          <div class="section-head reveal">
            <p class="eyebrow">{deliverablesEyebrow}</p>
            <h2 class="page-title">{deliverablesTitle}</h2>
            <p class="section-lead">{deliverablesLead}</p>
            <div class="handoff-note">
              <strong>{handoffTitle}</strong>
              <span>{handoffDesc}</span>
            </div>
          </div>
          <div class="deliverable-ledger reveal delay-1">
            {activeDeliverables.map((d: any) => {
              const dTitle = getItemVal(d, "title", l(d.title));
              const dDesc = getItemVal(d, "description", l(d.description));
              return (
                <div>
                  <span>{dTitle}</span>
                  <strong>{dDesc}</strong>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- CASE STUDIES — dynamic from CMS -->
    {caseStudies.length > 0 && (
      <section class="section services-case-studies-section" id="case-studies" style={{ background: "var(--surface)", borderTop: "1px solid var(--line)", borderBottom: "1px solid var(--line)" }}>
        <div class="section-inner">
          <div class="section-head reveal center" style={{ marginBottom: "48px" }}>
            <p class="eyebrow">{caseStudiesEyebrow}</p>
            <h2 class="page-title">{caseStudiesTitle}</h2>
            <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
              {caseStudiesLead}
            </p>
          </div>
          <div class="case-studies-list" style={{ display: "grid", gap: "64px" }}>
            {caseStudies.map((cs: any) => {
              const csTitle = getItemVal(cs, "title");
              const csSub = getItemVal(cs, "subtitle");
              const csProblem = getItemVal(cs, "problem");
              const csQuote = getItemVal(cs, "quote");
              const csQuoteAuthor = getItemVal(cs, "quoteAuthor");
              const csLogo = cs.logo || "";
              const s1Val = cs.stat1Value || "";
              const s1Label = getItemVal(cs, "stat1Label") || cs.stat1Label || "";
              const s2Val = cs.stat2Value || "";
              const s2Label = getItemVal(cs, "stat2Label") || cs.stat2Label || "";
              const s3Val = cs.stat3Value || "";
              const s3Label = getItemVal(cs, "stat3Label") || cs.stat3Label || "";
              return (
                <article class="split reveal" style={{ alignItems: "stretch" }}>
                  <div class="split-media" style={{ position: "relative", display: "flex", flexDirection: "column", justifyContent: "center", background: "rgba(255,255,255,0.8)", border: "1px solid var(--line)", overflow: "hidden", borderRadius: "var(--radius)", boxShadow: "var(--shadow)" }}>
                    {csLogo && (
                      <img src={csLogo.startsWith("http") ? csLogo : `${import.meta.env.BASE_URL}${csLogo.replace(/^\/+/, "")}`} alt={csTitle} style={{ maxHeight: "44px", width: "auto", objectFit: "contain", margin: "40px auto 20px", opacity: 0.85 }} />
                    )}
                    {(s1Val || s2Val || s3Val) && (
                      <div class="case-stats" style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "10px", padding: "20px", background: "rgba(240, 245, 255, 0.5)", borderTop: "1px solid var(--line)", textAlign: "center" }}>
                        {s1Val && <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>{s1Val}</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{s1Label}</span></div>}
                        {s2Val && <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>{s2Val}</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{s2Label}</span></div>}
                        {s3Val && <div><strong style={{ display: "block", fontSize: "1.85rem", color: "var(--accent)", fontFamily: "var(--font-display)" }}>{s3Val}</strong><span style={{ fontSize: "0.74rem", color: "var(--muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.02em" }}>{s3Label}</span></div>}
                      </div>
                    )}
                  </div>
                  <div style={{ display: "flex", flexDirection: "column", justifyContent: "center" }}>
                    <p class="eyebrow" style={{ color: "var(--accent)", marginBottom: "8px" }}>{csTitle}</p>
                    <h3 style={{ fontFamily: "var(--font-display)", fontSize: "clamp(1.6rem, 2.4vw, 2.5rem)", margin: "0 0 16px", color: "var(--ink)", lineHeight: 1.1, letterSpacing: "-0.02em" }}>{csSub}</h3>
                    {csProblem && <p style={{ color: "var(--muted)", fontSize: "0.98rem", lineHeight: 1.6, margin: "0 0 20px 0" }} set:html={csProblem}></p>}
                    {csQuote && (
                      <blockquote style={{ margin: 0, paddingLeft: "20px", borderLeft: "3px solid var(--accent)", fontStyle: "italic", color: "var(--muted)", fontSize: "0.94rem", lineHeight: 1.55 }}>
                        {csQuote}
                        {csQuoteAuthor && <cite style={{ display: "block", marginTop: "8px", fontWeight: 700, fontStyle: "normal", fontSize: "0.82rem", textTransform: "uppercase", letterSpacing: "0.04em", color: "var(--ink)" }}>{csQuoteAuthor}</cite>}
                      </blockquote>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- PROCESS TIMELINE — dynamic from CMS -->
    <section class="section soft process-section">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{processEyebrow}</p>
          <h2>{processTitle}</h2>
        </div>
        <div class="process process-premium process-compact">
          {activeProcessSteps.map((step: any, idx: number) => {
            const stepTitle = getItemVal(step, "title", l(step.title));
            const stepDesc = getItemVal(step, "description", l(step.description));
            const delayClass = idx === 0 ? "" : ` delay-${Math.min(idx, 3)}`;
            return (
              <div class={`process-step reveal${delayClass}`}>
                <div class="step-dot">{idx + 1}</div>
                <article class="card process-card">
                  <h3>{stepTitle}</h3>
                  <p>{stepDesc}</p>
                </article>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "36px" }}>
          <p class="eyebrow">{faqEyebrow}</p>
          <h2 class="page-title">{faqTitle}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {faqLead}
          </p>
        </div>
        <FaqAccordion pageKey="services" faqs={content.faqs || []} locale={locale} />
      </div>
    </section>

    <!-- FINAL PREMIUM CTA -->
    <section class="section soft services-cta-section">
      <div class="section-inner">
        <div class="services-cta-block reveal">
          <div class="services-cta-content">
            <p class="eyebrow">{ctaEyebrow}</p>
            <h2 class="page-title">{ctaTitle}</h2>
            <p class="section-lead">{ctaLead}</p>
          </div>
          <div class="services-cta-actions">
            <a class="btn btn-primary" href={`/${locale}/contact`}>{ctaPrimary}</a>
            <a class="btn btn-secondary" href={`/${locale}/start-project`}>{ctaSecondary}</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

const getLabel = (key: keyof typeof labels) => {
  return labels[key][locale] || labels[key]["en"];
};
---

<PageLayout
  {...seoProps}
  schema={companySchema}
  locale={locale}
  dataPage="company"
>
  <main>
    <!-- Hero Section -->
    <section class="hero compact">
      <div class="hero-media">
        <img src={`${import.meta.env.BASE_URL}pdf-assets/p28_01_X104.jpg`} alt="WillowSoft office reception" loading="lazy" decoding="async" />
      </div>
      <canvas class="signal-canvas" data-density="30"></canvas>
      <div class="hero-inner">
        <p class="eyebrow reveal">{getVal("heroEyebrow")}</p>
        <h1 class="reveal delay-1" set:html={getLabel("teamBehindSystem")} />
        <p class="reveal delay-2">{getLabel("teamDesc")}</p>
      </div>
    </section>

    <!-- About Us Split Section -->
    <section class="section">
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getVal("introEyebrow")}</p>
          <h2 class="page-title">{getVal("introTitle")}</h2>
        </div>
        <div class="card reveal delay-1">
          <p>{getVal("introLead")}</p>
        </div>
      </div>
    </section>

    <!-- How We Work Section -->
    <section class="section soft">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{getVal("principlesEyebrow")}</p>
          <h2>{getVal("principlesTitle")}</h2>
        </div>
        <div class="grid grid-3">
          <article class="card reveal">
            <h3>{getLabel("productionFirstThinking")}</h3>
            <p>{getLabel("productionFirstThinkingDesc")}</p>
          </article>
          <article class="card reveal delay-1">
            <h3>{getLabel("fullStackOwnership")}</h3>
            <p>{getLabel("fullStackOwnershipDesc")}</p>
          </article>
          <article class="card reveal delay-2">
            <h3>{getLabel("longTermReliability")}</h3>
            <p>{getLabel("longTermReliabilityDesc")}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Company History Section -->
    <section class="section">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{getVal("historyEyebrow")}</p>
          <h2>{getVal("historyTitle")}</h2>
        </div>
        <div class="process">
          <div class="process-step reveal">
            <div class="step-dot">20</div>
            <article class="card">
              <h3>{getLabel("year2020Title")}</h3>
              <p>{getLabel("year2020Desc")}</p>
            </article>
          </div>
          <div class="process-step reveal">
            <div class="step-dot">23</div>
            <article class="card">
              <h3>{getLabel("year2023Title")}</h3>
              <p>{getLabel("year2023Desc")}</p>
            </article>
          </div>
          <div class="process-step reveal">
            <div class="step-dot">25</div>
            <article class="card">
              <h3>{getLabel("year2025Title")}</h3>
              <p>{getLabel("year2025Desc")}</p>
            </article>
          </div>
          <div class="process-step reveal">
            <div class="step-dot">26</div>
            <article class="card">
              <h3>{getLabel("year2026Title")}</h3>
              <p>{getLabel("year2026Desc")}</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- Who We Work With Section -->
    <section class="section soft">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">{getVal("workWithEyebrow")}</p>
          <h2>{getVal("workWithTitle")}</h2>
        </div>
        <div class="grid grid-3">
          <article class="card reveal">
            <h3>{getLabel("industryEnergy")}</h3>
            <p>{getLabel("industryEnergyDesc")}</p>
          </article>
          <article class="card reveal delay-1">
            <h3>{getLabel("consumerFmcg")}</h3>
            <p>{getLabel("consumerFmcgDesc")}</p>
          </article>
          <article class="card reveal delay-2">
            <h3>{getLabel("healthcareTelecoms")}</h3>
            <p>{getLabel("healthcareTelecomsDesc")}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Final CTA Section -->
    <section class="section dark">
      <canvas class="signal-canvas" data-density="26"></canvas>
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getVal("ctaEyebrow")}</p>
          <h2 class="page-title">{getVal("ctaTitle")}</h2>
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{getVal("ctaLead")}</p>
          <p><a class="btn btn-primary" href={`/${locale}/contact`}>{getLabel("getInTouch")}</a></p>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

          })}
        </div>
      </div>
    </section>

    {/* CoC_Offices */}
    <section class="company-section company-offices-c">
      <div class="company-container">
        <span class="eyebrow">{locale === 'tr' ? 'Küresel Varlık' : 'Global presence'}</span>
        <h2 class="ws-h2" style="margin-top: 18px; margin-bottom: 36px;">
          {locale === 'tr'
            ? <>İki ofis. <span class="serif-accent">Tek</span> ekip.</>
            : <>Two offices. <span class="serif-accent">One</span> team.</>}
        </h2>
        <div class="company-offices-grid">
          {(getFactList("officesList") || []).map((o: any) => {
            const office = localizeItem(o, locale);
            return (
              <div class="ws-card company-office-card">
                <div class="ws-placeholder-office company-office-visual">
                  <div class="company-office-map-layer" aria-hidden="true">
                    <span class="company-map-route"></span>
                    <span class="company-map-pin company-map-pin-main"></span>
                    <span class="company-map-pin company-map-pin-sub"></span>
                    <span class="company-map-label">{office.country}</span>
                  </div>
                  {hasUsableImage(office.image) && (
                    <img class="company-office-image" src={resolveAsset(office.image)} alt={office.country} loading="lazy" onerror="this.style.display='none';" />
                  )}
                </div>
                <div class="company-office-body">
                  <div style="display: flex; align-items: center; gap: 12px;">
                    <div class="ws-icbox" style="flex: 0 0 auto; color: var(--ws-teal);" set:html={getSvg('pin', 22)} />
                    <b style="font-size: 18px; font-weight: 700; color: var(--ws-ink);">{office.country}</b>
                  </div>
                  <div style="display: flex; flex-direction: column; gap: 10px; font-size: 15px; color: var(--ws-body); font-weight: 600;">
                    {office.phone && <span style="display: flex; align-items: center; gap: 10px;"><span style="display: inline-flex; color: var(--ws-muted); flex: 0 0 auto;" set:html={getSvg('phone', 16)} />{office.phone}</span>}
                    {office.email && <span style="display: flex; align-items: center; gap: 10px;"><span style="display: inline-flex; color: var(--ws-muted); flex: 0 0 auto;" set:html={getSvg('mail', 16)} />{office.email}</span>}
                    {office.address && <span style="display: flex; align-items: center; gap: 10px;"><span style="display: inline-flex; color: var(--ws-muted); flex: 0 0 auto;" set:html={getSvg('pin', 16)} />{office.address}</span>}
                  </div>
                </div>

        </div>
      </div>
    </section>

    {/* CoC_Timeline */}
    <section class="company-section company-timeline-c">
      <div class="company-container">
        <div class="company-grid-timeline-head">
          <div>
            <span class="eyebrow">{t("historyEyebrow", u("historyTimeline"))}</span>
            <h2 class="ws-h2" style="margin-top: 18px;" set:html={sectionTitle("historyTitle", locale === 'tr'
                ? 'Ar-Ge köklerinden <span class="serif-accent">küresel</span> dağıtıma.'
                : 'From R&D roots to <span class="serif-accent">global</span> deployment.')} />
          </div>
          <p class="ws-lead" style="align-self: end; padding-bottom: 4px;">
            {factText("historyLead", u("historyLead"))}
          </p>
        </div>
        
        <div class={`timeline-container-scroll ${sortedTimeline.length > 1 ? 'is-looping' : 'is-static'}`} data-company-timeline data-timeline-count={sortedTimeline.length}>
          <div class="timeline-viewport" data-timeline-viewport aria-hidden="true">
            <div class="timeline-track" data-timeline-track>
              {timelineCopies.map((copyIndex) => (
                <div class="timeline-sequence" data-timeline-sequence={copyIndex === 1 ? "anchor" : undefined}>
                  {sortedTimeline.map((item: any, i: number) => {
                    const isLast = i === sortedTimeline.length - 1;
                    return (
                      <div class={`timeline-item ${isLast ? 'is-latest' : ''}`} data-timeline-card-last={copyIndex === 1 && isLast ? "true" : undefined}>
                        <div class="timeline-dot"></div>
                        <div class="ws-card timeline-card">
                          <b class="timeline-year">{item.year}</b>
                          <b class="timeline-title">{item.title}</b>
                          <p>{item.body}</p>
                        </div>
                      </div>
                    );
                  })}
                </div>
              ))}
            </div>
          </div>
          <ol class="timeline-accessible-list" aria-label={u("historyTimeline")}>
            {sortedTimeline.map((item: any, i: number) => {
              const isLast = i === sortedTimeline.length - 1;
              return (
                <li class={`timeline-list-item ${isLast ? 'is-latest' : ''}`}>
                  <div class="timeline-dot"></div>
                  <div class="ws-card timeline-card">
                    <b class="timeline-year">{item.year}</b>
                    <b class="timeline-title">{item.title}</b>
                    <p>{item.body}</p>
                  </div>
                </li>
              );
            })}
          </ol>
        </div>
      </div>
    </section>

    {/* CoC_Expertise */}
    <section class="company-section company-expertise-c">
      <div class="company-container company-expertise-layout">
        <div class="company-expertise-copy">
            <span class="eyebrow">{factText("expertiseEyebrow", u("expertiseEyebrow"))}</span>
            <h2 class="ws-h2" style="margin-top: 18px;" set:html={factText("expertiseTitle", ui.expertiseTitleHtml[locale] || ui.expertiseTitleHtml.en)} />
          <p class="ws-lead">
            {factText("expertiseLead", u("expertiseLead"))}
          </p>
        </div>
        <div class="company-capability-panel">
          {sortByOrder(getFactList("expertise")).map((e: any, i: number) => {
            if (!e || typeof e !== "object") return null;
            const exp = localizeItem(e, locale);
            return (
              <div class="company-capability-row">
                <span class="company-capability-number">{String(i + 1).padStart(2, "0")}</span>
                <div class="ws-icbox" set:html={getSvg(exp?.icon || e?.icon, 24)} />
                <div class="company-capability-copy">
                  <b>{exp?.label || e?.label || ""}</b>
                  <span>{exp?.note || e?.note || ""}</span>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* CoC_Industries */}
    <section class="company-section bg-soft company-industries-section">
      <div class="company-container company-industries-layout">
        <div class="company-industries-copy">
            <span class="eyebrow">{t("workWithEyebrow", u("workWithUs"))}</span>
            <h2 class="ws-h2" style="margin-top: 18px;" set:html={sectionTitle("workWithTitle", locale === 'tr' ? 'Küresel ekipler WillowSoft\'a tek bir nedenle güvenir: Sonuç <span class="serif-accent">üretiriz</span>.' : 'Global teams trust WillowSoft for one reason: we <span class="serif-accent">deliver</span>.')} />
          <p class="ws-lead">
            {factText("workWithLead", u("workWithLead"))}
          </p>
        </div>
        <div class="company-industry-proof-list">
          {getFactList("industries").map((ind: any, i: number) => {
            if (!ind || typeof ind !== "object") return null;
            const industry = localizeItem(ind, locale);
            return (
              <div class="ws-card company-industry-proof">
                <span class="company-industry-index">{String(i + 1).padStart(2, "0")}</span>
                <div class="company-industry-icon" style={`background: ${industry?.c || ind?.c || "#e8eef8"}; color: ${industry?.t || ind?.t || "#132175"};`} set:html={getSvg(industry?.icon || ind?.icon, 24)} />
                <div class="company-industry-body">
                  <b>{industry?.name || ind?.name || ""}</b>
                  <span>{industry?.tag || ind?.tag || ""}</span>
                  <p>{industry?.body || ind?.body || ""}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* CoC_Offices */}
    <section class="company-section company-offices-c">
      <div class="company-container">
        <span class="eyebrow">{u("globalPresence")}</span>
        <h2 class="ws-h2" style="margin-top: 18px; margin-bottom: 36px;" set:html={ui.officesTitleHtml[locale] || ui.officesTitleHtml.en} />
        <div class="company-offices-grid">
          {getFactList("officesList").map((o: any) => {
            if (!o || typeof o !== "object") return null;
            const office = localizeItem(o, locale);
            return (
              <div class="ws-card company-office-card">
                <div class="ws-placeholder-office company-office-visual">
                  <div class="company-office-map-layer" aria-hidden="true">
                    <span class="company-map-route"></span>
                    <span class="company-map-pin company-map-pin-main"></span>
                    <span class="company-map-pin company-map-pin-sub"></span>
                    <span class="company-map-label">{office.country}</span>
                  </div>
                  {hasUsableImage(office.image) && (
                    <img class="company-office-image" src={resolveAsset(office.image)} alt={office.country} loading="lazy" onerror="this.style.display='none';" />
                  )}
                </div>
                <div class="company-office-body">
                  <div style="display: flex; align-items: center; gap: 12px;">
                    <div class="ws-icbox" style="flex: 0 0 auto; color: var(--ws-teal);" set:html={getSvg('pin', 22)} />
                    <b style="font-size: 18px; font-weight: 700; color: var(--ws-ink);">{office.country}</b>
                  </div>
                  <div style="display: flex; flex-direction: column; gap: 10px; font-size: 15px; color: var(--ws-body); font-weight: 600;">
                    {resolveOfficePhone(o, companyFacts) && (
                      <span style="display: flex; align-items: center; gap: 10px;">
                        <span style="display: inline-flex; color: var(--ws-muted); flex: 0 0 auto;" set:html={getSvg('phone', 16)} />
                        <a href={telHref(resolveOfficePhone(o, companyFacts))} style="color: inherit; text-decoration: none;">
                          {resolveOfficePhone(o, companyFacts)}
                        </a>
                      </span>
                    )}
                    {office.email && <span style="display: flex; align-items: center; gap: 10px;"><span style="display: inline-flex; color: var(--ws-muted); flex: 0 0 auto;" set:html={getSvg('mail', 16)} />{office.email}</span>}
                    {office.address && <span style="display: flex; align-items: center; gap: 10px;"><span style="display: inline-flex; color: var(--ws-muted); flex: 0 0 auto;" set:html={getSvg('pin', 16)} />{office.address}</span>}
                  </div>

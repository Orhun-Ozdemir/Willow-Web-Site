    ja: "BekoやCoca-Colaなどのブランドが、スマート家電や自販機等のコネクテッド製品のファームウェア、クラウドデータ基盤、モバイル画面の開発を委託。"
  },
  healthcareTelecoms: { en: "Healthcare & Telecoms", tr: "Sağlık & Telekom", de: "Gesundheitswesen & Telekommunikation", fr: "Santé & Télécoms", es: "Salud y telecomunicaciones", it: "Sanità e telecomunicazioni", ar: "الرعاية الصحية والاتصالات", ja: "医療・通信" },
  healthcareTelecomsDesc: {
    en: "Aero Healthcare and AT&T require the highest reliability standards. WillowSoft delivers embedded systems built for regulated environments and carrier-grade connectivity requirements.",

        </div>
      </div>
    </section>

    {/* CoC_Cta */}
    <section class="company-section company-cta-c" style="padding-top: 0;">
      <div class="company-container company-cta-inner" style="background: linear-gradient(135deg, var(--ws-hero-1), var(--ws-hero-2)); border-radius: 24px; color: #ffffff;">
        <div>
          <span class="eyebrow" style="color: var(--ws-teal);">{locale === 'tr' ? 'Bizimle Çalışın' : 'Work with us'}</span>
          <h2 style="font-size: clamp(1.7rem, 3.2vw, 2.6rem); font-weight: 700; color: #fff; letter-spacing: -.02em; line-height: 1.1; margin-top: 18px; max-width: 680px; text-wrap: balance;">
            {locale === 'tr'
              ? <>Uçtan uca tüm <span class="serif-accent">katmanları</span> yöneten bir ekiple çalışmaya hazır mısınız?</>
              : <>Ready to build with a team that owns the <span class="serif-accent">full stack</span>?</>}
          </h2>
          <p style="font-size: 16px; line-height: 1.65; color: rgba(255,255,255,.68); margin-top: 16px; max-width: 520px;">
            {locale === 'tr' ? 'Ne üretmek istediğinizi bize anlatın. Size mühendislik yaklaşımımızı sunalım.' : "Tell us what you're building. We'll tell you how we'd approach it."}
          </p>
          <div style="display: flex; flex-direction: column; gap: 11px; margin-top: 28px; font-size: 15px; color: rgba(255,255,255,.7); font-weight: 600;">
            <span style="display: flex; align-items: center; gap: 10px;"><span style="display: inline-flex; flex: 0 0 auto;" set:html={getSvg('phone', 16)} />+90 850 30 24766</span>
            <span style="display: flex; align-items: center; gap: 10px;"><span style="display: inline-flex; flex: 0 0 auto;" set:html={getSvg('mail', 16)} />info@willowsoft.co</span>
          </div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 14px; flex: 0 0 auto;">
          <a href={`/${locale}/start-project`} class="ws-btn ws-btn-light">{locale === 'tr' ? 'Proje başlatın' : 'Start a project'}</a>
          <a href={`/${locale}/contact`} class="ws-btn ws-btn-ghost">{locale === 'tr' ? 'İletişime geçin' : 'Get in touch'}</a>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-company-timeline]");
    if (!root) return;

    const count = Number(root.getAttribute("data-timeline-count") || "0");
    const viewport = root.querySelector("[data-timeline-viewport]");
    const track = root.querySelector("[data-timeline-track]");
    const anchorSequence = root.querySelector('[data-timeline-sequence="anchor"]');
    const anchorLast = root.querySelector('[data-timeline-card-last="true"]');
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const compactLayout = window.matchMedia("(max-width: 900px)");

    if (!viewport || !track || !anchorSequence || !anchorLast || count < 2) return;

    const setStatic = () => {
      track.classList.remove("is-ready");
      root.classList.add("is-static-mode");
      track.style.setProperty("--timeline-start", "0px");
      track.style.setProperty("--timeline-shift", "0px");
    };

    const measure = () => {
      track.classList.remove("is-ready");
      root.classList.remove("is-static-mode");
      track.style.setProperty("--timeline-start", "0px");
      track.style.setProperty("--timeline-shift", "0px");

      if (reducedMotion.matches || compactLayout.matches) {
        setStatic();
        return;
      }

      requestAnimationFrame(() => {
        const viewportRect = viewport.getBoundingClientRect();
        const lastRect = anchorLast.getBoundingClientRect();
        const sequenceWidth = anchorSequence.getBoundingClientRect().width;

        if (!viewportRect.width || !lastRect.width || !sequenceWidth) {
          setStatic();
          return;
        }

        const start = Math.round(viewportRect.right - lastRect.right);
        const shift = Math.round(sequenceWidth);
        const duration = Math.max(28, Math.min(58, count * 9));

        track.style.setProperty("--timeline-start", `${start}px`);
        track.style.setProperty("--timeline-shift", `${shift}px`);
        track.style.setProperty("--timeline-duration", `${duration}s`);
        void track.offsetWidth;
        track.classList.add("is-ready");
      });
    };

    const scheduleMeasure = () => {
      requestAnimationFrame(() => requestAnimationFrame(measure));
    };

    if (document.readyState === "complete") {
      scheduleMeasure();
    } else {
      window.addEventListener("load", scheduleMeasure, { once: true });
      scheduleMeasure();
    }

    window.addEventListener("resize", scheduleMeasure, { passive: true });
    reducedMotion.addEventListener?.("change", scheduleMeasure);
    compactLayout.addEventListener?.("change", scheduleMeasure);
  })();
</script>

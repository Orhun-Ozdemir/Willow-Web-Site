---
import PageLayout from "@/layouts/PageLayout.astro";
import { loadContent } from "@/lib/content";
import { pageSeo, webPageNode, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA, SITE_ORIGIN } from "@/lib/seo";
import { localizeItem, resolveAsset, localizedValue, locales, resolveLocale, type Locale } from "@/lib/cms";

export const prerender = false;

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const content = await loadContent();
const seoProps = pageSeo(content, "company", locale, "/company", "Company | WillowSoft", "About WillowSoft.");
const companySchema = {
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    {
      ...webPageNode("AboutPage", seoProps.canonical, seoProps.title, seoProps.description, locale),
      mainEntity: { "@id": `${SITE_ORIGIN}/#org` },
    },
  ],
};
const pageContent = content.pageContent?.company || {};
const getVal = (key: string) => localizedValue(pageContent[key], locale);

const companyFacts = content.companyFacts || {};

const cleanCmsText = (value: string) => {
  return value
    .replace(/\s*\(?\s*Validated\s*Test\s*\)?/gi, "")
    .replace(/\s+([.,;:!?])/g, "$1")
    .replace(/\s{2,}/g, " ")
    .trim();
};

const cleanCmsValue = (value: any): any => {
  if (typeof value === "string") return cleanCmsText(value);
  if (Array.isArray(value)) {
    return value
      .map((item) => cleanCmsValue(item))
      .filter((item) => !(typeof item === "string" && item.length === 0));
  }
  if (value && typeof value === "object") {
    return Object.fromEntries(
      Object.entries(value).map(([key, item]) => [key, cleanCmsValue(item)])
    );
  }
  return value;
};

const getFactVal = (key: string) => {
  const map = companyFacts[key];
  if (!map) return "";
  if (typeof map === "string") return cleanCmsValue(map);
  const localized = companyFacts.localized?.[locale]?.[key];
  return cleanCmsValue(localized || map || "");
};

const getFactList = (key: string) => {
  return cleanCmsValue(companyFacts[key] || []);
};

const sortByOrder = (items: any[]) => {
  return [...(Array.isArray(items) ? items : [])].sort((a, b) => {
    const orderA = Number.isFinite(Number(a?.sortOrder)) ? Number(a.sortOrder) : 9999;
    const orderB = Number.isFinite(Number(b?.sortOrder)) ? Number(b.sortOrder) : 9999;
    if (orderA !== orderB) return orderA - orderB;
    return String(a?.year || a?.name || "").localeCompare(String(b?.year || b?.name || ""));
  });
};

const sortedTeam = sortByOrder(getFactList("team")).map((item) => cleanCmsValue(localizeItem(item, locale)));
const sortedTimeline = sortByOrder(getFactList("timeline")).map((item) => cleanCmsValue(localizeItem(item, locale)));
const timelineCopies = [0, 1, 2];

const getInitials = (name: string) => {
  const initials = String(name || "")
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((word) => word[0])
    .join("")
    .toUpperCase();
  return initials || "WS";
};

const hasUsableImage = (path: unknown) => {
  const value = String(path || "").trim();
  return value.length > 0 && !/placeholder/i.test(value);
};

const SVGS: Record<string, string> = {
  cpu: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="15" x2="23" y2="15"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="15" x2="4" y2="15"></line></svg>`,
  globe: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>`,
  check: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`,
  server: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>`,
  shield: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
  terminal: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>`,
  phone: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`,
  gear: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>`,
  database: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"></path></svg>`,
  water: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-4.3-7-11-7-11S5 10.7 5 15a7 7 0 0 0 7 7z"></path></svg>`,
  mail: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 5L2 7"></path></svg>`,
  pin: `<svg viewBox="0 0 24 24" width="SIZE" height="SIZE" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>`,
};

const getSvg = (name: string, size = 20) => {
  const template = SVGS[name] || SVGS.globe;
  return template.replace(/SIZE/g, String(size));
};
---

<PageLayout
  {...seoProps}
  schema={companySchema}
  locale={locale}
  dataPage="company"
>
  <main>
    {/* CoC_Hero */}
    <div class="company-hero-c" style="background: var(--ws-navy-950); position: relative; overflow: hidden;">
      <canvas class="signal-canvas company-hero-signal" data-density="46" data-color="26, 163, 196"></canvas>
      {/* grid lines */}
      <svg style="position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.06; pointer-events: none;">
        <defs>
          <pattern id="cocGrid" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
            <path d="M80 0H0V80" fill="none" stroke="#7fa3d8" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#cocGrid)"/>
      </svg>

      <div class="hero-inner-c">
        <div style="display: flex; flex-direction: column; gap: 28px;">
          <span class="eyebrow" style="color: var(--ws-teal);">{locale === 'tr' ? 'WillowSoft Hakkında' : 'About WillowSoft'}</span>
          <h1 style="font-size: clamp(2.1rem, 4.2vw, 3.4rem); font-weight: 700; letter-spacing: -.03em; line-height: 1.02; color: #fff; margin: 0;">
            Smart <span class="serif-accent" style="color: var(--ws-teal); font-size: 1.05em;">Teams.</span><br/>Resilient Systems.
          </h1>
          <p style="font-size: 16px; line-height: 1.68; color: rgba(255,255,255,.62); max-width: 520px; margin: 0;">
            {getFactVal("heroSub")}
          </p>
          
          <div style="display: flex; gap: 14px; margin-top: 4px;">
            <a href={`/${locale}/start-project`} class="ws-btn ws-btn-primary">{locale === 'tr' ? 'Proje başlatın' : 'Start a project'}</a>
            <a href={`/${locale}/contact`} class="ws-btn ws-btn-ghost">{locale === 'tr' ? 'İletişime geçin' : 'Get in touch'}</a>
          </div>
        </div>
      </div>
    </div>

    {/* CoC_Stats */}
    <div style="margin-top: 0; position: relative; z-index: 10; width: min(var(--max), calc(100% - 40px)); margin-left: auto; margin-right: auto;" class="company-stats-wrap">
      <div class="ws-card" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); padding: 36px 16px; box-shadow: 0 20px 56px rgba(13,27,62,.12); background: #ffffff;">
        <div class="ws-stat" style="padding: 0 32px;">
          <b>{getFactVal("founded")}</b>
          <span>{locale === 'tr' ? 'Kuruluş Yılı' : 'Year founded'}</span>
        </div>
        <div class="ws-stat" style="padding: 0 32px;" id="stat-border-1">
          <b>{getFactVal("countries")}</b>
          <span>{locale === 'tr' ? 'Ülkeye İhracat' : 'Countries deployed'}</span>
        </div>
        <div class="ws-stat" style="padding: 0 32px;" id="stat-border-2">
          <b>6 yrs</b>
          <span>{locale === 'tr' ? 'Sürekli Ar-Ge' : 'Continuous R&D'}</span>
        </div>
        <div class="ws-stat" style="padding: 0 32px;" id="stat-border-3">
          <b>Full-<br class="company-stat-mobile-break" />stack</b>
          <span>HW · FW · Cloud</span>
        </div>
      </div>
    </div>

    {/* CoC_About */}
    <section class="company-section company-about-c">
      <div class="company-container company-grid-2">
        <div style="display: flex; flex-direction: column; gap: 22px;">
          <span class="eyebrow">{locale === 'tr' ? 'Hakkımızda' : 'About us'}</span>
          <h2 class="ws-h2" style="font-size: clamp(2rem, 3.4vw, 2.75rem); text-wrap: balance;">
            {getFactVal("aboutHeadline")}
          </h2>
          <ul class="ws-bullets" style="margin-top: 4px;">
            <li>{locale === 'tr' ? 'Yıllarca müdahalesiz çalışma için optimize edilmiş düşük güç tüketimli mimari' : 'Low-power architecture optimized for years of unattended operation'}</li>
            <li>{locale === 'tr' ? 'Her türlü kutu, RF ve güç kısıtlaması için özel donanım tasarımı' : 'Custom hardware design for every enclosure, RF and power constraint'}</li>
            <li>{locale === 'tr' ? 'Kendi bünyemizde geliştirilen bulut ve arayüz katmanları — entegrasyon borcu yok' : 'Backend, cloud and interface layers built in-house — no integration debt'}</li>
            <li>{locale === 'tr' ? 'Üretime hazır: ilk prototipten sertifikalı, üretilmiş ürüne kadar' : 'Production-ready: from first prototype to certified, manufactured product'}</li>
          </ul>
        </div>
        <div style="display: flex; flex-direction: column; gap: 18px; padding-top: 8px;">
          <p style="font-size: 16px; line-height: 1.72; color: var(--ws-body); margin: 0;">
            {getFactVal("aboutSub")}
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 9px; margin-top: 4px;">
            {((getFactList("aboutTags") as string[]) || []).map((t: string) => (
              <span class="ws-chip">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* CoC_MV */}
    <section class="company-section company-mv-c" style="padding-top: 0;">
      <div class="company-container company-grid-2" style="gap: 20px;">
        <div style="background: linear-gradient(140deg, #1e1b4b, #132175); border-radius: 22px; padding: 56px 60px; display: flex; flex-direction: column; gap: 20px; color: #ffffff;">
          <span style="font-size: 12px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; color: var(--ws-teal);">MISSION</span>
          <p style="font-size: 19px; font-weight: 600; line-height: 1.5; margin: 0; text-wrap: balance;">
            "{getFactVal("mission")}"
          </p>
        </div>
        <div style="background: #f4f6fb; border: 1.5px solid var(--ws-line); border-radius: 22px; padding: 56px 60px; display: flex; flex-direction: column; gap: 20px;">
          <span style="font-size: 12px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; color: var(--ws-blue);">VISION</span>
          <p style="font-size: 19px; font-weight: 600; line-height: 1.5; color: var(--ws-ink); margin: 0; text-wrap: balance;">
            "{getFactVal("vision")}"
          </p>
        </div>
      </div>
    </section>

    {/* CoC_Team */}
    <section class="company-section bg-soft company-team-section">
      <div class="company-container company-grid-team">
        <div>
          <span class="eyebrow">{locale === 'tr' ? 'Ekibimiz' : 'The team'}</span>
          <h2 class="ws-h2" style="margin-top: 18px;">
            {locale === 'tr'
              ? <>Mühendisliğin arkasındaki <span class="serif-accent">insanlar</span>.</>
              : <>Meet the people behind the <span class="serif-accent">engineering</span>.</>}
          </h2>
          <p style="font-size: 16px; line-height: 1.65; color: var(--ws-body); margin-top: 16px;">
            {locale === 'tr' ? 'Kurucu mühendislerimiz ve IIoT mimarlarımız.' : 'Our core team of hardware engineers, firmware developers, and cloud architects.'}
          </p>
        </div>
        <div class="company-team-list">
          {sortedTeam.map((member: any) => {
            return (
              <div class="ws-card company-team-card">
                <div class="ws-placeholder-avatar company-team-avatar">
                  <span class="company-team-initials">{getInitials(member.name)}</span>
                  {hasUsableImage(member.image) && (
                    <img class="company-team-image" src={resolveAsset(member.image)} alt={member.name} loading="lazy" onerror="this.style.display='none';" />
                  )}
                </div>
                <div class="company-team-body">
                  <b>{member.name}</b>
                  <span>{member.role}</span>
                  <p>{member.bio}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* CoC_Principles */}
    <section class="company-section company-principles-c">
      <div class="company-container">
        <div class="company-grid-principles-head">
          <div>
            <span class="eyebrow">{locale === 'tr' ? 'Nasıl Çalışırız' : 'How we work'}</span>
            <h2 class="ws-h2" style="margin-top: 18px;">
              {locale === 'tr'
                ? <>Taviz vermediğimiz mühendislik <span class="serif-accent">ilkeleri</span>.</>
                : <>Engineering principles we don't <span class="serif-accent">compromise</span> on.</>}
            </h2>
          </div>
          <div class="company-proof-chips">
            {(getFactList("whyUs") || []).map((w: any) => (
              <div class="company-proof-chip">
                <div class="ws-icbox" style="flex: 0 0 auto;" set:html={getSvg(w.icon, 20)} />
                <span>{w.title}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="company-principles-list">
          {(getFactList("principles") || []).map((p: any) => {
            const principle = localizeItem(p, locale);
            return (
              <div class="ws-card company-principle-card">
                <div class="company-principle-top">
                  <span>{principle.n}</span>
                  <div class="ws-icbox" set:html={getSvg(principle.icon, 22)} />
                </div>
                <h3 class="ws-h3">{principle.title}</h3>
                <p>{principle.body}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* CoC_Timeline */}
    <section class="company-section company-timeline-c">
      <div class="company-container">
        <div class="company-grid-timeline-head">
          <div>
            <span class="eyebrow">{locale === 'tr' ? 'Şirket Geçmişi' : 'Company history'}</span>
            <h2 class="ws-h2" style="margin-top: 18px;">
              {locale === 'tr'
                ? <>Ar-Ge köklerinden <span class="serif-accent">küresel</span> dağıtıma.</>
                : <>From R&D roots to <span class="serif-accent">global</span> deployment.</>}
            </h2>
          </div>
          <p class="ws-lead" style="align-self: end; padding-bottom: 4px;">
            {locale === 'tr' 
              ? '6 yıllık istikrarlı büyüme — odaklanmış bir mühendislik stüdyosundan uluslararası ölçekte konuşlandırılmış bir IoT şirketine.' 
              : 'Six years of steady growth — from a focused engineering studio to an internationally deployed IoT company.'}
          </p>
        </div>
        
        <div class={`timeline-container-scroll ${sortedTimeline.length > 1 ? 'is-looping' : 'is-static'}`} data-company-timeline data-timeline-count={sortedTimeline.length}>
          <div class="timeline-viewport" data-timeline-viewport aria-hidden="true">
            <div class="timeline-track" data-timeline-track>
              {timelineCopies.map((copyIndex) => (
                <div class="timeline-sequence" data-timeline-sequence={copyIndex === 1 ? "anchor" : undefined}>
                  {sortedTimeline.map((item: any, i: number) => {
                    const isLast = i === sortedTimeline.length - 1;
                    return (
                      <div class={`timeline-item ${isLast ? 'is-latest' : ''}`} data-timeline-card-last={copyIndex === 1 && isLast ? "true" : undefined}>
                        <div class="timeline-dot"></div>
                        <div class="ws-card timeline-card">
                          <b class="timeline-year">{item.year}</b>
                          <b class="timeline-title">{item.title}</b>
                          <p>{item.body}</p>
                        </div>
                      </div>
                    );
                  })}
                </div>
              ))}
            </div>
          </div>
          <ol class="timeline-accessible-list" aria-label={locale === 'tr' ? 'Şirket zaman çizelgesi' : 'Company timeline'}>
            {sortedTimeline.map((item: any, i: number) => {
              const isLast = i === sortedTimeline.length - 1;
              return (
                <li class={`timeline-list-item ${isLast ? 'is-latest' : ''}`}>
                  <div class="timeline-dot"></div>
                  <div class="ws-card timeline-card">
                    <b class="timeline-year">{item.year}</b>
                    <b class="timeline-title">{item.title}</b>
                    <p>{item.body}</p>
                  </div>
                </li>
              );
            })}
          </ol>
        </div>
      </div>
    </section>

    {/* CoC_Expertise */}
    <section class="company-section company-expertise-c">
      <div class="company-container company-expertise-layout">
        <div class="company-expertise-copy">
            <span class="eyebrow">{locale === 'tr' ? 'Uzmanlık Alanlarımız' : 'Core expertise'}</span>
            <h2 class="ws-h2" style="margin-top: 18px;">
              {locale === 'tr'
                ? <>Asıl <span class="serif-accent">iyi</span> olduğumuz işler.</>
                : <>What we are actually <span class="serif-accent">good</span> at.</>}
            </h2>
          <p class="ws-lead">
            {locale === 'tr'
              ? 'Silikondan buluta kadar tüm IoT ürün yaşam döngüsünü kapsayan altı temel uzmanlık katmanı.'
              : 'Six deep competencies covering the entire IoT product lifecycle — from silicon to cloud.'}
          </p>
        </div>
        <div class="company-capability-panel">
          {(getFactList("expertise") || []).map((e: any, i: number) => (
            <div class="company-capability-row">
              <span class="company-capability-number">{String(i + 1).padStart(2, "0")}</span>
              <div class="ws-icbox" set:html={getSvg(e.icon, 24)} />
              <div class="company-capability-copy">
                <b>{e.label}</b>
                <span>{e.note}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CoC_Industries */}
    <section class="company-section bg-soft company-industries-section">
      <div class="company-container company-industries-layout">
        <div class="company-industries-copy">
            <span class="eyebrow">{locale === 'tr' ? 'Birlikte Çalıştıklarımız' : 'Who we work with'}</span>
            <h2 class="ws-h2" style="margin-top: 18px;">
              {locale === 'tr'
                ? <>Küresel ekipler WillowSoft'a tek bir nedenle güvenir: Sonuç <span class="serif-accent">üretiriz</span>.</>
                : <>Global teams trust WillowSoft for one reason: we <span class="serif-accent">deliver</span>.</>}
            </h2>
          <p class="ws-lead">
            {locale === 'tr'
              ? 'Fortune 500 endüstriyel devlerinden hızlı tüketim markalarına kadar — güvenilirliğin isteğe bağlı olmadığı zorlu çalışma koşulları.'
              : 'From Fortune 500 industrials to fast-moving consumer brands — demanding environments where reliability is not optional.'}
          </p>
        </div>
        <div class="company-industry-proof-list">
          {(getFactList("industries") || []).map((ind: any, i: number) => {
            const industry = localizeItem(ind, locale);
            return (

---
import PageLayout from "@/layouts/PageLayout.astro";
import SolutionCard from "@/components/SolutionCard.astro";
import FaqAccordion from "@/components/FaqAccordion.astro";
import AIAnswerBlock from "@/components/AIAnswerBlock.astro";
import { loadContent } from "@/lib/content";
import { pageSeo, webPageNode, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA } from "@/lib/seo";
import { localizedValue, resolveAsset, locales, resolveLocale, type Locale, localizeItem } from "@/lib/cms";
import { aiAnswerForPage, aiMetaForPage, appendSchemaNodes, fallbackFaqsForPage, faqItemsForPage, faqSchemaNode } from "@/lib/ai-search";

export const prerender = false;

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const content = await loadContent();
const seoProps = pageSeo(content, "solutions", locale, "/solutions", "Solutions | WillowSoft", "Industry-specific IoT solutions.");
const pageContent = content.pageContent?.solutions || {};
const getVal = (key: string) => localizedValue(pageContent[key], locale);
const solutionsFallbackFaqs = fallbackFaqsForPage("solutions", locale);
const solutionsFaqItems = faqItemsForPage(content.faqs || [], "solutions", locale, solutionsFallbackFaqs);
const aiAnswer = aiAnswerForPage(content, "solutions", locale, seoProps.description);
const aiMeta = aiMetaForPage(content, "solutions", locale);

const solutions = (content.solutions || []).sort((a: any, b: any) => (a.sortOrder || 0) - (b.sortOrder || 0));
const allProducts = content.products || [];
const solutionCategories = ["All", ...Array.from(new Set(solutions.map((s: any) => s.category).filter(Boolean)))];

const categoryLabelMap = new Map<string, string>();
for (const sol of solutions) {
  const loc = localizeItem(sol, locale);
  if (sol.category && loc.category) categoryLabelMap.set(sol.category, loc.category);
}
const solutionsSchema = appendSchemaNodes({
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    webPageNode("CollectionPage", seoProps.canonical, seoProps.title, seoProps.description, locale),
  ],
}, [faqSchemaNode(seoProps.canonical, solutionsFaqItems)]);

const selectorCards = pageContent.selectorCards || [];
const howItWorksSteps = pageContent.howItWorksSteps || [];
const whyCards = pageContent.whyCards || [];

const labels = {
  filterAll: { en: "All", tr: "Tümü", de: "Alle", fr: "Tous", es: "Todos", it: "Tutti", ar: "الكل", ja: "すべて" },
  exploreDevices: { en: "Explore Devices", tr: "Cihazları İnceleyin", de: "Geräte entdecken", fr: "Découvrir les appareils", es: "Explorar dispositivos", it: "Esplora i dispositivi", ar: "استكشف الأجهزة", ja: "製品を見る" },
  solutionStack: { en: "Solution Stack", tr: "Çözüm Katmanları", de: "Lösungs-Stack", fr: "Pile solution", es: "Capas de la solución", it: "Stack soluzione", ar: "طبقات الحل", ja: "ソリューション構成" },
  stackFieldSensing: { en: "Field sensing", tr: "Saha algılama", de: "Feldsensorik", fr: "Capteurs terrain", es: "Sensado en campo", it: "Rilevamento sul campo", ar: "الاستشعار الميداني", ja: "現場センシング" },
  stackTransmission: { en: "Low-power transmission", tr: "Düşük güç iletimi", de: "Stromsparende Übertragung", fr: "Transmission basse consommation", es: "Transmisión de bajo consumo", it: "Trasmissione a basso consumo", ar: "نقل منخفض الطاقة", ja: "低消費電力通信" },
  stackBackend: { en: "Backend processing", tr: "Arka uç işleme", de: "Backend-Verarbeitung", fr: "Traitement backend", es: "Procesamiento backend", it: "Elaborazione backend", ar: "معالجة الخلفية", ja: "バックエンド処理" },
  stackDashboards: { en: "Dashboards & mobile alerts", tr: "Paneller ve mobil uyarılar", de: "Dashboards & mobile Alarme", fr: "Tableaux de bord et alertes mobiles", es: "Paneles y alertas móviles", it: "Dashboard e avvisi mobili", ar: "لوحات وتنبيهات جوال", ja: "ダッシュボードとモバイル通知" },
  startWithSite: { en: "Start with Your Site", tr: "Sahanızla Başlayın", de: "Mit Ihrem Standort starten", fr: "Commencer par votre site", es: "Empiece por su sitio", it: "Inizia dal tuo sito", ar: "ابدأ من موقعك", ja: "現場から始める" },
  metric1: { en: "countries with active deployments", tr: "aktif kurulum yapılan ülke", de: "Länder mit aktiven Einsätzen", fr: "pays avec des déploiements actifs", es: "países con despliegues activos", it: "paesi con installazioni attive", ar: "دولة بنشرات نشطة", ja: "導入実績のある国" },
  metric2: { en: "R&D-first engineering foundation", tr: "Ar-Ge odaklı mühendislik temeli", de: "F&E-orientierte technische Basis", fr: "fondation d'ingénierie axée sur la R&D", es: "base de ingeniería orientada a I+D", it: "fondamento ingegneristico orientato alla R&S", ar: "أساس هندسي يركز على البحث والتطوير", ja: "研究開発重視のエンジニアリング基盤" },
  metric3: { en: "remote visibility for critical assets", tr: "kritik varlıklar için 24/7 uzaktan görünürlük", de: "Fernüberwachung kritischer Anlagen rund um die Uhr", fr: "visibilité à distance 24/7 pour les actifs critiques", es: "visibilidad remota 24/7 para activos críticos", it: "visibilità remota 24/7 per asset critici", ar: "رؤية عن بُعد على مدار الساعة للأصول الحرجة", ja: "重要資産の24時間遠隔可視化" },
  operationalCoverage: { en: "Operational Coverage", tr: "Operasyonel Kapsam", de: "Betriebliche Abdeckung", fr: "Couverture opérationnelle", es: "Cobertura operativa", it: "Copertura operativa", ar: "التغطية التشغيلية", ja: "業務のカバー範囲" },
  startProject: { en: "Start Project", tr: "Projeyi Başlat", de: "Projekt starten", fr: "Démarrer le projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "بدء المشروع", ja: "プロジェクト相談" },
  useCases: { en: "Use Cases", tr: "Kullanım Alanları", de: "Anwendungsbereiche", fr: "Cas d'usage", es: "Casos de uso", it: "Casi d'uso", ar: "حالات الاستخدام", ja: "ユースケース" },
  whyWillowSoft: { en: "Why WillowSoft", tr: "Neden WillowSoft", de: "Warum WillowSoft", fr: "Pourquoi WillowSoft", es: "Por qué WillowSoft", it: "Perché WillowSoft", ar: "لماذا WillowSoft", ja: "WillowSoftの強み" },
  mapCase: { en: "Map Your Use Case", tr: "Kullanım Senaryonuzu Belirleyin", de: "Anwendungsfall zuordnen", fr: "Cartographier votre cas d'usage", es: "Defina su caso de uso", it: "Mappa il tuo caso d'uso", ar: "حدّد حالة الاستخدام", ja: "ユースケースを相談" },
  faqEyebrow: { en: "Frequently asked", tr: "Sıkça sorulanlar", de: "Häufig gestellte Fragen", fr: "Questions fréquentes", es: "Preguntas frecuentes", it: "Domande frequenti", ar: "أسئلة شائعة", ja: "よくある質問" },
  faqTitle: { en: "Questions about our solutions.", tr: "Çözümlerimiz hakkında sorular.", de: "Fragen zu unseren Lösungen.", fr: "Questions sur nos solutions.", es: "Preguntas sobre nuestras soluciones.", it: "Domande sulle nostre soluzioni.", ar: "أسئلة حول حلولنا.", ja: "ソリューションに関するご質問" },
  faqLead: {
    en: "Here are the answers to the most common questions about our IoT capabilities and deployments.",
    tr: "IoT yeteneklerimiz ve kurulumlarımız hakkında en sık sorulan soruların yanıtları.",
    de: "Hier finden Sie Antworten auf die häufigsten Fragen zu unseren IoT-Funktionen und -Bereitstellungen.",
    fr: "Voici les réponses aux questions les plus courantes sur nos capacités IoT et nos déploiements.",
    es: "Aquí encontrará respuestas a las preguntas más comunes sobre nuestras capacidades y despliegues de IoT.",
    it: "Ecco le risposte alle domande più comuni sulle nostre capacità e installazioni IoT.",
    ar: "إليك إجابات الأسئلة الأكثر شيوعًا حول قدرات إنترنت الأشياء وعمليات النشر لدينا.",
    ja: "IoT機能と導入実績に関する最も一般的な質問への回答です。"
  }
};

const getLabel = (key: keyof typeof labels) => {
  return labels[key][locale] || labels[key]["en"];
};

const categoryName = (cat: string) =>
  cat === "All" ? getLabel("filterAll") : (categoryLabelMap.get(cat) || cat);
---

<PageLayout
  {...seoProps}
  schema={solutionsSchema}
  locale={locale}
  dataPage="solutions"
>
  <main>
    <!-- Hero — Hakkımızda ile aynı company-hero-c + signal-canvas -->
    <div class="company-hero-c" style="background: #070d19; position: relative; overflow: hidden;">
      <canvas class="signal-canvas company-hero-signal" data-density="46" data-color="26, 163, 196"></canvas>

      <svg class="solutions-hero-grid" aria-hidden="true" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="solutionsHeroGrid" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
            <path d="M80 0H0V80" fill="none" stroke="#7fa3d8" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#solutionsHeroGrid)"/>
      </svg>

      <div class="solutions-hero-inner">
        <div class="solutions-hero-content reveal">
          <p class="eyebrow">{getVal("heroEyebrow") || "Industrial IoT Solutions"}</p>

          <h1 set:html={getVal("heroTitle") || "Connected solutions for assets, sites and operations that cannot fail."} />

          <p>{getVal("heroLead") || "WillowSoft connects field sensors, LoRaWAN devices, gateways, APIs, dashboards and mobile workflows into one reliable industrial IoT ecosystem."}</p>

          <div class="solutions-hero-actions">
            <a class="ws-btn ws-btn-primary" href={`/${locale}/start-project`}>{getLabel("mapCase")}</a>
            <a class="ws-btn ws-btn-ghost" href={`/${locale}/products`}>{getLabel("exploreDevices")}</a>
          </div>
        </div>

        <div class="solutions-hero-panel reveal delay-1">
          <span class="panel-kicker">{getLabel("solutionStack")}</span>

          <div class="solution-stack-list">
            <div>
              <strong>01</strong>
              <span>{getLabel("stackFieldSensing")}</span>
            </div>
            <div>
              <strong>02</strong>
              <span>{getLabel("stackTransmission")}</span>
            </div>
            <div>
              <strong>03</strong>
              <span>{getLabel("stackBackend")}</span>
            </div>
            <div>
              <strong>04</strong>
              <span>{getLabel("stackDashboards")}</span>
            </div>
          </div>
        </div>

        <div class="solutions-hero-metrics reveal delay-2">
          <article>
            <strong>{pageContent.metric1Value || "15+"}</strong>
            <span>{localizedValue(pageContent.metric1Label, locale) || getLabel("metric1")}</span>
          </article>
          <article>
            <strong>{pageContent.metric2Value || "2020"}</strong>
            <span>{localizedValue(pageContent.metric2Label, locale) || getLabel("metric2")}</span>
          </article>
          <article>
            <strong>{pageContent.metric3Value || "24/7"}</strong>
            <span>{localizedValue(pageContent.metric3Label, locale) || getLabel("metric3")}</span>
          </article>
        </div>
      </div>
    </div>

    <!-- Selector Grid (path finder — before use-case catalog) -->
    <section class="section soft solution-selector-section">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
        <div class="section-head center reveal">
          <p class="eyebrow">{getVal("selectorEyebrow")}</p>
          <h2>{getVal("selectorTitle")}</h2>
          <p class="section-lead">{getVal("selectorLead")}</p>
        </div>

        <div class="solution-decision-grid">
          {selectorCards.length > 0 ? (
            selectorCards.map((card: any, idx: number) => {
              const c = localizeItem(card, locale);
              return (
                <article class={`solution-decision-card reveal ${idx > 0 ? `delay-${idx}` : ''}`}>
                  <div class="decision-icon">{String(idx + 1).padStart(2, '0')}</div>
                  <span>{c.eyebrow}</span>
                  <h3>{c.title}</h3>
                  <p>{c.body}</p>
                  {c.bullets && c.bullets.length > 0 && (
                    <ul>
                      {c.bullets.map((b: string) => <li>{b}</li>)}
                    </ul>
                  )}
                </article>
              );
            })
          ) : (
            <>
              <article class="solution-decision-card reveal">
                <div class="decision-icon">01</div>
                <span>{locale === 'tr' ? 'Görünürlük mü lazım?' : 'Need visibility?'}</span>
                <h3>{locale === 'tr' ? 'Uzaktan İzleme' : 'Remote Monitoring'}</h3>
                <p>
                  {locale === 'tr' ? 'Erişilmesi zor, sahalara dağıtılmış veya saha ekipleri tarafından manuel kontrol edilen varlıklar için.' : 'For assets that are hard to reach, distributed across sites or still checked manually by field teams.'}
                </p>
                <ul>
                  <li>{locale === 'tr' ? 'Canlı telemetri' : 'Live telemetry'}</li>
                  <li>{locale === 'tr' ? 'Varlık durumu' : 'Asset status'}</li>
                  <li>{locale === 'tr' ? 'Geçmiş trendler' : 'Historical trends'}</li>
                </ul>
              </article>
              <article class="solution-decision-card reveal delay-1">
                <div class="decision-icon">02</div>
                <span>{locale === 'tr' ? 'Müdahale mi gerekiyor?' : 'Need response?'}</span>
                <h3>{locale === 'tr' ? 'Uyarılar ve İş Akışları' : 'Alerts & Workflows'}</h3>
                <p>
                  {locale === 'tr' ? 'Seviye, basınç, hareket, panik, kapı, GPS veya hava kalitesi olaylarının anında müdahale gerektirdiği operasyonlar için.' : 'For operations where level, pressure, motion, panic, door, GPS or air-quality events require immediate action.'}
                </p>
                <ul>
                  <li>{locale === 'tr' ? 'Eşik uyarıları' : 'Threshold alerts'}</li>
                  <li>{locale === 'tr' ? 'Mobil bildirimler' : 'Mobile notifications'}</li>
                  <li>{locale === 'tr' ? 'Eskalasyon akışları' : 'Escalation flows'}</li>
                </ul>
              </article>
              <article class="solution-decision-card reveal delay-2">
                <div class="decision-icon">03</div>
                <span>{locale === 'tr' ? 'Entegrasyon mu lazım?' : 'Need integration?'}</span>
                <h3>{locale === 'tr' ? 'Endüstriyel Veri Platformu' : 'Industrial Data Platform'}</h3>
                <p>
                  {locale === 'tr' ? 'Raporlama araçlarını, ERP sistemlerini, müşteri portallarını, PostgreSQL veritabanını veya dahili API\'leri beslemesi gereken telemetri için.' : 'For telemetry that must feed reporting tools, ERP systems, customer portals, PostgreSQL or internal APIs.'}
                </p>
                <ul>
                  <li>{locale === 'tr' ? 'Arka uç API\'leri' : 'Backend APIs'}</li>
                  <li>{locale === 'tr' ? 'Yönetici panelleri' : 'Admin panels'}</li>
                  <li>{locale === 'tr' ? 'Veri hatları' : 'Data pipelines'}</li>
                </ul>
              </article>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- Use Cases Section -->
    <section class="section solution-market-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getVal("useCasesEyebrow") || getLabel("useCases")}</p>
            <h2>{getVal("useCasesTitle") || "Designed for distributed, harsh and operationally critical environments."}</h2>
            <p class="section-lead">
              {getVal("useCasesLead") || "From infrastructure and factories to buildings, logistics and utilities, every solution is shaped around field conditions, data needs and response workflows."}
            </p>
          </div>

          <a class="btn btn-secondary btn-small" href={`/${locale}/start-project`}>{getLabel("startWithSite")}</a>
        </div>

        {solutionCategories.length > 2 && (
          <div class="solution-filter-bar reveal" data-solution-filter data-cms-solution-filter>
            {solutionCategories.map((cat: string, i: number) => (
              <button class={`sol-filter-btn${i === 0 ? " active" : ""}`} data-cat={cat}>
                {categoryName(cat)}
              </button>
            ))}
          </div>
        )}

        <div class="solutions-showcase-frame reveal delay-2">
          <div class="solutions-showcase-side">
            <span>{getVal("showcaseEyebrow") || getLabel("operationalCoverage")}</span>
            <h3>{getVal("showcaseTitle")}</h3>
            <p>
              {getVal("showcaseLead")}
            </p>
          </div>

          <div class="solution-case-grid" data-cms-solutions>
            {solutions.map((s: any, idx: number) => (
              <SolutionCard solution={s} locale={locale} index={idx} allProducts={allProducts} />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Data Flow Architecture -->
    <section class="section dark solutions-architecture-section">
      <canvas class="signal-canvas" data-density="36" data-color="35, 168, 216"></canvas>

      <div class="section-inner">
        <div class="section-head center reveal" style={{ marginBottom: "32px" }}>
          <p class="eyebrow">{getVal("howEyebrow")}</p>
          <h2 class="page-title">{getVal("howTitle")}</h2>
          <p class="section-lead">
            {getVal("howLead")}
          </p>
        </div>

        <div class="tech-flow reveal delay-1" data-cms-architecture-flow>
          <div class="flow-row">
            {howItWorksSteps.length > 0 ? (
              howItWorksSteps.map((step: any, idx: number) => {
                const s = localizeItem(step, locale);
                return (
                  <div class="flow-node">
                    <small>{String(idx + 1).padStart(2, '0')}</small>
                    <strong>{s.title}</strong>
                    <span>{s.body}</span>
                  </div>
                );
              })
            ) : (
              // Fallback
              <>
                <div class="flow-node">
                  <small>01</small>
                  <strong>{locale === 'tr' ? 'Ölçüm' : 'Measure'}</strong>
                  <span>{locale === 'tr' ? 'Seviye, basınç, hava kalitesi, hareket, GPS, sıcaklık, nem ve daha fazlası.' : 'Level, pressure, air quality, motion, GPS, temperature, humidity and more.'}</span>
                </div>
                <div class="flow-node">
                  <small>02</small>
                  <strong>{locale === 'tr' ? 'İletim' : 'Transmit'}</strong>
                  <span>{locale === 'tr' ? 'Saha gerçekliğine göre tasarlanmış LoRaWAN ve düşük güçlü iletişim yolları.' : 'LoRaWAN and low-power communication paths designed for site reality.'}</span>
                </div>
                <div class="flow-node">
                  <small>03</small>
                  <strong>{locale === 'tr' ? 'İşleme' : 'Process'}</strong>
                  <span>{locale === 'tr' ? 'Backend API\'leri, PostgreSQL depolaması, kurallar, eşikler ve raporlama mantığı.' : 'Backend APIs, PostgreSQL storage, rules, thresholds and reporting logic.'}</span>
                </div>
                <div class="flow-node">
                  <small>04</small>
                  <strong>{locale === 'tr' ? 'Görselleştirme' : 'Visualize'}</strong>
                  <span>{locale === 'tr' ? 'Paneller, haritalar, yönetici panelleri, mobil uygulamalar ve müşteri portalları.' : 'Dashboards, maps, admin panels, mobile apps and customer portals.'}</span>
                </div>
                <div class="flow-node">
                  <small>05</small>
                  <strong>{locale === 'tr' ? 'Eylem' : 'Act'}</strong>
                  <span>{locale === 'tr' ? 'Uyarılar, iş akışları, saha yanıtları, bakım planlaması ve karar desteği.' : 'Alerts, workflows, field response, maintenance planning and decision support.'}</span>
                </div>
              </>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Why WillowSoft -->
    <section class="section soft solutions-why-section">
      <div class="section-inner">
        <div class="section-head reveal">
          <div>
            <p class="eyebrow">{getVal("whyEyebrow") || getLabel("whyWillowSoft")}</p>
            <h2>{getVal("whyTitle") || "Solutions are engineered around the site, not forced onto it."}</h2>
          </div>
        </div>

        <div class="solutions-principle-grid" data-cms-why-principles>
          {whyCards.length > 0 ? (
            whyCards.map((card: any, idx: number) => {
              const c = localizeItem(card, locale);
              return (
                <article class={`solutions-principle-card reveal ${idx > 0 ? `delay-${idx}` : ''}`}>
                  <span>{String(idx + 1).padStart(2, '0')}</span>
                  <h3>{c.title}</h3>
                  <p>{c.body}</p>
                </article>
              );
            })
          ) : (
            // Fallback
            <>
              <article class="solutions-principle-card reveal">
                <span>01</span>
                <h3>{locale === 'tr' ? 'Düşük Güç Uzmanlığı' : 'Low-Power Expertise'}</h3>
                <p>
                  {locale === 'tr' ? 'Pil ömrü, veri paketi boyutu ve raporlama aralıkları gerçek kurulum gereksinimlerine göre tasarlanır.' : 'Battery life, payload size and reporting intervals are designed around real deployment requirements.'}
                </p>
              </article>
              <article class="solutions-principle-card reveal delay-1">
                <span>02</span>
                <h3>{locale === 'tr' ? 'RF Uyumlu Kurulum' : 'RF-Aware Deployment'}</h3>
                <p>
                  {locale === 'tr' ? 'Bağlantı planlaması; metal yoğunluklu fabrikaları, mesafeyi, hava koşullarını, muhafazaları ve geçit yerleşimini hesaba katar.' : 'Connectivity planning considers metal-heavy factories, distance, weather, enclosures and gateway placement.'}
                </p>
              </article>
              <article class="solutions-principle-card reveal delay-2">
                <span>03</span>
                <h3>{locale === 'tr' ? 'Uçtan Uca Sahiplik' : 'Full Stack Ownership'}</h3>
                <p>
                  {locale === 'tr' ? 'Donanım, gömülü yazılım (firmware), backend, veritabanı, pano, admin paneli ve mobil iş akışları birlikte tasarlanır.' : 'Hardware, firmware, backend, database, dashboard, admin panel and mobile workflows are designed together.'}
                </p>
              </article>
              <article class="solutions-principle-card reveal delay-3">
                <span>04</span>
                <h3>{locale === 'tr' ? 'Önce Üretim Yaklaşımı' : 'Production-First Thinking'}</h3>
                <p>
                  {locale === 'tr' ? 'Her çözüm sadece prototip varsayımlarına göre değil, saha gerçekliğine göre değerlendirilir.' : 'Every solution is evaluated against field reality, not only against prototype assumptions.'}
                </p>
              </article>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section solutions-final-cta-section">
      <div class="section-inner">
        <div class="solutions-final-cta reveal">
          <div>
            <p class="eyebrow">{getVal("finalCtaEyebrow")}</p>
            <h2>{getVal("finalCtaTitle")}</h2>
            <p>
              {getVal("finalCtaLead")}
            </p>
          </div>

          <a class="btn btn-primary" href={`/${locale}/start-project`}>{getVal("finalCtaButton") || getLabel("startProject")}</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "24px" }}>
          <p class="eyebrow">{getLabel("faqEyebrow")}</p>
          <h2 class="page-title">{getLabel("faqTitle")}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {getLabel("faqLead")}
          </p>
        </div>
        <FaqAccordion pageKey="solutions" faqs={content.faqs || []} locale={locale} />
      </div>
    </section>
  </main>

  <script is:inline>
    (function() {
      const filterBar = document.querySelector("[data-solution-filter]");
      const grid = document.querySelector("[data-cms-solutions]");
      if (filterBar && grid) {
        filterBar.addEventListener("click", (e) => {
          const btn = e.target.closest(".sol-filter-btn");
          if (!btn) return;
          filterBar.querySelectorAll(".sol-filter-btn").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          const cat = btn.dataset.cat;
          grid.querySelectorAll(".solution-case-card").forEach((card) => {
            const match = cat === "All" || card.dataset.category === cat;
            card.style.display = match ? "" : "none";
          });
        });
      }
    })();
  </script>
</PageLayout>

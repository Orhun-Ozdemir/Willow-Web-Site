    it: "I prodotti WillowSoft offrono il massimo valore quando presentati como parte di un sistema operativo completo: sensore, connettività, backend, database, dashboard, app mobile e avvisi.",
    ar: "تكون منتجات WillowSoft في أقوى حالاتها عندما تُقدم كجزء من نظام تشغيلي متكامل: المستشعر، والاتصال، والخلفية، وقاعدة البيانات، ولوحة التحكم، والجوال، والتنبيهات.",
    ja: "WillowSoftのデバイスは、センサー、ネットワーク、サーバー、データベース、ダッシュボード、モバイル通知までを網羅した統合システムの一部として導入することで、最大の効果を発揮します。"
  },
  needInProject: { en: "Need this in a project?", tr: "Projelerinizde buna mı ihtiyacınız var?", de: "Benötigen Sie dies in einem Projekt?", fr: "Besoin de cela dans un projet ?", es: "¿Necesita esto en un proyecto?", it: "Ti serve in un progetto?", ar: "هل تحتاج هذا في مشروعك؟", ja: "プロジェクトへの導入をご検討中ですか؟" },
  askProductFit: { en: "Ask for product fit, integration path and deployment scope.", tr: "Ürün uyumu, entegrasyon yolu ve kurulum kapsamı hakkında bilgi isteyin.", de: "Fragen Sie nach Produktpassung, Integrationspfad und Bereitstellungsumfang.", fr: "Demandez l'adéquation du produit, le parcours d'intégration et la portée du déploiement.", es: "Pregunte por la idoneidad del producto, la ruta de integración y el alcance de la implementación.", it: "Chiedi informazioni sulla compatibilità del prodotto, il percorso di integrazione e l'ambito dell'installazione.", ar: "اسأل عن مدى ملاءمة المنتج ومسار الربط ونطاق النشر.", ja: "製品の適合性、既存システムとの連携方法、および導入規模についてお問い合わせください。"
  },
  startProject: { en: "Start Project", tr: "Projeyi Başlat", de: "Projekt starten", fr: "Démarrer le projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "بدء المشروع", ja: "プロジェクト相談" },
  contactSales: { en: "Contact Sales", tr: "Satışla İletişime Geçin", de: "Vertrieb kontaktieren", fr: "Contacter le service commercial", es: "Contactar a ventas", it: "Contatta le vendite", ar: "الاتصال بالمبيعات", ja: "営業チームに相談" },
  backToProducts: { en: "Back to Products", tr: "Ürünlere Dön", de: "Zurück zu Produkten", fr: "Retour aux Produkten", es: "Volver a productos", it: "Torna ai prodotti", ar: "العودة إلى المنتجات", ja: "製品一覧へ戻る" },
  reqInfo: { en: "Request Information", tr: "Bilgi Talep Et", de: "Informationen anfordern", fr: "Demander des informations", es: "Solicitar información", it: "Richiedi informazioni", ar: "طلب معلومات", ja: "資料請求・お問い合わせ" },
  flowDevice: { en: "Device", tr: "Cihaz", de: "Gerät", fr: "Dispositif", es: "Dispositivo", it: "Dispositivo", ar: "الجهاز", ja: "デバイス" },
  flowNetworkDesc: { en: "LoRaWAN payloads and gateway planning.", tr: "LoRaWAN payload'ları ve gateway planlaması.", de: "LoRaWAN-Payloads und Gateway-Planung.", fr: "Payloads LoRaWAN et planification des passerelles.", es: "Payloads LoRaWAN y planificación de gateways.", it: "Payload LoRaWAN e pianificazione dei gateway.", ar: "حمولات LoRaWAN وتخطيط البوابات.", ja: "LoRaWAN payloadとgateway計画。" },
  flowData: { en: "Data", tr: "Veri", de: "Daten", fr: "Données", es: "Datos", it: "Dati", ar: "البيانات", ja: "データ" },
  flowDataDesc: { en: "API ingestion and PostgreSQL schema.", tr: "API veri alımı ve PostgreSQL şeması.", de: "API-Ingestion und PostgreSQL-Schema.", fr: "Ingestion API et schéma PostgreSQL.", es: "Ingesta API y esquema PostgreSQL.", it: "Ingestion API e schema PostgreSQL.", ar: "استقبال API ومخطط PostgreSQL.", ja: "API取り込みとPostgreSQLスキーマ。" },
  flowInterface: { en: "Interface", tr: "Arayüz", de: "Schnittstelle", fr: "Interface", es: "Interfaz", it: "Interfaccia", ar: "الواجهة", ja: "インターフェース" },
  flowInterfaceDesc: { en: "Dashboard, mobile app and admin panel.", tr: "Dashboard, mobil uygulama ve yönetim paneli.", de: "Dashboard, mobile App und Admin-Panel.", fr: "Dashboard, application mobile et panneau admin.", es: "Dashboard, app móvil y panel admin.", it: "Dashboard, app mobile e pannello admin.", ar: "لوحة تحكم وتطبيق جوال ولوحة إدارة.", ja: "ダッシュボード、モバイルアプリ、管理画面。" },
  flowAction: { en: "Action", tr: "Aksiyon", de: "Aktion", fr: "Action", es: "Acción", it: "Azione", ar: "الإجراء", ja: "アクション" },
  flowActionDesc: { en: "Alerts, reports, integrations and service workflows.", tr: "Uyarılar, raporlar, entegrasyonlar ve servis iş akışları.", de: "Alarme, Berichte, Integrationen und Service-Workflows.", fr: "Alertes, rapports, intégrations et workflows de service.", es: "Alertas, informes, integraciones y flujos de servicio.", it: "Avvisi, report, integrazioni e workflow di servizio.", ar: "تنبيهات وتقارير وتكاملات وسير عمل للخدمة.", ja: "アラート、レポート、連携、運用ワークフロー。" },
  productsBreadcrumb: { en: "Products", tr: "Ürünler", de: "Produkte", fr: "Produits", es: "Productos", it: "Prodotti", ar: "المنتجات", ja: "製品一覧" },
  requestQuote: { en: "Request a quote", tr: "Teklif isteyin", de: "Angebot anfordern", fr: "Demander un devis", es: "Solicitar cotización", it: "Richiedi un preventivo", ar: "طلب عرض سعر", ja: "見積もりを依頼" },
  downloadDatasheet: { en: "Download datasheet", tr: "Veri sayfasını indir", de: "Datenblatt herunterladen", fr: "Télécharger la fiche technique", es: "Descargar ficha técnica", it: "Scarica la scheda tecnica", ar: "تنزيل ورقة البيانات", ja: "データシートをダウンロード" },
  specifications: { en: "Specifications", tr: "Teknik Özellikler", de: "Spezifikationen", fr: "Spécifications", es: "Especificaciones", it: "Specifiche", ar: "المواصفات", ja: "仕様" },
  keyFeatures: { en: "Key features", tr: "Öne çıkan özellikler", de: "Wichtige Eigenschaften", fr: "Caractéristiques principales", es: "Características clave", it: "Caratteristiche chiave", ar: "الميزات الرئيسية", ja: "主な特長" },
  capabilities: { en: "Capabilities", tr: "Yetenekler", de: "Fähigkeiten", fr: "Capacités", es: "Capacidades", it: "Funzionalità", ar: "القدرات", ja: "機能" },
  applications: { en: "Applications", tr: "Uygulama Alanları", de: "Anwendungen", fr: "Applications", es: "Aplicaciones", it: "Applicazioni", ar: "التطبيقات", ja: "用途" },
  faqSubtitle: { en: "Can't find your answer? Our engineers reply within one business day.", tr: "Aradığınız cevabı bulamadınız mı? Mühendislerimiz bir iş günü içinde yanıt verir.", de: "Keine Antwort gefunden? Unsere Ingenieure antworten innerhalb eines Werktages.", fr: "Vous ne trouvez pas votre réponse ? Nos ingénieurs répondent sous un jour ouvrable.", es: "¿No encuentra la respuesta? Nuestros ingenieros responden en un día hábil.", it: "Non trovi la risposta? I nostri ingegneri rispondono entro un giorno lavorativo.", ar: "لم تجد إجابتك؟ يجيب مهندسونا خلال يوم عمل واحد.", ja: "ご不明な点はございますか？ 技術スタッフ bir iş günü içinde yanıt verir." },
  askQuestion: { en: "Ask a question", tr: "Soru sorun", de: "Frage stellen", fr: "Poser une question", es: "Hacer una pregunta", it: "Fai una domanda", ar: "طرح سؤال", ja: "質問する" },
  inTheField: { en: "In the field", tr: "Sahada", de: "Im Feldeinsatz", fr: "Sur le terrain", es: "En el campo", it: "Sul campo", ar: "في الميدان", ja: "現場導入実績" },
  inTheFieldDesc: { en: "Deployed where decisions are made.", tr: "Kararların alındığı yerlerde kuruldu.", de: "Dort im Einsatz, wo Entscheidungen getroffen werden.", fr: "Déployé là où les décisions sont prises.", es: "Implementado donde se toman las decisiones.", it: "Installato dove si prendono le decisioni.", ar: "نُشرت حيث تُتخذ القرارات.", ja: "意思決定が行われる現場での運用実績。" }
};

const getT = (key: keyof typeof t) => {
  return t[key][locale] || t[key]["en"];
};
---

<PageLayout
  title={seo.seoTitle || `${product.title} | WillowSoft`}
  description={seo.metaDescription || product.shortDescription || ""}
  canonical={seo.canonical || `${SITE_ORIGIN}/${locale}/products/${slug}`}
  ogTitle={seo.ogTitle || product.title}
  ogDescription={seo.ogDescription || seo.metaDescription || product.shortDescription || ""}
  ogImage={product.image ? `${SITE_ORIGIN}/${product.image}`.replace(/([^:])\/\//g, "$1/") : DEFAULT_OG_IMAGE}
  alternates={buildAlternates(`/products/${slug}`)}
  schema={graphSchema}
  locale={locale}
  dataPage="product-detail"
>
  <main>
    <div class="section-inner">
      <div class="ws-breadcrumbs">
        <a href={`/${locale}/products`}>{getT("productsBreadcrumb")}</a>
        <span class="separator">/</span>
        <a href={`/${locale}/products?category=${product.category}`}>{categoryLabels[product.category]?.[locale] || product.category}</a>
        <span class="separator">/</span>
        <span class="current">{product.title}</span>
      </div>
    </div>

    <!-- Hero Section -->
    <section class="ws-hero-section">
      <canvas class="signal-canvas" data-density="36"></canvas>
      <div class="ws-hero-inner section-inner">
        <div class="ws-hero-left">
          <div class="ws-hero-image-card">
            <img src={product.image ? `/${product.image}`.replace("//", "/") : "/assets/hero-industrial-iot.png"} alt={product.title} class="ws-hero-img" />
          </div>
        </div>
        <div class="ws-hero-right">
          <div class="ws-hero-meta">
            <span class="ws-kicker">{categoryLabels[product.category]?.[locale] || product.category}</span>
            {product.featured && (
              <span class="ws-featured-badge">
                ★ {locale === 'tr' ? 'ÖNE ÇIKAN' : locale === 'de' ? 'HIGHLIGHT' : 'FEATURED'}
              </span>
            )}
          </div>
          <h1 class="ws-h1">{product.title}</h1>
          <p class="ws-lead">{product.aiShortAnswer || product.shortDescription}</p>
          {product.chips && product.chips.length > 0 && (
            <div class="ws-chip-row">
              {product.chips.map((chip: string) => (
                <span class="ws-chip">
                  <Fragment set:html={ICONS.check} />
                  {chip}
                </span>
              ))}
            </div>
          )}
          <div class="ws-hero-ctas">
            <a class="ws-btn ws-btn-primary" href={`/${locale}/contact?product=${encodeURIComponent(slug)}`}>{getT("requestQuote")}</a>
            {product.datasheet_url || product.datasheet ? (
              <a class="ws-btn ws-btn-secondary" href={product.datasheet_url || product.datasheet} target="_blank" rel="noopener noreferrer">
                <Fragment set:html={ICONS.download} />
                <span>{getT("downloadDatasheet")}</span>
              </a>
            ) : (
              <a class="ws-btn ws-btn-secondary" href={`/${locale}/contact?product=${encodeURIComponent(slug)}&type=datasheet`}>
                <Fragment set:html={ICONS.download} />
                <span>{getT("downloadDatasheet")}</span>
              </a>
            )}
          </div>
          {product.specifications?.warranty && (
            <p class="ws-warranty-text">
              {locale === 'tr' ? `${product.specifications.warranty} garantili.` :
               locale === 'de' ? `Unterstützt durch ${product.specifications.warranty} Garantie.` :
               `Backed by a ${product.specifications.warranty} warranty.`}
            </p>
          )}
        </div>
      </div>
    </section>

    <!-- Stats Band Section -->
    {highlights.length > 0 && (
      <section class="ws-stats-section">
        <div class="section-inner">
          <div class="ws-stats-band">
            {highlights.map((hl, i) => (
              <div class="ws-stat-col" style={i > 0 ? `border-left: 1px solid rgba(255,255,255,0.14)` : ""}>
                <b class="ws-stat-val">{hl.value}</b>
                <span class="ws-stat-lbl">{hl.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Specifications & Key Features Section -->
    <section class="ws-specs-section">
      <div class="ws-specs-grid section-inner">
        <div class="ws-specs-left">
          <div class="ws-specs-card">
            <div class="ws-specs-header">
              <h3 class="ws-specs-h3">{getT("specifications")}</h3>
              <div class="ws-specs-iconbox">
                <Fragment set:html={ICONS.mount} />
              </div>
            </div>
            <dl class="ws-specs-list">
              {specEntries.map(([k, v]) => (
                <div class="ws-spec-row">
                  <dt class="ws-spec-dt">{wsSpecLabel(k, locale)}</dt>
                  <dd class="ws-spec-dd">{v}</dd>
                </div>
              ))}
            </dl>
            <div class="ws-specs-download-link">
              <Fragment set:html={ICONS.download} />
              {product.datasheet_url || product.datasheet ? (
                <a href={product.datasheet_url || product.datasheet} target="_blank" rel="noopener noreferrer">
                  {getT("downloadDatasheet")} (PDF)
                </a>
              ) : (
                <a href={`/${locale}/contact?product=${encodeURIComponent(slug)}&type=datasheet`}>
                  {getT("downloadDatasheet")} (PDF)
                </a>
              )}
            </div>
          </div>
        </div>

        <div class="ws-specs-right-sticky">
          <span class="ws-kicker">{getT("keyFeatures")}</span>
          <h2 class="ws-h2-small">
            {locale === 'tr' ? "Saha için tasarlandı, üretime hazır." :
             locale === 'de' ? "Für den Feldeinsatz konzipiert, bereit für die Produktion." :
             "Designed for the field, ready for production."}
          </h2>
          {keyFeatures.length > 0 && (
            <ul class="ws-features-bullets">
              {keyFeatures.map((f: string) => (
                <li>{f}</li>
              ))}
            </ul>
          )}
          <div class="ws-stack-infobox">
            <span class="ws-stack-infobox-icon">
              <Fragment set:html={ICONS.radio} />
            </span>
            <p class="ws-stack-infobox-text">
              {locale === 'tr' ? "Eksiksiz WillowSoft altyapısının bir parçası — donanım, gömülü yazılım, backend ve kontrol panelleri tek bir ekipten." :
               locale === 'de' ? "Teil des kompletten WillowSoft-Stacks — Hardware, Firmware, Backend und Dashboards aus einer Hand." :
               "Part of the complete WillowSoft stack — hardware, firmware, backend and dashboards from one team."}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Capabilities Section -->
    {params.length > 0 && (
      <section class="ws-capabilities-section">
        <div class="section-inner">
          <div class="ws-section-header">
            <span class="ws-kicker">{paramsKicker || getT("capabilities")}</span>
            <h2 class="ws-h2">{paramsTitle || (locale === 'tr' ? "Neler Yapar" : "What it does.")}</h2>
          </div>
          <div class="ws-capabilities-grid">
            {params.map(x => (
              <div class="ws-capability-card">
                <div class="ws-capability-iconbox">
                  <Fragment set:html={ICONS[x.icon] || ICONS.check} />
                </div>
                <b class="ws-capability-name">{x.name}</b>
                <p class="ws-capability-desc">{x.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Applications Section -->
    {apps.length > 0 && (
      <section class="ws-applications-section">
        <div class="section-inner" style="display: contents;">
          <div class="ws-apps-left">
            <span class="ws-kicker">{getT("applications")}</span>
            <h2 class="ws-h2">{locale === 'tr' ? "Nerede Çalışır" : "Where it works"}</h2>
            {appsNote && (
              <p class="ws-apps-note">{appsNote}</p>
            )}
          </div>
          <div class="ws-apps-right-grid">
            {apps.map(a => (
              <div class="ws-app-card">
                <div class="ws-app-iconbox">
                  <Fragment set:html={ICONS[a.icon] || ICONS.check} />
                </div>
                <div class="ws-app-content">
                  <b class="ws-app-name">{a.name}</b>
                  <p class="ws-app-desc">{a.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ Accordion Section -->
    {product.aiFAQ && product.aiFAQ.length > 0 && (
      <section class="ws-faq-section" id="faq">
        <div class="section-inner" style="display: contents;">
          <div class="ws-faq-left">
            <span class="ws-kicker">FAQ</span>
            <h2 class="ws-h2">{locale === 'tr' ? "Sıkça sorulan sorular" : "Frequently asked questions"}</h2>
            <p class="ws-faq-subtitle">{getT("faqSubtitle")}</p>
            <a class="ws-btn ws-btn-secondary" href={`/${locale}/contact?product=${encodeURIComponent(slug)}&type=question`}>
              {getT("askQuestion")}
            </a>
          </div>
          <div class="ws-faq-right-list">
            {product.aiFAQ.map((f: any) => (
              <details class="ws-faq-details">
                <summary class="ws-faq-summary">
                  <span class="ws-faq-question">{f.question}</span>
                  <span class="ws-faq-arrow">
                    <svg viewBox="0 0 16 10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M2 2l6 6 6-6" /></svg>
                  </span>
                </summary>
                <div class="ws-faq-answer-wrapper">
                  <p class="ws-faq-answer">{f.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Gallery Section -->
    {galleryImages.length > 0 && (
      <section class="ws-gallery-section">
        <div class="ws-section-header section-inner">
          <span class="ws-kicker">{getT("inTheField")}</span>
          <h2 class="ws-h2">{getT("inTheFieldDesc")}</h2>
        </div>
        <div class="ws-gallery-grid section-inner">
          {galleryImages.slice(0, 3).map((imgUrl: string, i: number) => (
            <div class="ws-gallery-card">
              <img src={`/${imgUrl}`.replace("//", "/")} alt={`${product.title} gallery ${i + 1}`} class="ws-gallery-img" />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Quote Band Section -->
    <section class="ws-quote-band-section">
      <div class="ws-quote-band-inner section-inner">
        <div class="ws-quote-band-left">
          <span class="ws-kicker">{getT("needInProject")}</span>
          <h2 class="ws-h2-quote">{getT("askProductFit")}</h2>
        </div>
        <div class="ws-quote-band-right-actions">
          <a class="ws-btn ws-btn-primary" href={`/${locale}/start-project?product=${encodeURIComponent(slug)}`}>{getT("startProject")}</a>
          <a class="ws-btn ws-btn-secondary" href={`/${locale}/contact?product=${encodeURIComponent(slug)}`}>{getT("contactSales")}</a>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

<style>
  /* Base reset & typography within page scope */
  .ws-breadcrumbs {
    padding: 32px 0 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--muted);
  }
  .ws-breadcrumbs a {
    color: var(--muted);
    transition: color 0.2s ease;
  }
  .ws-breadcrumbs a:hover {
    color: var(--accent-text);
  }
  .ws-breadcrumbs .separator {
    opacity: 0.45;
  }
  .ws-breadcrumbs .current {
    color: var(--ink);
    font-weight: 800;
  }

  /* Hero Section */
  .ws-hero-section {
    position: relative;
    padding: 32px 0 64px;
    overflow: hidden;
  }
  .ws-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.3fr);
    gap: 64px;
    align-items: center;
  }
  @media (max-width: 1024px) {
    .ws-hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  .ws-hero-image-card {
    padding: 16px;
    border-radius: 20px;
    background: var(--panel);
    border: 1px solid rgba(var(--accent-rgb), 0.12);
    box-shadow: var(--shadow);

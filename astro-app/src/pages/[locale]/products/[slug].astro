  industrial: "Industrial bridge for machine-side data."
};
const localizedSnapshotText = {
  en: snapshotMap[product.category] || "Built for field telemetry.",
  tr: "Saha telemetrisi için tasarlanmış teknik yapı.",
  de: "Technische Basis für Feldtelemetrie.",
  fr: "Base technique pour la télémétrie terrain.",

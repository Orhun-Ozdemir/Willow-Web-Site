  askProductFit: { en: "Ask for product fit, integration path and deployment scope.", tr: "Ürün uyumu, entegrasyon yolu ve kurulum kapsamı hakkında bilgi isteyin.", de: "Fragen Sie nach Produktpassung, Integrationspfad und Bereitstellungsumfang.", fr: "Demandez l'adéquation du produit, le parcours d'intégration et la portée du déploiement.", es: "Pregunte por la idoneidad del producto, la ruta de integración y el alcance de la implementación.", it: "Chiedi informazioni sulla compatibilità del prodotto, il percorso di integrazione e l'ambito dell'installazione.", ar: "اسأل عن مدى ملاءمة المنتج ومسار الربط ونطاق النشر.", ja: "製品の適合性、既存システムとの連携方法、および導入規模についてお問い合わせください。"
  },
  startProject: { en: "Start Project", tr: "Projeyi Başlat", de: "Projekt starten", fr: "Démarrer le projet", es: "Iniciar proyecto", it: "Avvia progetto", ar: "بدء المشروع", ja: "プロジェクト相談" },
  contactSales: { en: "Contact Sales", tr: "Satışla İletişime Geçin", de: "Vertrieb kontaktieren", fr: "Contacter le service commercial", es: "Contactar a ventas", it: "Contatta le vendite", ar: "الاتصال بالمبيعات", ja: "営業チームに相談" },
  backToProducts: { en: "Back to Products", tr: "Ürünlere Dön", de: "Zurück zu Produkten", fr: "Retour aux Produkten", es: "Volver a productos", it: "Torna ai prodotti", ar: "العودة إلى المنتجات", ja: "製品一覧へ戻る" },
  reqInfo: { en: "Request Information", tr: "Bilgi Talep Et", de: "Informationen anfordern", fr: "Demander des informations", es: "Solicitar información", it: "Richiedi informazioni", ar: "طلب معلومات", ja: "資料請求・お問い合わせ" },
  flowDevice: { en: "Device", tr: "Cihaz", de: "Gerät", fr: "Dispositif", es: "Dispositivo", it: "Dispositivo", ar: "الجهاز", ja: "デバイス" },
  flowDeviceDesc: { en: "Sensing, enclosure, battery and RF behavior.", tr: "Ölçüm, muhafaza, pil ve RF davranışı.", de: "Messung, Gehäuse, Batterie und RF-Verhalten.", fr: "Mesure, boîtier, batterie et comportement RF.", es: "Medición, carcasa, batería y comportamiento RF.", it: "Misura, involucro, batteria e comportamento RF.", ar: "الاستشعار والغلاف والبطارية وسلوك RF.", ja: "センシング、筐体、バッテリー、RF特性。" },
  flowNetwork: { en: "Network", tr: "Ağ", de: "Netzwerk", fr: "Réseau", es: "Red", it: "Rete", ar: "الشبكة", ja: "ネットワーク" },
  flowNetworkDesc: { en: "LoRaWAN payloads and gateway planning.", tr: "LoRaWAN payload'ları ve gateway planlaması.", de: "LoRaWAN-Payloads und Gateway-Planung.", fr: "Payloads LoRaWAN et planification des passerelles.", es: "Payloads LoRaWAN y planificación de gateways.", it: "Payload LoRaWAN e pianificazione dei gateway.", ar: "حمولات LoRaWAN وتخطيط البوابات.", ja: "LoRaWAN payloadとgateway計画。" },
  flowData: { en: "Data", tr: "Veri", de: "Daten", fr: "Données", es: "Datos", it: "Dati", ar: "البيانات", ja: "データ" },
  flowDataDesc: { en: "API ingestion and PostgreSQL schema.", tr: "API veri alımı ve PostgreSQL şeması.", de: "API-Ingestion und PostgreSQL-Schema.", fr: "Ingestion API et schéma PostgreSQL.", es: "Ingesta API y esquema PostgreSQL.", it: "Ingestion API e schema PostgreSQL.", ar: "استقبال API ومخطط PostgreSQL.", ja: "API取り込みとPostgreSQLスキーマ。" },
  flowInterface: { en: "Interface", tr: "Arayüz", de: "Schnittstelle", fr: "Interface", es: "Interfaz", it: "Interfaccia", ar: "الواجهة", ja: "インターフェース" },
  flowInterfaceDesc: { en: "Dashboard, mobile app and admin panel.", tr: "Dashboard, mobil uygulama ve yönetim paneli.", de: "Dashboard, mobile App und Admin-Panel.", fr: "Dashboard, application mobile et panneau admin.", es: "Dashboard, app móvil y panel admin.", it: "Dashboard, app mobile e pannello admin.", ar: "لوحة تحكم وتطبيق جوال ولوحة إدارة.", ja: "ダッシュボード、モバイルアプリ、管理画面。" },
  flowAction: { en: "Action", tr: "Aksiyon", de: "Aktion", fr: "Action", es: "Acción", it: "Azione", ar: "الإجراء", ja: "アクション" },
  flowActionDesc: { en: "Alerts, reports, integrations and service workflows.", tr: "Uyarılar, raporlar, entegrasyonlar ve servis iş akışları.", de: "Alarme, Berichte, Integrationen und Service-Workflows.", fr: "Alertes, rapports, intégrations et workflows de service.", es: "Alertas, informes, integraciones y flujos de servicio.", it: "Avvisi, report, integrazioni e workflow di servizio.", ar: "تنبيهات وتقارير وتكاملات وسير عمل للخدمة.", ja: "アラート、レポート、連携、運用ワークフロー。" }
};

const getT = (key: keyof typeof t) => {
  return t[key][locale] || t[key]["en"];
};
---

<PageLayout
  title={seo.seoTitle || `${product.title} | WillowSoft`}
  description={seo.metaDescription || product.shortDescription || ""}
  canonical={seo.canonical || `${SITE_ORIGIN}/${locale}/products/${slug}`}
  ogTitle={seo.ogTitle || product.title}
  ogDescription={seo.ogDescription || seo.metaDescription || product.shortDescription || ""}
  ogImage={product.image ? `${SITE_ORIGIN}/${product.image}`.replace(/([^:])\/\//g, "$1/") : DEFAULT_OG_IMAGE}
  alternates={buildAlternates(`/products/${slug}`)}
  schema={graphSchema}
  locale={locale}
  dataPage="product-detail"
>
  <main>

    <section class="hero compact">
      <div class="hero-media">
        <img src={product.image ? `/${product.image}`.replace("//", "/") : "/assets/hero-industrial-iot.png"} alt={product.title} loading="lazy" decoding="async" />
      </div>
      <canvas class="signal-canvas" data-density="36"></canvas>
      <div class="hero-inner">
        <p class="eyebrow reveal">{product.category || "Product"}</p>
        <h1 class="reveal delay-1">{product.title}</h1>
        <p class="reveal delay-2">{product.shortDescription}</p>
        <div class="hero-ctas reveal delay-3">
          <a class="btn btn-primary" href={`/${locale}/contact?product=${encodeURIComponent(slug)}`}>{getT("reqInfo")}</a>
          <a class="btn btn-secondary" href={`/${locale}/products`}>{getT("backToProducts")}</a>
        </div>
      </div>
    </section>

    <!-- Bento Snapshot -->
    <section class="section">
      <div class="section-inner bento">
        <article class="card accent reveal">
          <p class="eyebrow">{getT("technicalSnapshot")}</p>
          <h2 class="page-title">{snapshotText}</h2>
          <div class="mini-spec-grid">
            {(product.chips || []).slice(0, 3).map((chip: string) => (
              <div class="mini-spec">
                <strong>{chip}</strong>
                <span>{getT("capability")}</span>
              </div>
            ))}
          </div>
        </article>
        <article
          class="card visual-card reveal delay-1"
          style={product.image ? `background-image: url('/${product.image}')` : ""}
        >
          <h3>{getT("readyText")}</h3>
          <p>{getT("readyDesc")}</p>
        </article>
      </div>
    </section>

    <!-- Gallery Section -->
    {galleryImages.length > 1 && (
      <section class="section product-gallery-section">
        <div class="section-inner">
          <div class="section-head">
            <p class="eyebrow">{getT("gallery")}</p>
            <h2 class="page-title">{getT("gallery")}</h2>
          </div>
          <ProductGallery images={galleryImages} title={product.title} />
        </div>
      </section>
    )}

    <!-- Tech sections -->
    {techBlocks.length > 0 && (
      <section class="section soft product-tech-section">
        <div class="section-inner">
          {techBlocks.map((block) => (
            <article class="product-tech-block" style={{ marginBottom: "40px" }}>
              <h2 class="page-title">{block.label}</h2>
              <div class="rich-content" set:html={block.html} />
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Where it fits -->
    <section class="section soft">
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getT("whereFits")}</p>
          <h2 class="page-title">{getT("fitsTitle")}</h2>
        </div>
        <div class="reveal delay-1">
          <p class="section-lead">{fitText}</p>
          <ul class="spec-list">
            <li>{getT("fitsLi1")}</li>
            <li>{getT("fitsLi2")}</li>
            <li>{getT("fitsLi3")}</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Buyer Checklist -->
    <section class="section product-decision-section">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{getT("buyerChecklist")}</p>
            <h2>{getT("buyerTitle")}</h2>
          </div>
          <a class="btn btn-secondary btn-small" href={`/${locale}/start-project`}>{getT("planDeployment")}</a>
        </div>
        <div class="product-decision-grid">
          <article class="product-decision-card reveal">
            <span>{getT("useCase")}</span>
            <h3>{decision.useTitle}</h3>
            <p>{decision.use}</p>
          </article>
          <article class="product-decision-card reveal delay-1">
            <span>{getT("systemRole")}</span>
            <h3>{decision.roleTitle}</h3>
            <p>{decision.role}</p>
          </article>
          <article class="product-decision-card reveal delay-2">
            <span>{getT("deliveredWith")}</span>
            <h3>{getT("hwSwPath")}</h3>
            <ul>
              {decision.delivered.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- System Architecture -->
    <section class="section soft product-system-section">
      <div class="section-inner split">
        <div class="reveal">
          <p class="eyebrow">{getT("sysArch")}</p>
          <h2 class="page-title">{getT("sysTitle")}</h2>
          <p class="section-lead">{getT("sysDesc")}</p>
        </div>
        <div class="tech-flow product-tech-flow reveal delay-1">
          <div class="flow-row">
            <div class="flow-node"><small>01</small><strong>{getT("flowDevice")}</strong><span>{getT("flowDeviceDesc")}</span></div>
            <div class="flow-node"><small>02</small><strong>{getT("flowNetwork")}</strong><span>{getT("flowNetworkDesc")}</span></div>
            <div class="flow-node"><small>03</small><strong>{getT("flowData")}</strong><span>{getT("flowDataDesc")}</span></div>
            <div class="flow-node"><small>04</small><strong>{getT("flowInterface")}</strong><span>{getT("flowInterfaceDesc")}</span></div>
            <div class="flow-node"><small>05</small><strong>{getT("flowAction")}</strong><span>{getT("flowActionDesc")}</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quote band -->
    <section class="section product-quote-band">
      <div class="section-inner product-quote-inner reveal">
        <div>
          <p class="eyebrow">{getT("needInProject")}</p>
          <h2 class="page-title">{getT("askProductFit")}</h2>
        </div>
        <div class="product-quote-actions">
          <a class="btn btn-primary" href={`/${locale}/start-project?product=${encodeURIComponent(slug)}`}>{getT("startProject")}</a>
          <a class="btn btn-secondary" href={`/${locale}/contact?product=${encodeURIComponent(slug)}`}>{getT("contactSales")}</a>
        </div>
      </div>
    </section>
  </main>
</PageLayout>

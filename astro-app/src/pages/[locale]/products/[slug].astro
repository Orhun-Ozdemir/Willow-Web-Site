    roleTitle: { tr: "Telemetri kaynağı", de: "Telemetriequelle", fr: "Source de télémétrie", es: "Fuente de telemetría", it: "Sorgente di telemetria", ar: "مصدر القياس عن بعد", ja: "テレメトリソース" },
    role: { tr: "Cihaz katmanından gelen ölçüm ve olay verilerini dijital sisteme taşıyan saha sinyalidir.", de: "Es liefert Mess- und Ereignisdaten aus der Geräteebene in das digitale System.", fr: "Il transmet les mesures et événements du terrain vers le système numérique.", es: "Lleva mediciones y eventos desde la capa de dispositivo hacia el sistema digital.", it: "Porta misure ed eventi dal livello dispositivo al sistema digitale.", ar: "ينقل القياسات والأحداث من طبقة الجهاز إلى النظام الرقمي.", ja: "デバイス層の計測値やイベントをデジタルシステムへ送る現場信号です。" },
    delivered: {
      tr: ["Cihaz ve bağlantı yapılandırması", "Backend veri alımı ve PostgreSQL modeli", "Dashboard, mobil ve alarm iş akışı"],
      de: ["Geräte- und Konnektivitätskonfiguration", "Backend-Ingestion und PostgreSQL-Modell", "Dashboard-, Mobile- und Alarm-Workflow"],
      fr: ["Configuration dispositif et connectivité", "Ingestion backend et modèle PostgreSQL", "Dashboard, mobile et workflow d'alertes"],
      es: ["Configuración de dispositivo y conectividad", "Ingesta backend y modelo PostgreSQL", "Dashboard, móvil y flujo de alertas"],
      it: ["Configurazione dispositivo e connettività", "Ingestion backend e modello PostgreSQL", "Dashboard, mobile e flusso di avvisi"],
      ar: ["إعداد الجهاز والاتصال", "استقبال البيانات في الخلفية ونموذج PostgreSQL", "لوحة تحكم وتطبيق جوال وسير عمل للتنبيهات"],
      ja: ["デバイスと通信設定", "バックエンド取り込みとPostgreSQLモデル", "ダッシュボード、モバイル、アラート運用"],
    },
  };
  decision.useTitle = pickText(localizedDecision.useTitle);
  decision.use = pickText(localizedDecision.use);
  decision.roleTitle = pickText(localizedDecision.roleTitle);
  decision.role = pickText(localizedDecision.role);
  decision.delivered = localizedDecision.delivered[locale] || localizedDecision.delivered.tr;
}

const galleryImages = Array.isArray(product.images) ? product.images.filter(Boolean) : (product.image ? [product.image] : []);

// Technical sections
const techBlockLabels = {
  technicalSummary: { en: "Technical Summary", tr: "Teknik Özet", de: "Technische Zusammenfassung", fr: "Résumé technique", es: "Resumen técnico", it: "Sintesi tecnica", ar: "ملخص تقني", ja: "技術概要" },
  useCases: { en: "Use Cases", tr: "Kullanım Senaryoları", de: "Anwendungsfälle", fr: "Cas d'usage", es: "Casos de uso", it: "Casi d'uso", ar: "حالات الاستخدام", ja: "ユースケース" },
  specifications: { en: "Specifications", tr: "Teknik Özellikler", de: "Spezifikationen", fr: "Spécifications", es: "Especificaciones", it: "Specifiche", ar: "المواصفات", ja: "仕様" },
};
const techBlocks = [
  { label: pickText(techBlockLabels.technicalSummary), html: product.technicalSummary },
  { label: pickText(techBlockLabels.useCases), html: product.useCases },
  { label: pickText(techBlockLabels.specifications), html: product.specifications }
].filter((block) => block.html && String(block.html).trim());

// Schema.org Graph
const graphSchema = {
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_ORIGIN}/${locale}` },
        { "@type": "ListItem", "position": 2, "name": "Products", "item": `${SITE_ORIGIN}/${locale}/products` },
        { "@type": "ListItem", "position": 3, "name": product.title }
      ]
    },
    {
      "@type": "Product",
      "name": product.title,
      "sku": product.slug || product.id,
      "image": product.image ? [`${SITE_ORIGIN}/${product.image}`.replace(/([^:])\/\//g, "$1/")] : [],
      "description": product.shortDescription || "",
      "brand": { "@type": "Brand", "name": "WillowSoft" },
      "manufacturer": { "@id": `${SITE_ORIGIN}/#org` },
      "category": product.category || "Product",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "seller": { "@id": `${SITE_ORIGIN}/#org` },
        "url": `${SITE_ORIGIN}/${locale}/products/${slug}`
      }
    }
  ]
};


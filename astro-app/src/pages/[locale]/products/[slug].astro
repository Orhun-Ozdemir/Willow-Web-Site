function getProductHighlights(p: any, locale: string) {
  const s = p.specifications || {};
  const highlights: { value: string; label: string }[] = [];
  for (const item of WS_HIGHLIGHT_KEYS) {
    const foundKey = item.keys.find(k => s[k] !== undefined);
    if (foundKey) {
      highlights.push({
        value: String(s[foundKey]),
        label: item.label[locale as keyof typeof item.label] || item.label.en
      });
    }
  }
  return highlights.slice(0, 4);
}


import { localizedValue, localizeItem, locales, type Locale } from "@/lib/cms";
import { buildAlternates, DEFAULT_OG_IMAGE, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA, SITE_ORIGIN } from "@/lib/seo";
import { aiMetaForPage, appendSchemaNodes, faqSchemaNode, stripHtml, type AiFaqItem } from "@/lib/ai-search";
import { getProductExtras } from "@/lib/product-extras";

export const prerender = false;

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
const content = await loadContent();
const rawProduct = (content.products || []).find((p: any) => p.slug === slug || p.id === slug);

if (!rawProduct) {
  return Astro.redirect(`/${locale}/products`);
}

const product = localizeItem(rawProduct, locale);
const seo = rawProduct.seo?.[locale] || {};
const titleLower = (product.title || "").toLowerCase();
const pickText = (value: any) => localizedValue(value, locale);

// Category text mappings
const categoryMap: Record<string, string> = {
  modules: "Use this module as the embedded core of low-power connected devices where firmware, RF performance and long-term maintainability matter.",
  environment: "Use this sensor family for environmental telemetry, alerts and remote monitoring in industrial, utility and field conditions.",
  tracking: "Use this device family to detect movement, access, safety events and asset state changes across distributed sites.",
  industrial: "Use this product to connect industrial equipment, Modbus devices and telemetry workflows into a unified platform."
};
const localizedFitText = {
  en: categoryMap[product.category] || "Use this product as part of a reliable connected product ecosystem.",
  tr: "Bu ürünü güvenilir bir bağlı ürün ekosisteminin parçası olarak konumlandırın.",
  de: "Nutzen Sie dieses Produkt als Teil eines zuverlässigen vernetzten Produktsystems.",
  fr: "Positionnez ce produit comme une brique d'un écosystème connecté fiable.",
  es: "Use este producto como parte de un ecosistema conectado fiable.",
  it: "Usa questo prodotto come parte di un ecosistema connesso affidabile.",
  ar: "استخدم هذا المنتج كجزء من منظومة منتجات متصلة وموثوقة.",
  ja: "この製品を信頼性の高い接続システムの一部として活用できます。",
};
const fitText = pickText(localizedFitText);

const snapshotMap: Record<string, string> = {

  },
  selectionQuestion: {
    en: `When should a buyer choose ${product.title}?`,
    tr: `Bir alıcı ${product.title} ürününü ne zaman seçmeli?`,
    de: `Wann sollte ein Käufer ${product.title} wählen?`,
    fr: `Quand choisir ${product.title} ?`,
    es: `¿Cuándo debería elegirse ${product.title}?`,
    it: `Quando scegliere ${product.title}?`,
    ar: `متى يجب اختيار ${product.title}؟`,
    ja: `${product.title} はどのような場合に選ぶべきですか？`,
  },
  integrationAnswer: {
    en: "It can be used as part of a complete WillowSoft hardware, firmware, backend and dashboard stack.",
    tr: "Eksiksiz bir WillowSoft donanım, firmware, backend ve dashboard yığınının parçası olarak kullanılabilir.",
    de: "Es kann als Teil eines vollständigen WillowSoft-Stacks aus Hardware, Firmware, Backend und Dashboard genutzt werden.",
    fr: "Il peut être utilisé dans une pile WillowSoft complète avec matériel, firmware, backend et tableau de bord.",
    es: "Puede usarse como parte de un stack completo de WillowSoft con hardware, firmware, backend y dashboard.",
    it: "Può essere usato come parte di uno stack WillowSoft completo con hardware, firmware, backend e dashboard.",
    ar: "يمكن استخدامه ضمن حزمة WillowSoft متكاملة تشمل العتاد والبرمجيات الثابتة والخلفية ولوحة التحكم.",
    ja: "WillowSoft のハードウェア、ファームウェア、バックエンド、ダッシュボードを含む統合スタックの一部として利用できます。",
  },
};
const productFaqItems: AiFaqItem[] = [
  { question: pickText(productFaqLabels.useQuestion), answer: stripHtml(decision.use) },
  { question: pickText(productFaqLabels.integrationQuestion), answer: stripHtml(pickText(productFaqLabels.integrationAnswer)) },
  { question: pickText(productFaqLabels.selectionQuestion), answer: stripHtml(fitText) },

function wsSpecLabel(key: string, locale: Locale) {
  if (WS_SPEC_LABELS[key]) {
    return WS_SPEC_LABELS[key][locale] || WS_SPEC_LABELS[key]["en"];
  }
  const words = key
    .replace(/[_-]+/g, " ")
    .replace(/([A-Z])/g, " $1")
    .trim()
    .toLowerCase();
  return words.charAt(0).toUpperCase() + words.slice(1);
}


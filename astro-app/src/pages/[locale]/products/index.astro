---
import PageLayout from "@/layouts/PageLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import FaqAccordion from "@/components/FaqAccordion.astro";
import AIAnswerBlock from "@/components/AIAnswerBlock.astro";
import { loadContent } from "@/lib/content";
import { pageSeo, webPageNode, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA, SITE_ORIGIN } from "@/lib/seo";
import { localizedValue, localizeItem, pageButtonParts, pageLocaleHref, pageText, resolveAsset, resolveLocale, type Locale } from "@/lib/cms";
import { aiAnswerForPage, aiMetaForPage, appendSchemaNodes, fallbackFaqsForPage, faqItemsForPage, faqSchemaNode } from "@/lib/ai-search";
import { productCategoriesFromContent, productCategoryText } from "@/lib/product-categories";

export const prerender = false;

const locale = resolveLocale(Astro.params.locale, Astro.url.pathname);
const content = await loadContent();
const seoProps = pageSeo(content, "products", locale, "/products", "Products | WillowSoft", "Industrial-grade LoRaWAN hardware portfolio.");
const pageContent = content.pageContent?.products || {};
const companyFacts = content.companyFacts || {};

const productsList = (content.products || []).filter((p: any) => p.visible !== false);
const productsFallbackFaqs = fallbackFaqsForPage("products", locale);
const productsFaqItems = faqItemsForPage(content.faqs || [], "products", locale, productsFallbackFaqs);
const aiAnswer = aiAnswerForPage(content, "products", locale, seoProps.description);
const aiMeta = aiMetaForPage(content, "products", locale);

const productsItemListId = `${seoProps.canonical}#itemlist`;
const productsSchema = appendSchemaNodes({
  "@context": "https://schema.org",
  "@graph": [
    ORGANIZATION_SCHEMA,
    WEBSITE_SCHEMA,
    {
      ...webPageNode("CollectionPage", seoProps.canonical, seoProps.title, seoProps.description, locale),
      mainEntity: { "@id": productsItemListId },
    },
    {
      "@type": "ItemList",
      "@id": productsItemListId,
      itemListElement: productsList.map((product: any, idx: number) => ({
        "@type": "ListItem",
        position: idx + 1,
        name: localizedValue(product.title, locale),
        url: `${SITE_ORIGIN}/${locale}/products/${product.slug || product.id}`,
      })),
    },
  ],
}, [faqSchemaNode(seoProps.canonical, productsFaqItems)]);

const previewLabel = (en: string, tr: string) => ({
  en, tr, de: en, fr: en, es: en, it: en, ar: en, ja: en,
});

const labels = {
  productsOnMarket: { en: "Products on Market", tr: "Piyasadaki Ürünler", de: "Produkte am Markt", fr: "Produits sur le marché", es: "Productos en el mercado", it: "Prodotti sul mercato", ar: "منتجات في السوق", ja: "市場実績製品" },
  catalogItems: { en: "catalog items", tr: "katalog ürünü", de: "Katalogartikel", fr: "articles du catalogue", es: "artículos del catálogo", it: "articoli a catalogo", ar: "عنصر في الكتالوج", ja: "ラインナップ" },
  fieldReadyOptions: { en: "field-ready options", tr: "sahaya hazır seçenek", de: "praxisbereite Optionen", fr: "options prêtes pour le terrain", es: "opciones listas para el campo", it: "opzioni pronte per il campo", ar: "خيار جاهز للموقع", ja: "IP67定格デバイス" },
  featuredHardware: { en: "Featured Hardware", tr: "Öne Çıkan Donanım", de: "Vorgestellte Hardware", fr: "Matériel vedette", es: "Hardware destacado", it: "Hardware in evidenza", ar: "الأجهزة المميزة", ja: "主要製品" },
  willowbeeCore: { en: "WillowBee at the core.", tr: "Çekirdekte WillowBee var.", de: "WillowBee im Kern.", fr: "WillowBee au cœur.", es: "WillowBee en el núcleo.", it: "WillowBee al centro.", ar: "WillowBee في القلب.", ja: "核となる無線マイコン「WillowBee」" },
  willowbeeDesc: {
    en: "A compact LoRaWAN-enabled MCU module for low-power sensor end-nodes.",
    tr: "Düşük güç tüketen sensör uç düğümleri için LoRaWAN özellikli kompakt bir MCU modülü.",
    de: "Ein kompaktes LoRaWAN-fähiges MCU-Modul für stromsparende Sensorendknoten.",
    fr: "Un module MCU compact compatible LoRaWAN pour les nœuds d'extrémité de capteurs basse consommation.",
    es: "Un módulo MCU compacto compatible con LoRaWAN para nodos finales de sensores de bajo consumo.",
    it: "Un modulo MCU compatto abilitato LoRaWAN per nodi terminali di sensori a basso consumo.",
    ar: "وحدة MCU مدمجة تدعم LoRaWAN لعقد استشعار طرفية منخفضة الطاقة.",
    ja: "低消費電力センサ端末向けに設計された、超小型LoRaWAN対応無線マイコンモジュール。"
  },

  // Proof section
  rangeLabel: { en: "Range", tr: "Mesafe", de: "Reichweite", fr: "Portée", es: "Alcance", it: "Portata", ar: "المدى", ja: "通信距離" },
  rangeVal: { en: "15 km", tr: "15 km", de: "15 km", fr: "15 km", es: "15 km", it: "15 km", ar: "١٥ كم", ja: "15 km" },
  rangeDesc: {
    en: "Long-range LoRaWAN communication for remote field deployments.",
    tr: "Uzak saha kurulumları için uzun menzilli LoRaWAN iletişimi.",
    de: "LoRaWAN-Kommunikation mit großer Reichweite für Remote-Feldeinsätze.",
    fr: "Communication LoRaWAN longue portée pour les déploiements sur le terrain à distance.",
    es: "Comunicación LoRaWAN de largo alcance para implementaciones de campo remotas.",
    it: "Comunicazione LoRaWAN a lungo raggio per installazioni remote sul campo.",
    ar: "اتصال LoRaWAN طويل المدى لعمليات النشر الميدانية البعيدة.",
    ja: "ゲートウェイから離れた現場でも通信を確保する長距離LoRaWAN規格。"
  },

  batteryLabel: { en: "Battery", tr: "Pil Ömrü", de: "Batterie", fr: "Batterie", es: "Batería", it: "Batteria", ar: "البطارية", ja: "バッテリー" },
  batteryVal: { en: "10 yrs", tr: "10 Yıl", de: "10 Jahre", fr: "10 ans", es: "10 años", it: "10 anni", ar: "١٠ سنوات", ja: "10 年" },
  batteryDesc: {
    en: "Low-power hardware design for unattended sensor operation.",
    tr: "Müdahalesiz sensör çalışması için düşük güçlü donanım tasarımı.",
    de: "Stromsparendes Hardware-Design für wartungsfreien Sensorbetrieb.",
    fr: "Conception matérielle basse consommation pour un fonctionnement sans surveillance des capteurs.",
    es: "Diseño de hardware de bajo consumo para el funcionamiento de sensores sin supervisión.",
    it: "Design hardware a basso consumo per il funzionamento dei sensori senza manutenzione.",
    ar: "تصميم أجهزة منخفضة الطاقة لتشغيل المستشعرات دون الحاجة إلى صيانة.",
    ja: "電池交換の手間を省き、長期の単独動作を可能にする省電力設計。"
  },

  outdoorLabel: { en: "Outdoor", tr: "Dış Ortam", de: "Außenbereich", fr: "Extérieur", es: "Exterior", it: "Esterno", ar: "خارجي", ja: "耐環境性" },
  outdoorVal: { en: "IP67", tr: "IP67", de: "IP67", fr: "IP67", es: "IP67", it: "IP67", ar: "IP67", ja: "IP67" },
  outdoorDesc: {
    en: "Rugged enclosures for industrial, utility and outdoor sites.",
    tr: "Endüstriyel, altyapı ve dış mekan sahaları için dayanıklı korumalı kutu tasarımları.",
    de: "Robuste Gehäuse für Industrie-, Versorgungs- und Außenstandorte.",
    fr: "Boîtiers robustes pour les sites industriels, de services publics et extérieurs.",
    es: "Gabinetes robustos para sitios industriales, de servicios públicos y exteriores.",
    it: "Custodie robuste per siti industriali, di servizi pubblici e all'aperto.",
    ar: "علب متينة للمواقع الصناعية ومواقع المرافق والمواقع الخارجية.",
    ja: "工場、プラント、屋外など過酷な環境での使用に耐えうる防塵防水筐体。"
  },

  regionsLabel: { en: "Regions", tr: "Frekanslar", de: "Regionen", fr: "Régions", es: "Regiones", it: "Regioni", ar: "المناطق", ja: "グローバル対応" },
  regionsVal: { en: "7", tr: "7 Plan", de: "7 Pläne", fr: "7 plans", es: "7 planes", it: "7 bande", ar: "٧ خطط", ja: "7 帯域" },
  regionsDesc: {
    en: "US915, EU868, AS923, AU915, KR920, IN865 and RU864 support.",
    tr: "US915, EU868, AS923, AU915, KR920, IN865 ve RU864 frekans desteği.",
    de: "Unterstützung für US915, EU868, AS923, AU915, KR920, IN865 und RU864.",
    fr: "Prise en charge de US915, EU868, AS923, AU915, KR920, IN865 et RU864.",
    es: "Soporte para US915, EU868, AS923, AU915, KR920, IN865 y RU864.",
    it: "Supporto per US915, EU868, AS923, AU915, KR920, IN865 e RU864.",
    ar: "دعم خطط الترددات US915, EU868, AS923, AU915, KR920, IN865, RU864.",
    ja: "US915、EU868、AS923、AU915など、各国の周波数プランをサポート。"
  },

  browseProducts: { en: "Explore Products", tr: "Ürünleri İnceleyin", de: "Produkte entdecken", fr: "Explorer les produits", es: "Explorar productos", it: "Esplora i prodotti", ar: "استكشف المنتجات", ja: "製品を見る" },
  talkToEngineer: { en: "Talk to an Engineer", tr: "Teknik Ekiple Görüşün", de: "Mit Technik sprechen", fr: "Parler à un ingénieur", es: "Hablar con ingeniería", it: "Parla con un ingegnere", ar: "تحدث مع مهندس", ja: "技術チームに相談" },
  productionReady: { en: "Production-ready platform", tr: "Üretime hazır platform", de: "Serienreife Plattform", fr: "Plateforme prête pour la production", es: "Plataforma lista para producción", it: "Piattaforma pronta per la produzione", ar: "منصة جاهزة للإنتاج", ja: "量産対応プラットフォーム" },
  flagshipCta: { en: "Explore WillowBee", tr: "WillowBee'yi İnceleyin", de: "WillowBee entdecken", fr: "Découvrir WillowBee", es: "Explorar WillowBee", it: "Scopri WillowBee", ar: "استكشف WillowBee", ja: "WillowBeeを見る" },
  selectionEyebrow: { en: "Engineering support", tr: "Mühendislik desteği", de: "Technischer Support", fr: "Support d’ingénierie", es: "Soporte de ingeniería", it: "Supporto ingegneristico", ar: "دعم هندسي", ja: "技術サポート" },
  selectionTitle: { en: "Not sure which product fits your field application?", tr: "Saha uygulamanız için doğru üründen emin değil misiniz?", de: "Welches Produkt passt zu Ihrer Anwendung?", fr: "Quel produit convient à votre application ?", es: "¿Qué producto se adapta a su aplicación?", it: "Quale prodotto è adatto alla tua applicazione?", ar: "ما المنتج المناسب لتطبيقك؟", ja: "現場に最適な製品をお探しですか？" },
  selectionLead: { en: "Share the measurement, environment and connectivity requirements. Our engineering team will recommend the right hardware and system architecture.", tr: "Ölçmek istediğiniz değeri, çalışma ortamını ve bağlantı ihtiyacınızı paylaşın. Mühendislik ekibimiz doğru donanımı ve sistem mimarisini birlikte belirlesin.", de: "Teilen Sie Mess-, Umgebungs- und Konnektivitätsanforderungen. Unser Team empfiehlt Hardware und Architektur.", fr: "Partagez vos besoins de mesure, d’environnement et de connectivité. Notre équipe recommandera le matériel adapté.", es: "Comparta sus requisitos de medición, entorno y conectividad. Nuestro equipo recomendará el hardware adecuado.", it: "Condividi requisiti di misura, ambiente e connettività. Il nostro team consiglierà l'hardware adatto.", ar: "شارك متطلبات القياس والبيئة والاتصال وسيوصي فريقنا بالأجهزة المناسبة.", ja: "計測対象、設置環境、通信要件を共有いただければ、最適なハードウェアと構成をご提案します。" },
  systemEyebrow: previewLabel("Connected product architecture", "Bağlı ürün mimarisi"),
  systemTitle: previewLabel("Hardware is only the beginning.", "Donanım yalnızca başlangıç."),
  systemLead: previewLabel("WillowSoft combines the device, connectivity and software layers so field data becomes an operational decision.", "WillowSoft; cihaz, bağlantı ve yazılım katmanlarını birlikte geliştirir. Böylece saha verisi yalnızca toplanmaz, operasyonel karara dönüşür."),
  systemStepOneTitle: previewLabel("Field device", "Saha cihazı"),
  systemStepOneDesc: previewLabel("Low-power sensing and industrial enclosure", "Düşük güçlü ölçüm ve endüstriyel gövde"),
  systemStepTwoTitle: previewLabel("LoRaWAN network", "LoRaWAN ağı"),
  systemStepTwoDesc: previewLabel("Long-range, regional frequency support", "Uzun menzil ve bölgesel frekans desteği"),
  systemStepThreeTitle: previewLabel("Cloud and API", "Cloud ve API"),
  systemStepThreeDesc: previewLabel("Secure ingestion, rules and integrations", "Güvenli veri alımı, kurallar ve entegrasyonlar"),
  systemStepFourTitle: previewLabel("Operational interface", "Operasyon arayüzü"),
  systemStepFourDesc: previewLabel("Web, mobile, alerts and reporting", "Web, mobil, alarm ve raporlama"),
  systemCta: previewLabel("Discuss your architecture", "Sistem mimarinizi görüşün"),

  // Filters
  filterAll: { en: "All", tr: "Tümü", de: "Alle", fr: "Tous", es: "Todos", it: "Tutti", ar: "الكل", ja: "すべて" },
  heroEyebrow: { en: "Products", tr: "Ürünler", de: "Produkte", fr: "Produits", es: "Productos", it: "Prodotti", ar: "المنتجات", ja: "製品" },
  catalogEyebrow: { en: "Catalog", tr: "Katalog", de: "Katalog", fr: "Catalogue", es: "Catálogo", it: "Catalogo", ar: "الكتالوج", ja: "カタログ" },
  filterModules: { en: "Modules", tr: "Modüller", de: "Module", fr: "Modules", es: "Módulos", it: "Moduli", ar: "وحدات", ja: "通信モジュール" },
  filterEnvironment: { en: "Environment & Sensing", tr: "Çevre & Ölçüm", de: "Umwelt & Messung", fr: "Environnement & Mesure", es: "Entorno y medición", it: "Ambiente e misura", ar: "البيئة والقياس", ja: "環境・計測" },
  filterTracking: { en: "Assets & Safety", tr: "Varlık & Güvenlik", de: "Assets & Sicherheit", fr: "Actifs & Sécurité", es: "Activos y seguridad", it: "Asset e sicurezza", ar: "الأصول والسلامة", ja: "資産・安全" },
  filterIndustrial: { en: "Industrial Process", tr: "Endüstriyel Proses", de: "Industrieprozess", fr: "Process industriel", es: "Proceso industrial", it: "Processo industriale", ar: "العمليات الصناعية", ja: "産業プロセス" },
  categoryLogic: {
    en: "Product families classified by operational purpose — not enclosure shape.", tr: "Ürün aileleri; gövde biçimine göre değil, operasyonel kullanım amacına göre sınıflandırıldı.",
    de: "Produktfamilien nach Einsatzzweck statt Gehäuseform klassifiziert.", fr: "Familles de produits classées par usage opérationnel, et non par forme de boîtier.",
    es: "Familias de productos clasificadas por uso operativo, no por la forma de la carcasa.", it: "Famiglie di prodotti classificate per uso operativo, non per forma dell'involucro.",
    ar: "عائلات المنتجات مصنفة حسب الغرض التشغيلي وليس شكل الهيكل.", ja: "筐体形状ではなく、運用目的によって分類した製品群です。",
  },
  modulesDesc: previewLabel("Embedded LoRaWAN core", "Gömülü LoRaWAN çekirdeği"),
  environmentDesc: previewLabel("Level, air, climate and soil", "Seviye, hava, iklim ve toprak"),
  trackingDesc: previewLabel("Location, movement and alerts", "Konum, hareket ve acil durum"),
  industrialDesc: previewLabel("Pressure, Modbus and machine data", "Basınç, Modbus ve makine verisi"),
  productsVisible: {
    en: "products in view", tr: "ürün gösteriliyor", de: "Produkte angezeigt", fr: "produits affichés",
    es: "productos mostrados", it: "prodotti visualizzati", ar: "منتجًا معروضًا", ja: "製品を表示中",
  },
  catalogTitlePremium: previewLabel("Explore hardware by operational purpose.", "Donanımı kullanım amacına göre keşfedin."),
  catalogLeadPremium: previewLabel("Every device belongs to one of four clear families based on the job it performs in the field. Compare the role first, then the technical specification.", "Her cihaz, sahada üstlendiği göreve göre dört net aileden birine yerleştirildi. Önce operasyonel rolü, ardından teknik özellikleri karşılaştırın."),

  // FAQ Section
  faqEyebrow: { en: "Frequently asked", tr: "Sıkça sorulanlar", de: "Häufig gestellte Fragen", fr: "Questions fréquentes", es: "Preguntas frecuentes", it: "Domande frequenti", ar: "أسئلة مكررة", ja: "よくある質問" },
  faqTitle: { en: "Questions about our products.", tr: "Ürünlerimiz hakkında sorular.", de: "Fragen zu unseren Produkten.", fr: "Questions sur nos produits.", es: "Preguntas sobre nuestros productos.", it: "Domande sui nostri prodotti.", ar: "أسئلة مكررة حول منتجاتنا.", ja: "製品に関するよくある質問" },
  faqLead: {
    en: "Here are answers to the most common questions about our LoRaWAN devices and module specifications.",
    tr: "LoRaWAN cihazlarımız ve modül özelliklerimiz hakkında en sık sorulan soruların yanıtları.",
    de: "Hier finden Sie Antworten auf die häufigsten Fragen zu unseren LoRaWAN-Geräten und Modulspezifikationen.",
    fr: "Voici les réponses aux questions les plus courantes sur nos appareils LoRaWAN et les spécifications de nos modules.",
    es: "Aquí encontrará respuestas a las preguntas más comunes sobre nuestros dispositivos LoRaWAN y las especificaciones de los módulos.",
    it: "Ecco le risposte alle domande più comuni sui nostri dispositivi LoRaWAN e sulle specifiche dei moduli.",
    ar: "إليك إجابات الأسئلة الأكثر شيوعًا حول أجهزة LoRaWAN ومواصفات الوحدات لدينا.",
    ja: "LoRaWANデバイスの仕様や機能について、よくいただく技術的な質問です。"
  }
};

const getLabel = (key: keyof typeof labels) => {
  return labels[key][locale] || labels[key]["en"];
};

const pt = (key: string, labelKey: keyof typeof labels) => pageText(pageContent, key, locale, getLabel(labelKey));

const productSystemSteps = [
  { number: "01", title: pt("systemStepOneTitle", "systemStepOneTitle"), desc: pt("systemStepOneDesc", "systemStepOneDesc"), code: "SENSE" },
  { number: "02", title: pt("systemStepTwoTitle", "systemStepTwoTitle"), desc: pt("systemStepTwoDesc", "systemStepTwoDesc"), code: "CONNECT" },
  { number: "03", title: pt("systemStepThreeTitle", "systemStepThreeTitle"), desc: pt("systemStepThreeDesc", "systemStepThreeDesc"), code: "PROCESS" },
  { number: "04", title: pt("systemStepFourTitle", "systemStepFourTitle"), desc: pt("systemStepFourDesc", "systemStepFourDesc"), code: "ACT" },
];

const productCategories = productCategoriesFromContent(content).filter((category) => category.visible);
const catalogCategoryFor = (product: any) => String(product.category || "environment");

const catalogFamilies = [
  { key: "all", label: getLabel("filterAll"), description: getLabel("categoryLogic"), count: productsList.length, number: "00" },
  ...productCategories.map((category, index) => {
    const text = productCategoryText(category, locale);
    return {
      key: category.key,
      label: text.title,
      description: text.description,
      count: productsList.filter((product: any) => catalogCategoryFor(product) === category.key).length,
      number: String(index + 1).padStart(2, "0"),
    };
  }),
];

const featuredProductId = String(pageContent.featuredProductId || "willowbee");
const featuredProductRaw = productsList.find((product: any) => product.id === featuredProductId)
  || productsList.find((product: any) => product.featured)
  || productsList[0];
const featuredProduct = localizeItem(featuredProductRaw, locale);
const featuredImage = resolveAsset(
  featuredProduct?.id === "willowbee"
    ? "assets/product-cutouts/willowbee-lorawan-module.png"
    : featuredProduct?.cardImage || featuredProduct?.image || `assets/product-cutouts/${featuredProduct?.id || "willowbee"}.png`,
);
const featuredChips = Array.isArray(featuredProduct?.chips) ? featuredProduct.chips.slice(0, 3) : [];

const proofItems = [
  { label: pt("proofRangeLabel", "rangeLabel"), value: pt("proofRangeValue", "rangeVal"), description: pt("proofRangeDescription", "rangeDesc") },
  { label: pt("proofBatteryLabel", "batteryLabel"), value: pt("proofBatteryValue", "batteryVal"), description: pt("proofBatteryDescription", "batteryDesc") },
  { label: pt("proofOutdoorLabel", "outdoorLabel"), value: pt("proofOutdoorValue", "outdoorVal"), description: pt("proofOutdoorDescription", "outdoorDesc") },
  { label: pt("proofRegionsLabel", "regionsLabel"), value: pt("proofRegionsValue", "regionsVal"), description: pt("proofRegionsDescription", "regionsDesc") },
];

const buttonFor = (key: string, fallbackLabel: string, fallbackUrl: string) => {
  const button = pageButtonParts(pageContent[key], locale);
  const rawUrl = button.url || fallbackUrl;
  return {
    label: button.label || fallbackLabel,
    url: rawUrl.startsWith("#") ? rawUrl : pageLocaleHref(locale, pageContent[key], fallbackUrl),
  };
};
const heroPrimaryButton = buttonFor("heroPrimaryButton", getLabel("browseProducts"), "#catalog");
const selectionPrimaryButton = buttonFor("selectionPrimaryButton", getLabel("talkToEngineer"), `/${locale}/contact`);
---

<PageLayout
  {...seoProps}
  schema={productsSchema}
  locale={locale}
  dataPage="products"
>
  <main>
    <!-- Hero -->
    <section class="hero compact products-motion-hero">
      <canvas class="signal-canvas" data-density="34" data-color="24, 167, 255"></canvas>
      <div class="services-hero-light" aria-hidden="true"></div>
      <div class="hero-inner products-hero-grid">
        <div class="products-hero-copy">
          <p class="eyebrow reveal">{pt("heroEyebrow", "heroEyebrow")}</p>
          <h1 class="reveal delay-1">{pageText(pageContent, "heroTitle", locale)}</h1>
          <p class="reveal delay-2">{pageText(pageContent, "heroLead", locale)}</p>
          <div class="products-hero-actions reveal delay-3">
            <a class="btn btn-primary" href={heroPrimaryButton.url}>{heroPrimaryButton.label}</a>
          </div>
          <div class="services-hero-meta reveal delay-3" role="list" aria-label="Product portfolio facts">
            <span class="hero-meta-item" role="listitem">
              <strong data-company-fact="productsOnMarket">{companyFacts.productsOnMarket || "100+"}</strong>
              <span>{getLabel("productsOnMarket")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong>{productsList.length}</strong>
              <span>{getLabel("catalogItems")}</span>
            </span>
            <span class="hero-meta-divider" aria-hidden="true"></span>
            <span class="hero-meta-item" role="listitem">
              <strong>IP67</strong>
              <span>{getLabel("fieldReadyOptions")}</span>
            </span>
          </div>
        </div>
        <aside class="product-hero-showcase reveal delay-2" aria-label="Featured WillowSoft hardware">
          <div class="product-showcase-topline">
            <span>{pt("featuredStatus", "productionReady")}</span>
            <span class="product-live-dot" aria-hidden="true"></span>
          </div>
          <div class="product-showcase-stage">
            <span class="product-orbit product-orbit-one" aria-hidden="true"></span>
            <span class="product-orbit product-orbit-two" aria-hidden="true"></span>
            <img src={featuredImage} alt={featuredProduct?.title || "Featured product"} loading="lazy" decoding="async" />
            {featuredChips.map((chip: string, index: number) => (
              <span class={`product-spec-tag product-spec-tag-${["one", "two", "three"][index]}`}>{chip}</span>
            ))}
          </div>
          <div class="product-showcase-copy">
            <p class="architecture-label">{pt("featuredEyebrow", "featuredHardware")}</p>
            <h2>{featuredProduct?.title}</h2>
            <p>{featuredProduct?.shortDescription}</p>
            <a class="product-showcase-link" href={`/${locale}/products/${featuredProduct?.slug || featuredProduct?.id}`}>
              <span>{pt("featuredButtonLabel", "flagshipCta")}</span><span aria-hidden="true">↗</span>
            </a>
          </div>
        </aside>
      </div>
    </section>

    <!-- Proof section -->
    <section class="section product-proof-section">
      <div class="section-inner">
        <AIAnswerBlock answer={aiAnswer} locale={locale} meta={aiMeta} />
        <div class="product-proof-grid">
          {proofItems.map((item, index) => (
            <article class={`proof-stat-card reveal${index ? ` delay-${index}` : ""}`}>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Catalog section -->
    <section class="section soft product-catalog-section" id="catalog">
      <div class="section-inner">
        <div class="section-head reveal product-headline">
          <div>
            <p class="eyebrow">{pt("catalogEyebrow", "catalogEyebrow")}</p>
            <h2>{pt("catalogTitle", "catalogTitlePremium")}</h2>
            <p class="section-lead">{pt("catalogLead", "catalogLeadPremium")}</p>
          </div>
        </div>

        <div class="product-atlas reveal" aria-label="Product families">
          <div class="product-atlas-topline">
            <span>PRODUCT ATLAS / 2026</span>
            <span class="product-filter-status" aria-live="polite">{productsList.length} {getLabel("productsVisible")}</span>
          </div>
          <div class="filter-bar" role="group" aria-label="Product family filters">
            {catalogFamilies.map((family, index) => (
              <button class={`filter-btn${index === 0 ? " active" : ""}`} data-filter={family.key} aria-pressed={index === 0 ? "true" : "false"}>
                <span class="filter-btn-number">{family.number}</span>
                <span class="filter-btn-copy">
                  <strong>{family.label}</strong>
                  <small>{family.description}</small>
                </span>
                <span class="filter-btn-count">{String(family.count).padStart(2, "0")}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="grid grid-4 product-atlas-grid" data-cms-products>
          {productsList.map((p: any, idx: number) => (
            <ProductCard product={p} locale={locale} index={idx} variant="catalog" categories={productCategories} />
          ))}
        </div>
      </div>
    </section>

    <!-- Connected product architecture -->
    <section class="section product-system-section">
      <div class="section-inner">
        <div class="product-system-head reveal">
          <div>
            <p class="eyebrow">{pt("systemEyebrow", "systemEyebrow")}</p>
            <h2>{pt("systemTitle", "systemTitle")}</h2>
          </div>
          <div>
            <p>{pt("systemLead", "systemLead")}</p>
          </div>
        </div>
        <div class="product-system-flow">
          {productSystemSteps.map((step) => (
            <article class="product-system-step">
              <div><span>{step.number}</span><small>{step.code}</small></div>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Product selection CTA -->
    <section class="section product-selection-section">
      <div class="section-inner">
        <div class="product-selection-panel reveal">
          <div class="product-selection-copy">
            <p class="eyebrow">{pt("selectionEyebrow", "selectionEyebrow")}</p>
            <h2>{pt("selectionTitle", "selectionTitle")}</h2>
            <p>{pt("selectionLead", "selectionLead")}</p>
          </div>
          <div class="product-selection-actions">
            <a class="btn btn-primary" href={selectionPrimaryButton.url}>{selectionPrimaryButton.label}</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section soft services-faq-section" id="faq">
      <div class="section-inner">
        <div class="section-head reveal center" style={{ marginBottom: "36px" }}>
          <p class="eyebrow">{pt("faqEyebrow", "faqEyebrow")}</p>
          <h2 class="page-title">{pt("faqTitle", "faqTitle")}</h2>
          <p class="section-lead" style={{ maxWidth: "720px", marginLeft: "auto", marginRight: "auto" }}>
            {pt("faqLead", "faqLead")}
          </p>
        </div>
        <FaqAccordion faqs={content.faqs || []} pageKey="products" locale={locale} fallbackFaqs={productsFallbackFaqs} />
      </div>
    </section>
  </main>
</PageLayout>

<script>
  function setupProductFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const productCards = document.querySelectorAll('.product-card') as NodeListOf<HTMLElement>;

    const grid = document.querySelector('[data-cms-products]') as HTMLElement | null;
    const status = document.querySelector('.product-filter-status') as HTMLElement | null;
    const visibleSuffix = status?.textContent?.replace(/^\d+\s*/, '') || '';

    const applyFilter = (requestedFilter: string, updateUrl = false) => {
      const requestedButton = Array.from(filterButtons).find(
        button => (button as HTMLButtonElement).dataset.filter === requestedFilter,
      );
      const activeButton = requestedButton || Array.from(filterButtons).find(
        button => (button as HTMLButtonElement).dataset.filter === 'all',
      );
      const filter = (activeButton as HTMLButtonElement | undefined)?.dataset.filter || 'all';

      filterButtons.forEach(button => {
        const isActive = button === activeButton;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      let visibleCount = 0;
      productCards.forEach(card => {
        const isVisible = filter === 'all' || card.dataset.category === filter;
        card.style.display = isVisible ? '' : 'none';
        if (isVisible) {
          visibleCount += 1;
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        }
      });

      grid?.classList.toggle('is-filtered', filter !== 'all');
      if (status) status.textContent = `${visibleCount} ${visibleSuffix}`;

      if (updateUrl) {
        const nextUrl = new URL(window.location.href);
        if (filter === 'all') nextUrl.searchParams.delete('category');
        else nextUrl.searchParams.set('category', filter);
        window.history.replaceState({}, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
      }
    };

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        applyFilter((button as HTMLButtonElement).dataset.filter || 'all', true);
      });
    });

    applyFilter(new URLSearchParams(window.location.search).get('category') || 'all');
  }

  // Initial setup
  setupProductFilters();
  // Setup on page transition if any
  document.addEventListener('astro:after-swap', setupProductFilters);
</script>

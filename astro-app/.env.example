# Astro app environment — copy to astro-app/.env and fill in.
# Astro auto-loads this file in dev/build; Vercel reads the same vars from project settings.

SUPABASE_URL=https://chemyzlmjqvnoxeqxfku.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Server-side only — NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin panel (/admin) ──────────────────────────────────────────────────────
# REQUIRED in production. If ADMIN_PASSWORD is not set in production, the env-var
# login fallback is DISABLED (the baked-in dev default is refused), so set these.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Signs the stateless admin session cookie. REQUIRED in production — if left as the
# dev default, anyone who knows it can forge admin sessions. Use a long random value.
SESSION_SECRET=change-me-to-a-long-random-string
